#target rom
#charset ascii
.asm8080

#include "./include/kernel.inc"
#include "kernel_time.inc"
TICKS_PER_SECOND    EQU 50          ; 50 квантов по 20 мс = ровно 1 секунда
#include "hw.inc"
; =============================================================================
; АДРЕСА ПОРТОВ ПЕРИФЕРИИ И АППАРАТНЫЕ КОНСТАНТЫ СИСТЕМЫ / POSIX
; =============================================================================
; --- АППАРАТНЫЕ ПОРТЫ ИНТЕРФЕЙСОВ МЕГА-580 ---
; --- Базовые порты контроллера прерываний ВН59 №1 (МАСТЕР) ---
MASTER_8259_DATA 	EQU 0A0H    ; КР580ВН59 — Порт данных
MASTER_8259_CMD  	EQU 0A1H    ; КР580ВН59 — Порт команд/статуса

SYS_ISR_TABLE_BASE  EQU 0040H	; Базовый физический адрес таблицы векторов
SYS_MAX_IRQS        EQU 8		; 8 аппаратных линий (IRQ 0..7)
OPCODE_CALL         EQU 0CDH	; Код операции инструкции CALL процессора КР580ВМ80А

; --- Базовые порты системного таймера ВИ53 №1 ---
SYS_PIT_CH0         EQU 0B0H        ; Канал 0 (Вход 1 МГц -> Выход IRQ0)
SYS_PIT_CMD         EQU 0B3H        ; Управляющий порт БИС КР580ВИ53 №1
; --- Управляющие слова (Control Words) КР580ВИ53 ---
PIT_CW_CH0_M0       EQU 030H        ; Канал 0, Чтение/Запись LSB/MSB, Режим 0 (Проверка)
PIT_CW_CH0_M3       EQU 036H        ; Канал 0, Чтение/Запись LSB/MSB, Режим 3 (Меандр)
PIT_CW_LATCH_CH0    EQU 000H        ; Команда защелкивания счета для Канала 0

; --- Базовые порты контроллера прямого доступа к памяти ВТ57 ---
;DMA_CH0_ADDR		EQU 020H	; Канал 0: Регистр текущего адреса (2 байта последовательно)
;DMA_CH0_COUNT		EQU 021H	; Канал 0: Счетчик терминальных циклов (2 байта)
;DMA_CMD_STATUS		EQU 028H	; Управляющий регистр (OUT) / Регистр статуса (IN)

; --- Базовые адреса сегментно-страничной памяти ---
EMMU_PAGE_0			EQU 0000H 	; Базовый адрес сегмента 0 Ring 3
EMMU_PAGE_1			EQU	4000H	; Базовый адрес сегмента 1 Ring 3
EMMU_PAGE_2			EQU 8000H	; Базовый адрес сегмента 2 Ring 3
EMMU_PAGE_3			EQU 0C000H	; Базовый адрес сегмента 3 Ring 3
EMMU_PAGE_SIZE		EQU 4000H	; Размер сегмента
; --- Базовые порты управления сегментно-страничным модулем памяти ---
EMMU_PAGE_REG0		EQU 070H 	; Сегмент 0 Ring 3
EMMU_PAGE_REG1		EQU	071H	; Сегмент 1 Ring 3
EMMU_PAGE_REG2		EQU 072H	; Сегмент 2 Ring 3
EMMU_PAGE_REG3		EQU 073H	; Сегмент 3 Ring 3
EMMU_ROM_DISABLE	EQU	075H	; Отключение ПЗУ
EMMU_OVERRIDE		EQU 076H	; Kernel Override
; --- БИТЫ УПРАВЛЕНИЯ KERNEL OVERRIDE ---
KERNEL_OVERRIDE_ON   EQU 0       ; Или другое значение для включения оверрана
KERNEL_OVERRIDE_OFF  EQU 1       ; Или другое значение для выключения

; --- Физическая карта базовых портов для 4-х консолей TTY ---
TTY0_BASE_PORT      EQU 0A0H        ; Базовый порт для TTY0
TTY1_BASE_PORT      EQU 0B0H        ; Базовый порт для TTY1
TTY2_BASE_PORT      EQU 0C0H        ; Базовый порт для TTY2
TTY3_BASE_PORT      EQU 0D0H        ; Базовый порт для TTY3

; --- Аппаратные 8-битные базовые порты ввода-вывода КР580ВМ80А ---
; (Адреса LPT0=0x378 и LPT1=0x278 на шине eMMU РЕВ_2.0 отражены в 8-битную кучу)
LPT0_BASE_PORT      EQU 078H        ; Базовый физический порт данных LPT0
LPT1_BASE_PORT      EQU 028H        ; Базовый физический порт данных LPT1
#include "signals.inc"
; =============================================================================
; НАЗВАНИЕ: signals.inc (Спецификация 16-битных POSIX-сигналов ядра)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | eMMU РЕВ_2.0
; =============================================================================

; === БЛОК 1: МЛАДШИЙ БАЙТ МАСКИ СИГНАЛОВ — O_SIG_PENDING (+26) ===
; Отвечает за системные сигналы с номерами от 1 до 8.

SIG_HUP             EQU 1           ; Сигнал 1: Обрыв линии терминала / сессии (SIGHUP)
SIGHUP_MASK_L       EQU 001H        ; Бит 0 (00000001b)

SIG_INT             EQU 2           ; Сигнал 2: Прерывание пользователя Ctrl+C (SIGINT)
SIGINT_MASK_L       EQU 002H        ; Бит 1 (00000010b)

SIG_QUIT            EQU 3           ; Сигнал 3: Останов процесса с дампом Ctrl+\ (SIGQUIT)
SIGQUIT_MASK_L      EQU 004H        ; Бит 2 (00000100b)

SIG_ILL             EQU 4           ; Сигнал 4: Недопустимый код операции CPU (SIGILL)
SIGILL_MASK_L       EQU 008H        ; Бит 3 (00001000b)

SIG_TRAP            EQU 5           ; Сигнал 5: Трассировочная ловушка отладчика (SIGTRAP)
SIGTRAP_MASK_L      EQU 010H        ; Бит 4 (00010000b)

SIG_ABRT            EQU 6           ; Сигнал 6: Аварийное завершение через abort() (SIGABRT)
SIGABRT_MASK_L      EQU 020H        ; Бит 5 (00100000b)

SIG_BUS             EQU 7           ; Сигнал 7: Ошибка системной шины / оверран eMMU (SIGBUS)
SIGBUS_MASK_L       EQU 040H        ; Бит 6 (01000000b)

SIG_FPE             EQU 8           ; Сигнал 8: Арифметическая ошибка / деление на ноль (SIGFPE)
SIGFPE_MASK_L       EQU 080H        ; Бит 7 (10000000b)


; === БЛОК 2: СТАРШИЙ БАЙТ МАСКИ СИГНАЛОВ — O_SIG_PENDING + 1 (+27) ===
; Отвечает за системные сигналы с номерами от 9 до 16.

SIG_KILL            EQU 9           ; Сигнал 9: Безусловное неперехватываемое убийство (SIGKILL)
SIGKILL_MASK_H      EQU 001H        ; Бит 0 (00000001b)

SIG_USR1            EQU 10          ; Сигнал 10: Пользовательский сигнал №1 (SIGUSR1)
SIGUSR1_MASK_H      EQU 002H        ; Бит 1 (00000010b)

SIG_SEGV            EQU 11          ; Сигнал 11: Нарушение защиты/границ памяти (SIG_SEGV)
SIGSEGV_MASK_H      EQU 004H        ; Бит 2 (00000100b)

SIG_USR2            EQU 12          ; Сигнал 12: Пользовательский сигнал №2 (SIGUSR2)
SIGUSR2_MASK_H      EQU 008H        ; Бит 3 (00001000b)

SIG_PIPE            EQU 13          ; Сигнал 13: Запись в пайп / сокет без читателя (SIGPIPE)
SIGPIPE_MASK_H      EQU 010H        ; Бит 4 (00010000b)

SIG_ALRM            EQU 14          ; Сигнал 14: Истечение таймера будильника ВИ53 (SIGALRM)
SIGALRM_MASK_H      EQU 020H        ; Бит 5 (00100000b)

SIG_TERM            EQU 15          ; Сигнал 15: Мягкое программное завершение процесса (SIGTERM)
SIGTERM_MASK_H      EQU 040H        ; Бит 6 (01000000b)

SIG_CHLD            EQU 16          ; Сигнал 16: Сигнал родителю от умершего потомка (SIGCHLD)
SIGCHLD_MASK_H      EQU 080H        ; Бит 7 (10000000b)


; === БЛОК 3: КОМБИНИРОВАННЫЕ МАСКИ СМЕРТЕЛЬНЫХ СИГНАЛОВ ДЛЯ ISR ===
; Позволяют ядру одной быстрой командой отфильтровать критические ситуации.

; Маска смертельных сигналов младшего байта (HUP, INT, QUIT, ILL, ABRT, BUS, FPE)
SIG_FATAL_MASK_L    EQU SIGHUP_MASK_L OR SIGINT_MASK_L OR SIGQUIT_MASK_L OR SIGILL_MASK_L OR SIGABRT_MASK_L OR SIGBUS_MASK_L OR SIGFPE_MASK_L

; Маска смертельных сигналов старшего байта (KILL, SEGV, TERM)
SIG_FATAL_MASK_H    EQU SIGKILL_MASK_H OR SIGSEGV_MASK_H OR SIGTERM_MASK_H
#include "pcb.inc"
; =============================================================================
; /include/pcb.inc - КАНОНИЧЕСКАЯ UNIX-СТРУКТУРА PCB (ВЕРСИЯ 1.5.75_STABLE)
; ТОКЕН:    TOKEN::MEGA-580_OS_v1.5.75_PCB_INC_REBUILT_MATCHED_20260708
; =============================================================================
PCB_START           EQU 0

; --- БЛОК 1: РАНТАЙМ-СТАТУС И ИДЕНТИФИКАЦИЯ (0..7) ---
O_PID               EQU PCB_START    ; +0 [1 B] PID процесса (0=FREE, 1=init...)
O_STATUS            EQU O_PID + 1    ; +1 [1 B] Статус (READY, RUNNING, WAITING, ZOMBIE)
O_WAIT_CODE         EQU O_STATUS + 1 ; +2 [1 B] wait-channel (Причина сна)
O_SAVED_SP          EQU O_WAIT_CODE + 1 ; +3 [2 B] Сохраненный указатель стека Ring 3
O_SYSCALL_RES       EQU O_SAVED_SP + 2 ; +5 [1 B] Результат сисколла / exit code
O_PPID              EQU O_SYSCALL_RES + 1 ; +6 [1 B] PID родительского процесса
O_PAGE_DIRTY_MASK   EQU O_PPID + 1   ; +7 [1 B] Битовая маска измененных страниц eMMU

; --- БЛОК 2: АППАРАТНАЯ MMU-КАРТА И ОВЕРЛЕИ (8..15) ---
O_PAGES_MAP         EQU O_PAGE_DIRTY_MASK + 1 ; +8 [4 B] Физические страницы ОЗУ (Сегменты 0-3)
O_EXT_PAGES_MAP     EQU O_PAGES_MAP + 4 ; +12 [4 B] ОВЕРЛЕИ: Страницы динамических библиотек Ring 3

; --- БЛОК 3: ПРИОРИТЕТЫ ПЛАНИРОВАНИЯ POSIX (16..19) ---
O_PRIO_STATIC       EQU O_EXT_PAGES_MAP + 4 ; +16 [1 B] Базовый статический приоритет
O_PRIO_NICE         EQU O_PRIO_STATIC + 1 ; +17 [1 B] POSIX nice-поправка (0-40)
O_PRIO_DYNAMIC      EQU O_PRIO_NICE + 1 ; +18 [1 B] Текущий динамический приоритет
O_CPU_TICKS         EQU O_PRIO_DYNAMIC + 1 ; +19 [1 B] Штрафной счетчик времени CPU

; --- БЛОК 4: БЕЗОПАСНОСТЬ, СЕССИИ И ДЕМОНЫ (20..24) ---
O_UID               EQU O_CPU_TICKS + 1 ; +20 [1 B] User ID (0 = ROOT)
O_GID               EQU O_UID + 1    ; +21 [1 B] Group ID
O_PGID              EQU O_GID + 1    ; +22 [1 B] Process Group ID
O_SID               EQU O_PGID + 1   ; +23 [1 B] Session ID (Уникальный маркер демона)
O_TTY_INDEX         EQU O_SID + 1    ; +24 [1 B] Index управляющего TTY (0xFF = отвязан)

; --- БЛОК 5: АСИНХРОННЫЕ СИГНАЛЫ И ТАЙМЕРЫ (25..30) ---
O_SIG_PENDING       EQU O_TTY_INDEX + 1 ; +25 [2 B] 16-битная маска ожидающих сигналов
O_SIG_BLOCKED       EQU O_SIG_PENDING + 2 ; +27 [2 B] 16-битная маска заблокированных сигналов
O_SIG_TABLE_PTR     EQU O_SIG_BLOCKED + 2 ; +29 [2 B] Системный указатель на векторы sigaction

; --- БЛОК 6: ВВОД-ВЫВОД VFS С ЛИМИТОМ 16 ФАЙЛОВ НА ПРОЦЕСС (31..49) ---
O_CWD_INODE         EQU O_SIG_TABLE_PTR + 2 ; +31 [2 B] Номер Inode текущей директории файла
O_UMASK             EQU O_CWD_INODE + 2 ; +33 [1 B] Маска создания файлов (POSIX umask)
O_FILE_TABLE        EQU O_UMASK + 1  ; +34 [16 B] Локальная таблица 16 дескрипторов (FD 0..15)

; === ДОБАВЛЕНО В РАМКАХ ИНКРЕМЕНТА: СУПЕРВИЗОРСКИЙ РЕЗЕРВ (50..63) ===
O_ALARM_TICKS       EQU O_FILE_TABLE + 16 ; +50 [2 B] 16-битный счетчик мягкого POSIX-будильника

; === АВТОМАТИЧЕСКИЙ СИСТЕМНЫЙ КОНТРОЛЬ ГАБАРИТОВ ===
PCB_USED_SPACE      EQU O_ALARM_TICKS + 2 ; Всего занято по калькуляции = 52 байта
PCB_SIZE            EQU 64           ; КАНOНИЧНЫЙ ИНВАРИАНТ СОХРАНЕН БЕЗ СДВИГОВ!
O_RESERVED_PAD      EQU PCB_SIZE - PCB_USED_SPACE ; 12 байт глубокого резерва супервизора

; МАСШТАБЫ СИСТЕМЫ ДЛЯ ЧИСТОЙ RAM-МОДЕЛИ (4 МБ)
MAX_PROCS           EQU 32           ; 32 процесса (Таблица PCB_TABLE весит ровно 2 КБ)
RES_FREE_MARKER     EQU 0FFH         ; Маркер свободного ресурса

; Константы состояний процессов
ST_FREE             EQU 000h         ; Слот PCB свободен
ST_CREATED          EQU 001h         ; Процесс создается (sys_fork)
ST_READY            EQU 002h         ; Процесс готов к исполнению
ST_RUNNING          EQU 003h         ; Процесс выполняется на CPU
ST_WAITING          EQU 004h         ; Процесс заблокирован/спит асинхронно
ST_ZOMBIE           EQU 005h         ; Процесс мертв, ожидает waitpid()

; --- КОНСТАНТЫ РАСЧЕТА CPU_USAGE (0..4) ---
CPU_LOAD_0          EQU 0            ; 0%   - Процессор полностью простаивает
CPU_LOAD_25         EQU 1            ; 25%  - Низкая загрузка
CPU_LOAD_50         EQU 2            ; 50%  - Средняя загрузка
CPU_LOAD_75         EQU 3            ; 75%  - Высокая загрузка
CPU_LOAD_100        EQU 4            ; 100% - Полная загруженность
#include "vfs.inc"
; =============================================================================
; /include/vfs.inc - MEGA-580 OS - КОНСТАНТЫ И ОШИБКИ POSIX API (ВЕРСИЯ 1.5.2)
; =============================================================================

; --- ЛИМИТЫ И ГАБАРИТЫ ПОДСИСТЕМЫ VFS ---
VFS_MAX_TYPES      EQU 32           ; До 32 типов VFS драйверов!
VFS_DRV_OPS_COUNT  EQU 5            ; 5 методов: open, close, read, write, ioctl
VFS_ROW_SIZE       EQU 10           ; 5 методов * 2 байта = 10 байт на строку драйвера
MAX_SYS_FILES      EQU 128          ; 128 дескрипторов на систему
SYS_FILE_SLOT_SIZE EQU 10           ; Каноничный размер строки таблицы файлов = 10 байт
MAX_MOUNT_DEVS     EQU 16            ; Количество записей в таблице устройств /dev
MNT_ENTRY_SZ       EQU 6            ; Сжатый каноничный размер записи монтирования = 6 байт

; --- СМЕЩЕНИЯ МЕТОДОВ ВНУТРИ СТРОКИ VFS_SWITCH_TABLE (10 БАЙТ) ---
V_OP_OPEN          EQU 0            ; +0 [2 B]: Адрес функции open
V_OP_CLOSE         EQU 2            ; +2 [2 B]: Адрес функции close
V_OP_READ          EQU 4            ; +4 [2 B]: Адрес функции read
V_OP_WRITE         EQU 6            ; +6 [2 B]: Адрес функции write
V_OP_IOCTL         EQU 8            ; +8 [2 B]: Адрес функции ioctl

; --- ОФИЦИАЛЬНЫЕ MAJOR-НОМЕРА СИСТЕМНЫХ ДРАЙВЕРОВ ---
VFS_TYPE_FREE      EQU 000h         ; Слот свободен
VFS_TYPE_DISK      EQU 001h         ; Experimental FS (CompactFlash)
VFS_TYPE_PIPE      EQU 002h         ; IPC Конвейеры ОЗУ
VFS_TYPE_TTY       EQU 003h         ; Физический terminal КР580ВВ51А
VFS_TYPE_UNIX      EQU 004h         ; Программный сокет AF_UNIX
VFS_TYPE_INET      EQU 005h         ; Аппаратный Ethernet-сокет (KSZ8851)
VFS_TYPE_PTY       EQU 006h         ; Виртуальный псевдотерминал PTY
VFS_TYPE_LPT       EQU 007h         ; Аппаратный параллельный порт LPT

; --- СТРУКТУРА ГЛОБАЛЬНОЙ SYS_FILE_TABLE (СТРОГО 10 БАЙТ) ---
F_TYPE             EQU 0            ; Major Number [1 байт] (00h = Свободный слот)
F_MINOR            EQU 1            ; Minor Number [1 байт]
F_REF              EQU 2            ; Счетчик ссылок дескриптора [1 байт]
F_INODE            EQU 3            ; Номер дискового Inode [2 байта]
F_OFFSET           EQU 5            ; 32-битная позиция чтения/записи файла [4 байта]
F_DIRTY            EQU 9            ; Флаг грязного буфера отложенной записи [1 байт]
RES_FREE_MARKER    EQU 0FFh

; --- СТРУКТУРА ТАБЛИЦЫ МОНТИРОВАНИЯ DEV_MOUNT_TABLE (СТРОГО 6 БАЙТ) ---
; Устранено наложение смещений: структура выровнена линейно без дыр
MNT_START          EQU 0
O_MNT_PATH_PTR     EQU MNT_START    ; +0 [2 B] Указатель на ASCII-строку имени модуля
O_MNT_MAJOR        EQU 2            ; +2 [1 B] Номер связанного мажорного драйвера
O_MNT_MINOR        EQU 3            ; +3 [1 B] Номер минорного порта устройства
O_MNT_RESERVED     EQU 4            ; +4 [2 B] Резерв для выравнивания / Флаги доступа

; === КАНОНИЧЕСКИЕ POSIX-КОДЫ ОШИБОК ABI ЯДРА ===
EPERM              EQU 1            ; Operation not permitted
ENOENT             EQU 2            ; No such file or directory
ESRCH              EQU 3            ; No such process
EINTR              EQU 4            ; Interrupted system call
EIO                EQU 5            ; I/O error
EBADF              EQU 9            ; Bad file number
ECHILD             EQU 10           ; No child processes
EAGAIN             EQU 11           ; Try again
ENOMEM             EQU 12           ; Out of memory
EACCES             EQU 13           ; Permission denied
EFAULT             EQU 14           ; Bad address
EBUSY              EQU 16           ; Device or resource busy
EEXIST             EQU 17           ; File exists
ENODEV             EQU 19           ; No such device
EINVAL             EQU 22           ; Invalid argument
ENFILE             EQU 23           ; File table overflow
EMFILE             EQU 24           ; Too many open files
ENOTTY             EQU 25           ; Not a typewriter
ESPIPE             EQU 29           ; Invalid seek
EROFS              EQU 30           ; Read-only file system
EMLINK             EQU 31           ; Too many links
EPIPE              EQU 32           ; Broken pipe
EDOM               EQU 33           ; Math argument out of domain
ERANGE             EQU 34           ; Math result not representable
EDEADLK            EQU 35           ; Resource deadlock avoided
ENAMETOOLONG       EQU 36           ; File name too long
ENOLCK             EQU 37           ; No locks available
ENOSYS             EQU 38           ; Function not implemented
ENOTEMPTY          EQU 39           ; Directory not empty
ELOOP              EQU 40           ; Too many levels of symbolic links
EWOULDBLOCK        EQU EAGAIN       ; Operation would block
ENOMSG             EQU 42           ; No message of desired type
EIDRM              EQU 43           ; Identifier removed
EAFNOSUPPORT       EQU 97           ; Address family not supported
ENOTCONN           EQU 107          ; Transport endpoint is not connected

VFS_MAX_INODES      EQU 64          ; Максимальное число файлов на RAM-диске
INODE_STRUCT_SIZE   EQU 16          ; Размер одной структуры Inode (16 байт)

; Канонические типы файлов POSIX VFS ядра
I_TYPE_FREE         EQU 00H         ; Слот Inode свободен
I_TYPE_REGULAR      EQU 01H         ; Обычный регулярный файл
I_TYPE_CHRDEV       EQU 02H         ; Символьное устройство (TTY, LP, NULL)
I_TYPE_BLKDEV       EQU 03H         ; Блочное устройство (RAM-диск, FDD)
#include "chrdev.inc"
O_CHR_WRITE         EQU 0           ; [2 B] Адрес метода write драйвера
O_CHR_READ          EQU 2           ; [2 B] Адрес метода read драйвера
CHRDEV_OPS_SIZE     EQU 4           ; Размер структуры одногоMajor-слота
#include "syscall.inc"
; =============================================================================
; НАЗВАНИЕ: syscalls.inc (Расширенная таблица системных вызовов ядра POSIX)
; ТОКЕН:    
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Вектор RST 6
; =============================================================================

; --- БЛОК 1: УПРАВЛЕНИЕ ПРОЦЕССАМИ (PROCESS MANAGEMENT) ---
DEF_SYS_EXIT            EQU 1           ; Уничтожение текущей задачи с кодом возврата
DEF_SYS_FORK            EQU 2           ; Клонирование текущего процесса (дублирование PCB и eMMU)
DEF_SYS_EXECVE          EQU 3           ; Загрузка и запуск нового исполняемого бинарника в Ring 3
DEF_SYS_WAITPID         EQU 4           ; Ожидание завершения или изменения статуса дочерней задачи
DEF_SYS_GETPID          EQU 5           ; Получить собственный PID текущего процесса
DEF_SYS_GETPPID         EQU 6           ; Получить PID родительского процесса

; --- БЛОК 2: ВИРТУАЛЬНАЯ ФАЙЛОВАЯ СИСТЕМА И ВВОД-ВЫВОД (VFS / IO) ---
DEF_SYS_OPEN            EQU 7           ; Открыть/создать файл или символьное устройство TTY
DEF_SYS_CLOSE           EQU 8           ; Закрыть дескриптор, освободить слот O_FILE_TABLE
DEF_SYS_READ            EQU 9           ; Синхронное чтение из дескриптора в буфер Ring 3
DEF_SYS_WRITE           EQU 10          ; Синхронная запись из буфера Ring 3 в дескриптор/TTY
DEF_SYS_IOCTL           EQU 11          ; Управление параметрами устройств (POSIX termios для TTY)

; --- БЛОК 3: УПРАВЛЕНИЕ СИГНАЛАМИ И ВРЕМЕНЕМ (SIGNALS / TIME) ---
DEF_SYS_KILL            EQU 12          ; Отправка сигнала процессу по его PID (например, SIGKILL)
DEF_SYS_ALARM           EQU 13          ; Взвод POSIX-будильника (запись тиков в O_ALARM_TICKS)
DEF_SYS_SIGACTION       EQU 14          ; Регистрация пользовательского обработчика сигнала

; --- ИНВАРИАНТ ГАБАРИТОВ ТАБЛИЦЫ ---
DEF_SYS_MAX_SYSCALLS    EQU 14          ; Максимальный легитимный номер сисколла для контроля границ
#include "tty.inc"
; =============================================================================
; /include/tty.inc - КОНСТАНТЫ, ОПРЕДЕЛЕНИЯ И HAL-РАСШИРЕНИЕ (ВЕРСИЯ 1.5.52_HAL)
; =============================================================================

; --- ПАРАМЕТРЫ И ОГРАНИЧЕНИЯ ---
MAX_TTY_DEVS       EQU 4            ; 4 идентичных физических TTY консолей (0..3)
UNBOUND_WAIT_PID   EQU 0FFH         ; Маркер отсутствия привязки (0xFF)
TTY_BUF_SIZE       EQU 64           ; Размер кольцевого буфера (64 байта)
TTY_MINOR_BASE     EQU 0            ; Базовый minor для TTY

; --- БИТОВЫЕ МАСКИ ПОДФЛАГОВ POSIX TERMIOS ---
TM_ECHO            EQU 001H         ; ECHO
TM_ICANON          EQU 002H         ; ICANON
TM_ISIG            EQU 004H         ; ISIG
TM_ICRNL           EQU 001H         ; ICRNL
TM_INLCR           EQU 002H         ; INLCR
TM_OPOST           EQU 001H         ; OPOST
TM_ONLCR           EQU 002H         ; ONLCR

; --- ИНДЕКСЫ УПРАВЛЯЮЩИХ СИМВОЛОВ В МАССИВЕ TTY_C_CC (0..7) ---
VEOF               EQU 0            ; Ctrl+D
VEOL               EQU 1            ; \n
VERASE             EQU 2            ; Backspace
VKILL              EQU 3            ; Ctrl+U
VINTR              EQU 4            ; Ctrl+C
VQUIT              EQU 5            ; Ctrl+\
VSTART             EQU 6            ; Ctrl+Q
VSTOP              EQU 7            ; Ctrl+S

; --- ДЕФOЛТНЫЕ ЗНАЧЕНИЯ АТРИБУТОВ ТЕРМИНАЛА ---
DEF_VEOF           EQU 004H         ; Ctrl+D
DEF_VEOL           EQU 00AH         ; \n
DEF_VERASE         EQU 008H         ; Backspace
DEF_VKILL          EQU 015H         ; Ctrl+U
DEF_VINTR          EQU 003H         ; Ctrl+C
DEF_VQUIT          EQU 01CH         ; Ctrl+\
DEF_VSTART         EQU 011H         ; Ctrl+Q
DEF_VSTOP          EQU 013H         ; Ctrl+S

DEF_C_IFLAG        EQU TM_ICRNL     ; CR → NL на входе
DEF_C_OFLAG        EQU TM_OPOST OR TM_ONLCR  ; NL → CR-NL на выходе
DEF_C_LFLAG        EQU TM_ECHO OR TM_ICANON OR TM_ISIG  ; Полный canonical режим

; --- POSIX IOCTL КОМАНДЫ ТЕРМИНАЛА ---
TCGETA             EQU 1            
TCSETA             EQU 2            
TCFLSH             EQU 3            
TIOCGPGRP          EQU 4            
TIOCSPGRP          EQU 5            

TCIFLUSH           EQU 0            
TCOFLUSH           EQU 1            
TCIOFLUSH          EQU 2            

TTY_SIGINT         EQU 2            
TTY_SIGQUIT        EQU 3            
TTY_SIGTSTP        EQU 18           

; =============================================================================
; СМЕЩЕНИЯ ВНУТРИ СТРУКТУРЫ ОДНОГО TTY СЛОТА (СТРОГО 160 БАЙТ)
; =============================================================================
TTY_ROW_START      EQU 0
O_TTY_RX_HEAD      EQU TTY_ROW_START     
O_TTY_RX_TAIL      EQU O_TTY_RX_HEAD + 1 
O_TTY_RX_COUNT     EQU O_TTY_RX_TAIL + 1 
O_TTY_RX_BUFFER    EQU O_TTY_RX_COUNT + 1
O_TTY_TX_HEAD      EQU O_TTY_RX_BUFFER + TTY_BUF_SIZE 
O_TTY_TX_TAIL      EQU O_TTY_TX_HEAD + 1 
O_TTY_TX_COUNT     EQU O_TTY_TX_TAIL + 1 
O_TTY_TX_BUFFER    EQU O_TTY_TX_COUNT + 1
O_TTY_C_IFLAG      EQU O_TTY_TX_BUFFER + TTY_BUF_SIZE 
O_TTY_C_OFLAG      EQU O_TTY_C_IFLAG + 1 
O_TTY_C_LFLAG      EQU O_TTY_C_OFLAG + 1 
O_TTY_C_CC         EQU O_TTY_C_LFLAG + 1 
O_TTY_WAIT_PID     EQU O_TTY_C_CC + 8    
O_TTY_WAIT_CODE    EQU O_TTY_WAIT_PID + 1
O_TTY_PGRP         EQU O_TTY_WAIT_CODE + 1
O_TTY_CANON_RAW    EQU O_TTY_PGRP + 1    ; +148 [1 B] Технологический паддинг/зазор

; --- ИНКРЕМЕНТ СЛОЯ АППАРАТНОЙ АБСТРАКЦИИ (HAL) ВНУТРИ СУПЕРВИЗОРСКОГО РЕЗЕРВА ---
O_TTY_HW_PUT_CHAR  EQU O_TTY_PGRP + 2    ; +149 [2 B] Физический адрес процедуры hw_put_char
O_TTY_HW_GET_CHAR  EQU O_TTY_HW_PUT_CHAR + 2 ; +151 [2 B] Физический адрес процедуры hw_get_char
O_TTY_HW_POLL_STAT EQU O_TTY_HW_GET_CHAR + 2 ; +153 [2 B] Физический адрес процедуры hw_poll_status

; --- ТЕХНОЛОГИЧЕСКИЕ ПАРАМЕТРЫ ФИЗИЧЕСКИХ ЧИПОВ UART ---
O_TTY_HW_BASE_PORT EQU O_TTY_HW_POLL_STAT + 2 ; +155 [1 B] Базовый порт ввода-вывода контроллера
O_TTY_HW_DIV_LOW   EQU O_TTY_HW_BASE_PORT + 1 ; +156 [1 B] Младший байт делителя частоты
O_TTY_HW_DIV_HIGH  EQU O_TTY_HW_DIV_LOW + 1   ; +157 [1 B] Старший байт делителя частоты
O_TTY_HW_CHIP_TYPE EQU O_TTY_HW_DIV_HIGH + 1  ; +158 [1 B] Маркер типа чипа (01H=ВВ51, 02H=16550)

; Оставшийся свободный хвост до выравнивания: +159 [1 B] (Глубокий резерв ядра)

; --- МАСКИ И АППАРАТНЫЙ СТАТУС HAL ---
; Регистр А после исполнения O_TTY_HW_POLL_STAT обязан возвращать данные биты:
TTY_HAL_TXRDY      EQU 01H          ; Бит 0: Передатчик UART аппаратно готов принять байт
TTY_HAL_RXRDY      EQU 02H          ; Бит 1: Приемник UART аппаратно содержит байт для чтения

; Идентификаторы поддерживаемых контроллеров
CHIP_TYPE_I8251    EQU 01H          ; Микросхема КР580ВВ51А + КР580ВИ53
CHIP_TYPE_NS16550  EQU 02H          ; Микросхема NS16550 / 16550A

TTY_STRUCT_SIZE    EQU 160          ; КАНOНИЧНЫЙ ИНВАРИАНТ СОХРАНЕН БЕЗ СДВИГОВ!

; =============================================================================
;; Пример: TTY0 использует КР580ВВ51А
;LXI  H, TTY_TABLE
;LXI  D, O_TTY_HW_PUT_CHAR
;DAD  D
;LXI  B, hw_i8251_put_char
;MOV  M, C
;INX  H
;MOV  M, B
;
;; Пример: TTY1 использует NS16550
;LXI  H, TTY_TABLE + 160
;LXI  D, O_TTY_HW_PUT_CHAR
;DAD  D
;LXI  B, hw_16550_put_char
;MOV  M, C
;INX  H
;MOV  M, B
; =============================================================================
#include "hw_i8251.inc"
; =============================================================================
; MEGA-580_OS v1.5.54_HAL - i8251+i8253 DRIVER CONSTANTS
; BUILD DATE: 20260707 | AUTHOR: OS ARCHITECT & DEVICE DRIVER MANAGER
; =============================================================================

; --- Аппаратные биты состояния КР580ВВ51А (Вход из UART_CMD_PORT) ---
I8251_STAT_TXRDY    EQU 01H         ; Буфер передатчика пуст
I8251_STAT_RXRDY    EQU 02H         ; Байт принят и готов к чтению
I8251_STAT_TXEMPTY  EQU 04H         ; Передатчик полностью освободился

; --- Константы инициализации чипов ---
PIT_CW_CH0_M3       EQU 036H        ; Канал 0, LSB/MSB, Режим 3 (Меандр)
PIT_CW_CH1_M3       EQU 076H        ; Канал 1, LSB/MSB, Режим 3 (Меандр)

I8251_CMD_RESET     EQU 040H        ; Внутренний программный сброс
I8251_MODE_8N1_X16  EQU 04EH        ; 1 стоп, без паритета, 8 бит, фактор x16
I8251_CMD_START     EQU 027H        ; Tx/Rx разрешены, RTS/DTR активны
#include "hw_ns16550.inc"
; =============================================================================
; MEGA-580_OS v1.5.55_HAL - NS16550 CONTROLLER REGISTERS & MASKS
; BUILD DATE: 20260707 | AUTHOR: OS ARCHITECT & DEVICE DRIVER MANAGER
; =============================================================================

; --- Смещения регистров относительно O_TTY_HW_BASE_PORT ---
REG_RBR             EQU 0           ; Receiver Buffer Register (чтение, DLAB=0)
REG_THR             EQU 0           ; Transmitter Holding Register (запись, DLAB=0)
REG_IER             EQU 1           ; Interrupt Enable Register (DLAB=0)
REG_FCR             EQU 2           ; FIFO Control Register (запись)
REG_LCR             EQU 3           ; Line Control Register
REG_MCR             EQU 4           ; Modem Control Register
REG_LSR             EQU 5           ; Line Status Register
REG_DLL             EQU 0           ; Divisor Latch LSB (DLAB=1)
REG_DLM             EQU 1           ; Divisor Latch MSB (DLAB=1)
REG_SCR             EQU 7           ; Scratchpad Register чипа 16550

; --- Биты Line Status Register (REG_LSR) ---
LSR_DATA_READY      EQU 01H         ; Бит 0: Байт принят в FIFO (DR)
LSR_THRE            EQU 20H         ; Бит 5: Буфер передатчика пуст (THRE)
LSR_TEMT            EQU 40H         ; Бит 6: Передатчик полностью пуст (TEMT)

; --- Биты управления Line Control Register (REG_LCR) ---
LCR_WLS_8BIT        EQU 03H         ; Размер слова: 8 бит
LCR_STB_1STOP       EQU 00H         ; Стоп-биты: 1 стоп-бит
LCR_PEN_NO_PARITY   EQU 00H         ; Без четности
LCR_DLAB_ENABLE     EQU 80H         ; Включение защелки делителя частоты (DLAB=1)

; --- Биты управления FIFO Control Register (REG_FCR) ---
FCR_FIFO_ENABLE     EQU 01H         ; Включение FIFO
FCR_RX_FIFO_RESET   EQU 02H         ; Сброс FIFO приемника
FCR_TX_FIFO_RESET   EQU 04H         ; Сброс FIFO передатчика
FCR_RX_TRIGGER_14B  EQU 0C0H        ; Прерывание приемника при заполнении 14 байт

; --- Биты Interrupt Enable Register (REG_IER) ---
IER_DISABLE_ALL     EQU 00H         ; Запретить все прерывания
IER_ENABLE_RX       EQU 01H         ; Разрешить прерывание по приему данных
IER_ENABLE_TX       EQU 02H         ; Разрешить прерывание по освобождению THR

; =============================================================================
; ДОПОЛНЕНИЯ К ns16550_hal.inc
; =============================================================================

; --- Регистр идентификации прерываний (для ISR) ---
REG_IIR             EQU 2           ; Interrupt Identification Register (чтение)
IIR_NO_INT_PENDING  EQU 01H         ; Бит 0 = 1 → нет ожидающего прерывания
IIR_INT_ID_MASK     EQU 0EH         ; Маска источника (биты 1-3)
IIR_RX_DATA_AVAIL   EQU 04H         ; Приём данных (приоритет 2)
IIR_THR_EMPTY       EQU 02H         ; THR пуст (приоритет 3)
IIR_RX_TIMEOUT      EQU 0CH         ; Таймаут FIFO (приоритет 2)

; --- Маски ошибок LSR ---
LSR_OVERRUN_ERR     EQU 02H         ; Переполнение FIFO
LSR_PARITY_ERR      EQU 04H         ; Ошибка чётности
LSR_FRAMING_ERR     EQU 08H         ; Ошибка фрейма
LSR_BREAK_INT       EQU 10H         ; Обнаружен BREAK
LSR_ALL_ERRORS      EQU 0EH         ; Маска всех ошибок

; --- Расширенные IER ---
IER_ENABLE_LSR      EQU 04H         ; Прерывания по ошибкам линии

; --- Делители частоты (для кварца 1.8432 МГц) ---
NS16550_DIV_9600    EQU 000CH
NS16550_DIV_19200   EQU 0006H
NS16550_DIV_38400   EQU 0003H
NS16550_DIV_57600   EQU 0002H
NS16550_DIV_115200  EQU 0001H


#include "chrdev.inc"
O_CHR_WRITE         EQU 0           ; [2 B] Адрес метода write драйвера
O_CHR_READ          EQU 2           ; [2 B] Адрес метода read драйвера
CHRDEV_OPS_SIZE     EQU 4           ; Размер структуры одногоMajor-слота
#include "devices.inc"
; =============================================================================
; НАЗВАНИЕ: devices.inc (Каноническая спецификация Major/Minor номеров устройств)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | eMMU РЕВ_2.0
; =============================================================================

; =============================================================================
; БЛОК 1: СИМВОЛЬНЫЕ УСТРОЙСТВА (CHARACTER DEVICES - MAJOR NODES)
; =============================================================================
MAJOR_NULL          EQU 1           ; /dev/null   — Системный поглотитель данных
MAJOR_ZERO          EQU 2           ; /dev/zero   — Системный генератор нулей
MAJOR_MEM           EQU 3           ; /dev/mem    — Прямой физический доступ к ОЗУ ядра
MAJOR_TTY           EQU 4           ; /dev/tty*   — Последовательные консоли (ВВ51/16550)
MAJOR_PTY           EQU 5           ; /dev/pty*   — Псевдо-терминалы для сетевых сессий
MAJOR_LP            EQU 6           ; /dev/lp*    — Параллельный порт принтера (82C11/КР580ВВ55А)

; --- МЛАДШИЕ НOМЕРА СИМВОЛЬНЫХ УСТРOЙСТВ (MINOR MAP) ---
MINOR_NULL          EQU 0           ; Единственный Minor для /dev/null
MINOR_ZERO          EQU 0           ; Единственный Minor для /dev/zero

; Распределение карусели терминалов TTY
MINOR_TTY0          EQU 0           ; /dev/tty0 -> Первый аппаратно найденный UART [1.3]
MINOR_TTY1          EQU 1           ; /dev/tty1 -> Второй аппаратно найденный UART [1.3]
MINOR_TTY2          EQU 2           ; /dev/tty2 -> Третий аппаратно найденный UART [1.3]
MINOR_TTY3          EQU 3           ; /dev/tty3 -> Четвертый аппаратно найденный UART [1.3]

; Распределение параллельных портов печати
MINOR_LP0           EQU 0           ; /dev/lp0  -> Основной принтер на портах 0x80..0x83

; =============================================================================
; БЛОК 2: БЛОЧНЫЕ УСТРОЙСТВА (BLOCK DEVICES - MAJOR NODES)
; =============================================================================
MAJOR_RAMDISK       EQU 1           ; /dev/ram*   — Локальные виртуальные диски в памяти
MAJOR_FDD           EQU 2           ; /dev/fd*    — Накопители на гибких дисках (КР580ВГ93)

; --- МЛАДШИЕ НOМЕРА БЛOЧНЫХ УСТРOЙСТВ (MINOR MAP) ---
MINOR_RAM0          EQU 0           ; /dev/ram0 -> Системный корневой RAM-диск "/" (Сегмент 1 ОЗУ)
MINOR_RAM1          EQU 1           ; /dev/ram1 -> Пользовательский RAM-диск "/tmp"

MINOR_FDA           EQU 0           ; /dev/fda  -> Дисковод А: (Физический накопитель 0)
MINOR_FDB           EQU 1           ; /dev/fdb  -> Дисковод B: (Физический накопитель 1)
#include "lp.inc"
; =============================================================================
; НАЗВАНИЕ: lp.inc (Итоговые константы подсистемы параллельной печати)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | eMMU РЕВ_2.0
; =============================================================================

; --- Управляющие слова для Intel 82C11 ---
C11_CTRL_IRQ_EN       EQU 001H  ; Бит 0: Разрешить IRQ от ACK
C11_CTRL_BIDIR        EQU 002H  ; Бит 1: Двунаправленный режим
C11_CTRL_RESET        EQU 000H  ; Сброс чипа

; --- Системные лимиты и глобальные константы VFS ---
LP_MAX_DEVICES      EQU 2           ; Жесткий лимит: только два порта (LPT0, LPT1)
LP_STRUCT_SIZE      EQU 80          ; Канонический размер структуры одного слота

; --- Аппаратные константы чипов контроллеров ---
LP_TYPE_8255        EQU 001H        ; Контроллер на базе БИС КР580ВВ55А
LP_TYPE_82C11       EQU 002H        ; Контроллер на базе специализированной БИС 82C11

; --- Биты регистра статуса LPT (Считывание из порта STATUS_PORT) ---
LP_BUSY             EQU 080H        ; Бит 7: Занятость (0 = принтер готов, инвертирован!)
LP_ACK              EQU 040H        ; Бит 6: Подтверждение приема байта (Импульс ACK)
LP_PAPER_OUT        EQU 020H        ; Бит 5: Флаг окончания бумаги в лотке
LP_SELECT           EQU 010H        ; Бит 4: Принтер выбран и находится ONLINE
LP_ERROR            EQU 008H        ; Бит 3: Аппаратная ошибка / сбой принтера

; --- Биты регистра управления LPT (Запись в порт CTRL_PORT) ---
LP_CTRL_STROBE      EQU 001H        ; Бит 0: Строб фиксации данных (Активный фронт)
LP_CTRL_AUTOFD      EQU 002H        ; Бит 1: Автоматическая подача строки (LF)
LP_CTRL_INIT        EQU 004H        ; Бит 2: Сброс и инициализация принтера
LP_CTRL_SELECT_IN   EQU 008H        ; Бит 3: Выбор устройства со стороны контроллера
LP_CTRL_IRQ_EN      EQU 010H        ; Бит 4: Разрешение асинхронных прерываний
LP_CTRL_BIDIR       EQU 020H        ; Бит 5: Двунаправленный режим шины данных

; --- Карта смещений внутри 80-байтовой ОЗУ-структуры одного LP-слота ---
O_LP_STATUS         EQU 0           ; [1 B] Текущее рантайм-состояние порта
O_LP_PORT_DATA      EQU 1           ; [1 B] Вычисленный физический порт DATA (BASE+0)
O_LP_PORT_STATUS    EQU 2           ; [1 B] Вычисленный физический порт STATUS (BASE+1)
O_LP_PORT_CTRL      EQU 3           ; [1 B] Вычисленный физический порт CTRL (BASE+2)
O_LP_FLAGS          EQU 4           ; [1 B] Логические флаги драйвера (LP_OPEN...)
O_LP_TIMEOUT        EQU 5           ; [2 B] 16-битный таймаут ожидания BUSY=0
O_LP_ERROR_COUNT    EQU 7           ; [1 B] Накопительный счетчик ошибок печати
O_LP_BYTES_WRITTEN  EQU 8           ; [4 B] 32-битный сквозной счетчик выведенных байт
O_LP_BUFFER_PTR     EQU 12          ; [2 B] 16-битный адрес начала кольцевого FIFO-буфера
O_LP_BUFFER_SIZE    EQU 14          ; [2 B] Физический размер буфера отложенной записи
O_LP_BUFFER_HEAD    EQU 16          ; [1 B] Индекс HEAD кольцевого буфера
O_LP_BUFFER_TAIL    EQU 17          ; [1 B] Индекс TAIL кольцевого буфера
O_LP_BUFFER_COUNT   EQU 18          ; [1 B] Текущий счетчик байт, ожидающих выгрузку
O_LP_HW_TYPE        EQU 19          ; [1 B] Тип активного кремния: LP_TYPE_8255 / 82C11
O_LP_HW_IRQ_LINE    EQU 20          ; [1 B] Вычисленная линия прерываний ВН59 (1..7)
O_LP_RESERVED       EQU 21          ; [59 B] Защитный резерв до границы 80 байт [1.3]

; --- Логические флаги состояния драйвера ---
LP_OPEN             EQU 001H        ; Устройство успешно открыто ядром
LP_RAW              EQU 002H        ; Режим RAW-печати (Без обработки спецсимволов)
LP_ERROR_STATE      EQU 004H        ; Порт находится в состоянии фатальной блокировки

; --- Коды ошибок LPT драйвера ---
LP_ERR_TIMEOUT      EQU 001H        ; Превышено время ожидания готовности кремния
LP_ERR_PAPER_OUT    EQU 002H        ; Датчик сигнализирует об отсутствии бумаги
LP_ERR_HARDWARE     EQU 003H        ; Аппаратный сбой БИС / обрыв кабеля Centronics
LP_ERR_BUSY         EQU 004H        ; Порт монопольно занят сторонним процессом

; =============================================================================
; Константы подсистемы распределения физической памяти ядра
; =============================================================================
RAM_BITMAP_SIZE    EQU 32           ; 32 байта для карты 256 страниц (256 / 8)

#code CODE, EMMU_PAGE_0, EMMU_PAGE_SIZE
; =============================================================================
; НАЧАЛО ТЕНЕВОГО ПЗУ (ХОЛОДНЫЙ СТАРТ С АДРЕСА 0x0000)
; =============================================================================
boot_start:
	DI                       ; Запрещаем прерывания на период холодной настройки БИС
	JMP cold_boot            ; Прыжок на процедуру первичной конфигурации

; =============================================================================
; ТАБЛИЦА ПРОГРАММНЫХ ВЕКТОРОВ (ЛОВУШЕК) PROCESSOR 8080 (0x0008 - 0x003F)
; =============================================================================
    ORG 0008H
	JMP rst_stub			; RST 1 — Системная заглушка программного сброса
    ORG 0010H
	JMP rst_stub			; RST 2 — Системная заглушка программного сброса
    ORG 0018H
	JMP rst_stub			; RST 3 — Системная заглушка программного сброса
    ORG 0020H
	JMP rst_stub 			; RST 4 — Системная заглушка программного сброса
    ORG 0028H
	JMP rst_stub 			; RST 5 — Системная заглушка программного сброса
    ORG 0030H
    JMP rst_stub;sys_call_entry		; RST 6 — МОНОПОЛЬНАЯ ТОЧКА ВХОДА SYSCALL ENTRY (Trap)
    ORG 0038H
	JMP rst_stub 			; RST 7  — Системная заглушка программного сброса

; =============================================================================
; ТАБЛИЦА АППАРАТНЫХ ВЕКТОРОВ ПРЕРЫВАНИЙ ОТ КР580ВН59 (БАЗА 0x0040)
; =============================================================================
    ORG SYS_ISR_TABLE_BASE
	DUP	8
	DB	0CDH
	DW	0000H
	EDUP
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
; =============================================================================
; ТАБЛИЦА АППАРАТНЫХ ВЕКТОРОВ ПРЕРЫВАНИЙ ОТ ДОПОЛНИТЕЛЬНОГО КР580ВН59 (БАЗА 0x0058)
; =============================================================================
	DUP	8
	DB	0CDH
	DW	0000H
	EDUP
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
	DB	0CDH
	DW	0000H
; =============================================================================
; НАЧАЛО ТЕНЕВОГО ПЗУ: БЛОК ХОЛОДНОЙ ИНИЦИАЛИЗАЦИИ И ПЕРИФЕРИИ (8 КБ)
; =============================================================================
cold_boot:
    ; Процессор только что сбросился. Мы находимся в Ring 0. 
    ; Триггер DD3 держит ~{ROM_EN}=0. Процессор читает код из ПЗУ (0x0000-0x1FFF).
    
    LXI  SP, KERNEL_STACK_TOP       ; Выставляем временный стек ядра в верхнем ОЗУ

	; =============================================================================
    ; ЭТАП 1: Прямой перенос 8 КБ кода из нижнего ПЗУ в верхнее ОЗУ Ядра
	; =============================================================================
    LXI  H, 00000H              ; HL = Начало Теневого ПЗУ (Источник)
    LXI  D, EMMU_PAGE_2         ; DE = Временный буфер в верхнем ОЗУ (Назначение)
    LXI  B, 8192                ; Счетчик длины переноса: ровно 8 КБ (2000H)

copy_to_upper_ram_loop:
    MOV  A, M                   ; Считываем байт системного кода из ПЗУ
    STAX D                      ; Записываем напрямую в верхнее ОЗУ Ядра (адреса 0x8000...)
    INX  H                      ; Инкремент указателя источника ПЗУ
    INX  D                      ; Инкремент указателя назначения ОЗУ
    DCX  B                      ; Декремент 16-битного счетчика длины BC
    MOV  A, B
    ORA  C                      ; Проверяем, обнулился ли счетчик BC?
    JNZ  copy_to_upper_ram_loop ; Если нет — продолжаем качать ядро вверх

	; Копирование завершено. Переносим выполнение процессора в верхнее ОЗУ.
    ; ИСПРАВЛЕНО: Модификация адреса метки под верхнее окно ОЗУ (+0x8000)
    LXI  H, upper_ram_stage2;+EMMU_PAGE_2 
    PCHL                        ; Программный прыжок PC процессора в микросхемы верхнего ОЗУ!

	; =============================================================================
	; ЭТАП 2: ВЫПОЛНЕНИЕ ИЗ ВЕРХНЕГО ОЗУ ЯДРА И ОТКЛЮЧЕНИЕ ТЕНЕВОГО ПЗУ
	; =============================================================================
upper_ram_stage2:
    ; Процессор аппаратно выполняет эту кодовую строчку уже из микросхем ОЗУ Ядра!
    
    ; АППАРАТНОЕ ОТКЛЮЧЕНИЕ ТЕНЕВОГО ПЗУ НА ПЛАТЕ eMMU
    ; Системный импульс OUT 0x75 сбрасывает внешний триггер DD3. 
    ; ПЗУ навсегда исчезает с шины. В нижнем окне 0x0000-0x1FFF открывается 
    ; физически изолированная «чистая» память нижнего ОЗУ Ядра (Ring 0).
    OUT  EMMU_ROM_DISABLE		; ТЕНЕВОЕ ПЗУ НАВСЕГДА ДЕАКТИВИРОВАНО

    ; =============================================================================
	; ЭТАП 3: Зеркальный перенос всех 8 КБ кода из верхнего ОЗУ вниз
	; =============================================================================
    ; Теперь, когда нижнее ОЗУ Ядра открыто, мы сажаем ядро на его каноническое место.
    LXI  H, EMMU_PAGE_2         ; HL = Наш верхний временный буфер ОЗУ (Источник)
    LXI  D, EMMU_PAGE_0         ; DE = Целевой физический адрес 0 ОЗУ Ядра (Назначение)
    LXI  B, 8192                ; Переносим 8 КБ системного кода вниз

copy_down_to_zero_loop:
    MOV  A, M                   ; Читаем байт ядра из верхней памяти ОЗУ
    STAX D                      ; Пишем в нижнее ОЗУ Ядра на канонический адрес 0
    INX  H                      ; Инкремент указателя источника
    INX  D                      ; Инкремент указателя назначения
    DCX  B                      ; Декремент 16-битного счетчика
    MOV  A, B
    ORA  C                      ; Проверяем окончание переноса
    ; Теперь процессор будет крутиться строго внутри верхних физических адресов ОЗУ,
    ; пока полностью не восстановит нижнюю память ядра!
    JNZ  copy_down_to_zero_loop

    ; =============================================================================
	; ЭТАП 4: Окончательный запуск операционной системы
	; =============================================================================
    ; Передаем управление на канонический адрес старта ядра в нижнем ОЗУ
    LXI  H, kernel_clean_start  ; HL = Логический адрес старта в нижнем ОЗУ
    PCHL                        ; Процессор переходит на исполнение с адреса 0 ОЗУ Ядра!

	; =============================================================================
	; ЭТАП 5: ЧИСТЫЙ СТАРТ ИЗ НИЖНЕГО ОЗУ ЯДРА — НАСТРОЙКА БИС ПЕРИФЕРИИ
	; =============================================================================
kernel_clean_start:
    ; =============================================================================
	; --- ЭТАП 5.1: Инициализация Системных Таблиц и Таблиц ОЗУ
	; =============================================================================
    CALL	k_pcb_subsys_init		; Размечаем GLOBAL_RESOURCE_TABLE и слоты PCB
    ; =============================================================================
	; --- ЭТАП 5.2: Инициализация структур ОЗУ массива TTY
	; =============================================================================
	CALL	k_tty_subsys_init		; Полностью очистить и инициализировать все 4 независимых TTY-слота
									; внутри TTY_TABLE каноническими стартовыми значениями.
    ; =============================================================================
	; --- ЭТАП 5.3: Инициализация структур ОЗУ массива LPT
	; =============================================================================
	CALL	k_lp_subsys_init		; Полностью очистить и инициализировать все 2 независимых LP-слота
									; внутри LP_TABLE каноническими стартовыми значениями.
    ; =============================================================================
	; --- ЭТАП 5.4: Инициализация структур ОЗУ массива VFS
	; =============================================================================
	CALL	k_vfs_subsys_init
	CALL	k_tty_register_vfs
	CALL	k_lp_register_vfs
    ; =============================================================================
	; --- ЭТАП 5.5: Инициализация системного таймера
	; =============================================================================	
	CALL	hw_sys_init				; Проверяем наличие в системе системного таймера
									; и проводим его инициализацию.
	JC   	kernel_panic_no_sys     ; Если таймер не обнаружен — критический останов (опционально)
	; =============================================================================
    ; --- ЭТАП 5.6: Инициализация TTY ---
	; =============================================================================
    CALL	k_tty_carousel_auto_build	; Перебрать все 4 физических порта, протестировать наличие железа
										; (ВВ51 приоритет, затем 16550) и заполнить TTY-слоты СТРОГО ПОСЛЕДОВАТЕЛЬНО.
	; =============================================================================
	; --- ЭТАП 5.7: Регистрация файлов /dev/tty* в RAM-диске
	; =============================================================================	
	CALL	vfs_mount_tty_nodes        ; Регистрация TTY0-TTY4 в VFS
	; =============================================================================
    ; --- ЭТАП 5.8: Инициализация LPT ---
	; =============================================================================
    CALL	k_lp_carousel_auto_build	; Перебрать все 2 физических порта, протестировать наличие железа
										; (ВВ55 приоритет, затем 82C11) и заполнить LP-слоты СТРОГО ПОСЛЕДОВАТЕЛЬНО.
	; =============================================================================
	; --- ЭТАП 5.8: Регистрация файлов /dev/lp* в RAM-диске
	; =============================================================================	
	CALL vfs_mount_lp_nodes        ; Регистрация LP0-LP1 в VFS
	; =============================================================================
	; --- ЭТАП 5.9: Инициализация контроллера прерываний
	; =============================================================================	
	CALL	hw_int_init				; Проверяем наличие в системе контроллера прерываний
									; и проводим его инициализацию.
	JC   	kernel_panic_no_pic     ; Если контроллер не обнаружен — критический останов (опционально)
	; =============================================================================
	; Инициализация сетевого контроллера KSZ8851-16MML
	; =============================================================================
	;CALL k_ksz8851_init             ; Перевод чипа 16MLL в 8-битный режим, пуск маски IRQ3
    ;CPI  0FFh                       ; Карта ответила?
    ;JZ   kernel_panic_no_net        ; Если сеть не обнаружена — критический останов (опционально)
	
	; =============================================================================
	; ЭТАП 6: Инициализация виртуальной VFS-таблицы монтирования
	; =============================================================================
    ; Вызываем последовательную цепочку внутренних подпрограмм ранней инициализации
    ;CALL sys_socketfs_init          ; Очистка NET_UNIX_HEADS и монтирование префикса "/dev/sock"
	


    ; =============================================================================
	; ЭТАП 8: АППАРАТНЫЙ МОНТИНГ ФАЙЛОВОЙ СИСТЕМЫ (ВСТРАИВАНИЕ MBR)
	; =============================================================================
    ; ВНИМАНИЕ! КРИТИЧЕСКАЯ ТОЧКА ВЫЗОВА:
    ;CALL vfs_init_mbr            ; Ядро считывает сектор 0 через ПДП и монтирует VFS на LBA 0x1000
    
    ; Проверяем результат монтирования. Если MBR поврежден (A != 0), уходим в панику ядра
    CPI  00H
    JNZ  kernel_panic_mbr_failed

    ; =============================================================================
	; ЭТАП 9: Запуск многозадачной карусели POSIX ОС
	; =============================================================================
    ; Здесь ядро создает первый пользовательский процесс PID=1 (наш разработанный Shell),
    ; прописывает его начальный контекст в PCB_TABLE и выставляет статус ST_READY.
    ; [Код спавна PID=1]

    MVI  A, 020h                    ; Сброс маски прерываний в КР580ВН59 (EOI)
    OUT  MASTER_8259_CMD
	
    EI                          	; ОФИЦИАЛЬНО РАЗРЕШАЕМ АППАРАТНЫЕ ПРЕРЫВАНИЯ!
    
idle_loop:
    HLT                         	; Спим в экономичном режиме PID=0 до первого тика таймера 20 мс
    JMP  idle_loop

	; =============================================================================
	; --- КРИТИЧЕСКИЙ ОСТАНОВ ПРИ ЗАГРУЗКЕ ---
	; =============================================================================
kernel_panic_no_pic:
	; Фатальная ошибка старта: Контроллер прерываний не найден.
    ; Выключаем прерывания и намертво вешаем процессор.
    DI
    HLT
	JMP  kernel_panic_no_pic

kernel_panic_no_sys:
	; Фатальная ошибка старта: Системный таймер не найден.
    ; Выключаем прерывания и намертво вешаем процессор.
    DI
    HLT
	JMP  kernel_panic_no_pic

kernel_panic_no_net:
	; Фатальная ошибка старта: Сетевая карта не найдена.
    ; Выключаем прерывания и намертво вешаем процессор.
    DI
    HLT
	JMP  kernel_panic_no_net
	
kernel_panic_mbr_failed:
    ; Фатальная ошибка старта: MBR не валиден или раздел VFS 0x1000 не найден.
    ; Выключаем прерывания и намертво вешаем процессор для предотвращения порчи диска.
    DI
    HLT
    JMP  kernel_panic_mbr_failed
; =============================================================================
; АППАРАТНЫЙ ОБРАБОТЧИК IR0: КВАНТОВАНИЕ 20 МС И ВЫТЕСНЕНИЕ КОНТЕКСТА
; =============================================================================
; =============================================================================
; ОБРАБОТЧИК: hw_timer_entry
; Вход:  Аппаратный тик IRQ0 (Квант 20 мс). Прерывания заперты (DI).
; Задача: Эвакуировать контекст, обновить UNIX-время и CPU usage каждую секунду,
;         обслужить будильники, выбрать новую задачу и прыгнуть в MMU-свичер.
; =============================================================================
hw_timer_entry:
    ; --- ЭТАП 1: ТЕНЕВОЕ СОХРАНЕНИЕ КОНТЕКСТА ВЫТЕСНЯЕМОЙ ЗАДАЧИ ---
    PUSH PSW
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили РОН Ring 3 процесса в его стек

    ; Переключаем процессор на изолированный системный стек ядра ОС
    LXI  H, 0000H
    DAD  SP                         ; HL = Текущий пользовательский SP
    LXI  SP, KERNEL_STACK_TOP       ; Загрузили стек супервизора Ring 0
    PUSH H                          ; Временно спрятали пользовательский SP в стек ядра

    ; --- ЭТАП 2: ФИКСАЦИЯ USER_SP В СТРУКТУРЕ PCB ТЕКУЩЕЙ ЗАДАЧИ ---
    LHLD CURRENT_PCB_PTR            ; HL = Адрес активного PCB из кэша ядра
    MOV  A, H
    ORA  L
    JZ   _timer_cold_start          ; Защита от холодного старта (Если указатель равен 0)

    PUSH H                          ; Спасли базу текущей PCB
    LXI  D, O_SAVED_SP
    DAD  D                          ; HL -> Поле O_SAVED_SP (+3)
    
    POP  D                          ; DE = Восстановили базу текущей PCB
    POP  B                          ; BC = Извлекли сохраненный пользовательский SP
    MOV  M, C                       ; Записали младший байт SP (База + 3)
    INX  H
    MOV  M, B                       ; Записали старший байт SP (База + 4)

    ; Изменяем рантайм-статус задачи: ST_RUNNING -> ST_READY
    MOV  H, D
    MOV  L, E                       ; HL = База PCB
    LXI  D, O_STATUS
    DAD  D                          ; HL -> O_STATUS (+1)
    MOV  A, M
    CPI  ST_RUNNING                 ; Задача была вытеснена принудительно таймером?
    JNZ  _timer_skip_status_reset   ; Нет (сама ушла в сон) — статус не трогаем
    MVI  M, ST_READY                ; Возвращаем задачу в queue готовности планировщика
    JMP  _timer_skip_status_reset

_timer_cold_start:
    POP  D                          ; Очистили стек от SP, если это холодный старт

_timer_skip_status_reset:

    ; === ЭТАП 2.5: ИНКРЕМЕНТ UNIX TIME И ОБНОВЛЕНИЕ CPU USAGE (NEW!) ===
    LXI  H, SYS_TICK_COUNTER
    INR  M                          ; Инкрементируем счетчик тиков текущей секунды
    MOV  A, M
    CPI  TICKS_PER_SECOND           ; Набралось 50 тиков (прошла 1 секунда)?
    JC   _timer_skip_unix_time      ; Меньше 50 — пропускаем секундный инкремент

    ; СЕКУНДА ПРОШЛА! Сбрасываем внутрисекундный счетчик тиков
    MVI  M, 00H                     ; SYS_TICK_COUNTER = 0

    ; Выполняем 32-битный инкремент Little-Endian времени SYS_UNIX_TIME в памяти
    LXI  H, SYS_UNIX_TIME           ; HL указывает на Байт 0 (младший)
    INR  M                          ; Байт 0++
    JNZ  _unix_time_inc_done        ; Если нет переполнения (результат != 0) — инкремент окончен
    
    INX  H                          ; Переполнение в Байт 1
    INR  M                          ; Байт 1++
    JNZ  _unix_time_inc_done
    
    INX  H                          ; Переполнение в Байт 2
    INR  M                          ; Байт 2++
    JNZ  _unix_time_inc_done
    
    INX  H                          ; Переполнение в Байт 3 (старший)
    INR  M                          ; Байт 3++

_unix_time_inc_done:
    ; Секунда накручена, UNIX-время обновлено. 
    ; Принудительно вызываем подпрограмму планировщика для расчета загрузки CPU
    CALL k_calc_cpu_usage           ; Выход: РОН согласно контракту будут сохранены

_timer_skip_unix_time:

    ; === ЭТАП 3: АБСОЛЮТНО ИЗОЛИРОВАННОЕ СКАНИРОВАНИЕ БУДИЛЬНИКОВ ===
    LXI  H, PCB_TABLE               ; HL = Начало глобального массива процессов ядра
    MVI  C, 0                       ; C = Счетчик цикла строго по PID (0..31)

_alarm_scan_loop:
    PUSH H                          ; Спасли БАЗУ PCB текущего слота на стеке

    LXI  D, O_STATUS
    DAD  D                          ; HL -> O_STATUS (+1)
    MOV  A, M
    CPI  ST_FREE                    ; Слот пуст?
    JZ   _alarm_next_slot           ; Да — шагаем мимо

    ; Слот занят — проверяем будильник. Восстанавливаем ЧИСТУЮ БАЗУ из стека
    POP  H
	PUSH H                 ; HL = Истинный старт текущей PCB
    LXI  D, O_ALARM_TICKS           ; DE = СТРОГО +50 (согласно pcb.inc v1.5.75) [1.3]
    DAD  D                          ; HL -> Младший байт O_ALARM_TICKS (+50)
    
    MOV  A, M
	INX H
	ORA M       ; Проверка на 0000H в ячейках +50 и +51
    JZ   _alarm_next_slot           ; Выключен — шагаем мимо

    ; Будильник взведен — выполняем 16-битный декремент
    DCX  H                          ; HL -> Младший байт будильника (+50)
    MOV  A, M
	SUI 1
	MOV M, A
    JNC  _alarm_check_zero
    INX  H
	MOV  A, M
	SBI 1
	MOV M, A
	DCX H

_alarm_check_zero:
    MOV  A, M
	INX H
	ORA M       ; Счетчик докрутился до 0000H?
    JNZ  _alarm_next_slot           ; Нет — время еще не вышло

    ; БУДИЛЬНИК СРАБОТАЛ! Доставляем SIGALRM в старший байт маски сигналов
    POP  H
	PUSH H                 ; Восстановили чистую базу текущей PCB
    LXI  D, O_SIG_PENDING + 1       ; DE = +25 + 1 = СТРОГО +26 [1.3]
    DAD  D                          ; HL -> Старший байт маски сигналов (+26)
    MOV  A, M
	ORI SIGALRM_MASK_H
	MOV M, A

_alarm_next_slot:
    POP  H                          ; HL = Восстановили чистую базу текущей PCB
    LXI  D, PCB_SIZE                ; DE = 64
    DAD  D                          ; Сдвиг к началу следующего слота таблицы (64 байта)
    
    INR  C
	MOV A, C
	CPI MAX_PROCS
	JNZ _alarm_scan_loop

    ; === ЭТАП 4: ВЫЗОВ ПЛАНИРОВЩИКА ===
    CALL scheduler                  ; Выбираем NEXT_PID [1.3]
    STA  NEXT_PID

    MOV  L, A
	MVI H, 00H
    DAD  H
	DAD  H
	DAD  H
	DAD  H
	DAD  H
	DAD  H ; Умножение на 64 [1.3]
    LXI  D, PCB_TABLE
	DAD  D      ; HL = Адрес PCB новой задачи

    ; === ЭТАП 5: БЕЗОПАСНАЯ ИЗОЛИРОВАННАЯ ПРОВЕРКА FATAL-СИГНАЛОВ ===
    PUSH H                          ; Спасли базу новой PCB
    LXI  D, O_SIG_PENDING           ; DE = +25
    DAD  D                          ; HL -> Младший байт маски сигналов (+25)
    MOV  A, M
	ANI SIG_FATAL_MASK_L
	JNZ _timer_sig_fatal_kill

    INX  H                          ; HL -> Старший байт маски сигналов (+26)
    MOV  A, M
	ANI SIG_FATAL_MASK_H
	JNZ _timer_sig_fatal_kill

    POP  H                          ; Восстановили базу новой PCB
    PUSH H
    LXI  D, O_STATUS
	DAD D
	MVI M, ST_RUNNING
    POP  H

    MVI  A, 020H
	OUT MASTER_8259_CMD ; EOI в КР580ВН59
    JMP  switch_mmu_context

_timer_sig_fatal_kill:
    POP  H                          ; HL = Восстановили адрес PCB новой задачи
    MVI  A, 09H
    JMP  sys_exit_fatal             ; Атомарная ликвидация рантайма задачи!


; =============================================================================
; ПОДПРОГРАММА ЯДРА (Ring 0): ДЕАЛЛОКАТОР ФИЗИЧЕСКИХ СТРАНИЦ ПАМЯТИ eMMU
; =============================================================================
; Вход:  A = Номер освобождаемой физической страницы ОЗУ eMMU (0..255).
; Выход: Соответствующий бит в системной RAM_BITMAP сброшен в 0.
;        Регистры BC, DE, HL полностью сохраняются, прерывания не трогаются.
; =============================================================================
; =============================================================================
; НАЗВАНИЕ: k_free_physical_page
; МОДУЛЬ:   Низкоуровневый постраничный деаллокатор ОЗУ eMMU РЕВ_2.0
; =============================================================================
k_free_physical_page:
    ; Вход:  A = Номер освобождаемой физической страницы ОЗУ eMMU (0..255).
    ; Выход: Соответствующий бит в системной RAM_BITMAP сброшен в 0.
    ;        Регистры BC, DE, HL полностью сохраняются.
    PUSH H
    PUSH D
    PUSH B

    MOV  C, A                       ; C = Исходный номер страницы (0..255)

    ; --- ШАГ 1: ТОЧНЫЙ ВЫЧИСЛИТЕЛЬ ИНДЕКСА БАЙТА И НОМЕРА БИТА ---
    ; Выделяем номер бита: Бит = Страница & 07h (Нижние 3 бита)
    ANI  07H
    MOV  B, A                       ; B = Номер бита (0..7) внутри целевого байта

    ; Выделяем индекс байта: Индекс = (Страница >> 3) & 01Fh
    MOV  A, C
    RRC
    RRC
    RRC                             ; Циклический сдвиг вправо на 3 бита
    ANI  01FH                       ; ЖЕСТКИЙ МАТЕМАТИЧЕСКИЙ ФИКС: Очищаем натекание 
                                    ; старших битов из-за циклического вращения RRC!
    MOV  E, A                       ; E = Индекс байта в RAM_BITMAP (0..31)
    MVI  D, 0                       ; DE = 16-битное смещение

    ; Вычисляем физический адрес целевого байта в битовой карте ядра
    LXI  H, RAM_BITMAP
    DAD  D                          ; HL указывает точно на нужный байт карты

    ; --- ШАГ 2: БЫСТРАЯ ГЕНЕРАЦИЯ МАСКИ СБРОСА БИТА ---
    MOV  A, B                       ; A = Номер бита (0..7)
    MOV  C, A                       ; C = Счетчик сдвигов для цикла
    MVI  A, 001H                    ; Стартовая базовая маска (взведен 0-й бит)

    MOV  B, A                       ; Временно прячем стартовую маску в B
    MOV  A, C
    ORA  A                          ; Проверяем счетчик сдвигов на равенство нулю
    MOV  A, B                       ; Восстановили базовую маску в аккумулятор
    JZ   _page_free_mask_ready      ; Если номер бита = 0, маска 01h уже готова

_page_free_shift_loop:
    ADD  A                          ; Эквивалент сдвига влево (A = A + A)
    DCR  C                          ; Уменьшаем счетчик сдвигов
    JNZ  _page_free_shift_loop      ; Цикл крутится ровно столько раз, каков номер бита

_page_free_mask_ready:
    ; Аккумулятор содержит прямую маску бита (например, 04h для 2-го бита).
    CMA                             ; Инвертируем маску (04h превращается в 0FBh)

    ; --- ШАГ 3: АТОМАРНЫЙ СБРОС БИТА В ПАМЯТИ ЯДРА ---
    ANA  M                          ; Сбрасываем целевой бит в 0, удерживая соседей
    MOV  M, A                       ; Записали обновленный байт обратно в RAM_BITMAP

    ; --- ШАГ 4: ВОССТАНОВЛЕНИЕ КОНТЕКСТА И ВЫХОД ---
    POP  B
    POP  D
    POP  H
    RET

; =============================================================================
; ПОДПРОГРАММА ЯДРА (Ring 0): УНИВЕРСАЛЬНЫЙ РЕГИСТРАТОР АППАРАТНЫХ ISR
; =============================================================================
; Вход:  A  = Номер аппаратной линии IRQ контроллера КР580ВН59 (0..7).
;        HL = 16-битный физический адрес нового обработчика (вектор).
; Задача: Вычислить адрес операнда CALL (0x0040 + IRQ*3 + 1), пропатчить ОЗУ,
;         и атомарно снять маску прерывания в КР580ВН59, оживив линию.
; Выход: Все РОН (PSW, BC, DE, HL) полностью сохранены согласно контракту HAL.
; =============================================================================
k_register_isr:
    PUSH PSW                        ; Сохранили A+F
    PUSH B                          ; Сохранили BC
    PUSH D                          ; Сохранили DE
    PUSH H                          ; Сохранили HL (= адрес ISR) ← НА ВЕРШИНЕ СТЕКА

    MOV  C, A                       ; C = Исходный номер IRQ (0..7)

    ; === ЭТАП 1: ИЗВЛЕЧЕНИЕ АДРЕСА ISR ЧЕРЕЗ XTHL ===
    XTHL                            ; HL = адрес ISR, стек содержит старый HL
    
    ; Сохраняем адрес ISR в безопасную регистровую пару DE
    MOV  E, L
    MOV  D, H                       ; DE = адрес ISR (теперь защищён)
    
    ; Восстанавливаем оригинальный HL со стека
    XTHL                            ; HL = старый HL, стек содержит адрес ISR
    
    ; === ЭТАП 2: МАТЕМАТИЧЕСКИЙ РАСЧЁТ СМЕЩЕНИЯ (IRQ * 3) ===
    MOV  A, C                       ; A = IRQ
    ADD  A                          ; A = IRQ * 2
    ADD  C                          ; A = IRQ * 3
    MOV  L, A
    MVI  H, 00H                     ; HL = IRQ * 3
    
    LXI  B, SYS_ISR_TABLE_BASE      ; BC = 0x0040 (ICW2 база КР580ВН59)
    DAD  B                          ; HL = 0x0040 + IRQ*3
    INX  H                          ; HL -> младший байт адреса в CALL (пропуск opcode 0xCD)
    
    ; === ЭТАП 3: SMC-ПАТЧИНГ ТАБЛИЦЫ ПРЕРЫВАНИЙ В ОЗУ ===
    ; DE содержит извлеченный адрес ISR
    MOV  M, E                       ; Прошили младший байт адреса обработчика
    INX  H
    MOV  M, D                       ; Прошили старший байт адреса обработчика
    
    ; === ЭТАП 4: АТОМАРНОЕ СНЯТИЕ МАСКИ В КР580ВН59 ===
    ; Вычисляем маску бита: Бит = 1 << IRQ
    MVI  A, 001H                    ; Стартовый бит 0 (00000001b)
    MOV  B, A                       ; B = шаблон маски
    MOV  A, C                       ; A = номер IRQ (0..7)
    ORA  A                          ; Проверка на IRQ 0
    JZ   _k_reg_mask_calculated     ; Если IRQ0 — сдвиг не требуется

_k_reg_shift_loop:
    MOV  A, B
    RLC                             ; Циклический сдвиг маски влево
    MOV  B, A
    DCR  C
    JNZ  _k_reg_shift_loop

_k_reg_mask_calculated:
    ; B содержит маску с взведённым битом регистрируемой линии
    ; Инвертируем маску для сброса бита
    MOV  A, B
    CMA                             ; A = NOT B
    MOV  B, A                       ; B = инверсная маска сброса бита
    
    ; Читаем-модифицируем-записываем регистр масок (IMR) КР580ВН59
    IN   MASTER_8259_DATA           ; A = текущие замаскированные линии
    
    ; ИСПРАВЛЕНО: Регистровая логическая команда процессора 8080 вместо ANI B
    ANA  B                          ; Сбросили бит нашей линии (A = A AND B)
    
    OUT  MASTER_8259_DATA           ; Физически прошили контроллер. Линия ожила!

    ; === ЭТАП 5: ПОЛНОЕ ВОССТАНОВЛЕНИЕ КОНТЕКСТА HAL ===
    POP  H                          ; Извлекаем адрес ISR, оставшийся на вершине стека
    POP  D
    POP  B
    POP  PSW                        ; Восстановили абсолютно все РОН и флаги F
    RET

; =============================================================================
; СИСТЕМНЫЙ ПЕРЕХВАТЧИК СБОЕВ Ring 3: ЗАГЛУШКА НЕОБРАБОТАННЫХ ЛОВУШЕК (RST 1-7)
; =============================================================================
rst_stub:
    ; Вход: Сюда процессор КР580ВМ80А попадает аппаратно при вызове нелегального RST.
    ;       В стеке задачи Ring 3 лежит адрес PC, где произошел сбой.
    ;       Мы уже находимся в защищённом режиме Ring 0!
    
    ; Вызываем легитимный системный трап SYS_EXIT, чтобы ядро уничтожило эту задачу!
    
    DI                          	; Запрещаем прерывания таймера на время паники
    
    ; Загружаем в регистр C код легитимного системного вызова SYS_EXIT (1)
    MVI  C, DEF_SYS_EXIT               	; SYS_EXIT EQU 1
    
    ; Загружаем в аккумулятор A код возврата фатального сбоя POSIX
    ; Стандартный exit-код при падении по ошибке сегментации/RST = 139 (08BH)
    MVI  A, SIG_SEGV+128            	; 139 = 128 + SIG_SEGV (Аварийное завершение)
    
    ; Нам нужно передать этот код возврата ядру через регистр C, но в C уже лежит 
    ; номер сисколла (1). Поэтому, согласно нашему соглашению о системных вызовах,
    ; пользовательский параметр exit-кода передается в регистре B (или аккумуляторе).
    MOV  B, A                   	; Переносим код паники 139 в регистр B для sys_exit
    
    ; Официально вызываем программную ловушку Ядра, которая переключит нас в Ring 0
    RST  6                      	; Прыгаем на sys_call_entry
    
    ; Сюда процессор физически никогда не вернется, так как ядро внутри sys_exit
    ; полностью освободит память текущей задачи и переключит eMMU на другой PID.

    ; Финальная аппаратная петля безопасности на случай тотального краха ОС
    HLT
    JMP  rst_stub

; =============================================================================
; АППАРАТНЫЙ ОБРАБОТЧИК ПРЕРЫВАНИЯ: hw_privilege_violation_entry (IRQ7)
; =============================================================================
; Вход:  Сработал триггер нарушения привилегий eMMU. Прерывания заперты (DI).
;        Пользователь попытался сделать IN/OUT/EI/DI напрямую из Ring 3!
; Выход: Нарушитель мгновенно уничтожен, ресурсы освобождены, ЦП переключен.
; =============================================================================
hw_privilege_violation_entry:
    ; --- ШАГ 1: Консервация контекста прерванного потока ---
    PUSH PSW                        ; Сохраняем аккумулятор А и флаги PSW
	
    ; Проверим, как именно мы сюда попали: если ISR пуст — это ложный тик
    MVI  A, 00BH
    OUT  MASTER_8259_CMD
    IN   MASTER_8259_CMD        	; Читаем актуальное состояние регистра ISR
    CPI  00H
    JZ   hw_stub_exit           	; Если ISR полностью пуст — это ложный тик, EOI не шлем

    PUSH B                          ; Сохраняем регистровую пару BC
    PUSH D                          ; Сохраняем регистровую пару DE
    PUSH H                          ; Сохраняем регистровую пару HL

    ; --- ШАГ 2: Защита супервизора ядра от падения ---
    LDA  CURRENT_PID
    ORA  A                          ; Нарушение произошло внутри Ring 0 (Ядро)?
    JZ   privilege_panic_route      ; Если само ядро нарушило шину — Kernel Panic!

    ; --- ШАГ 3: ЖЕСТКОЕ ПЕРЕВЕДЕНИЕ НАРУШИТЕЛЯ В СТАТУС ZOMBIE ---
    LHLD CURRENT_PCB_PTR            ; HL = Адрес активного PCB из кэша ядра
    PUSH H                          ; Сохранили базу PCB в стек супервизора
    
    LXI  D, O_STATUS                ; Смещение поля статуса (+2)
    DAD  D
    MVI  M, 005h                    ; Отрезали процесс от планировщика: статус = ST_ZOMBIE (05h)
    
    ; Записываем код завершения (SIG_SEGV = 0x0B) в поле O_SYSCALL_RES (+5)
    POP  H
	PUSH H                 			; Восстановили базу PCB
    LXI  D, O_SYSCALL_RES           ; Смещение кода возврата (+5)
    DAD  D
    MVI  M, 00Bh                    ; Прописали флаг падения по аппаратному нарушению (0x0B)

    ; --- ШАГ 4: АТОМАРНОЕ ВЫСВОБОЖДЕНИЕ ФИЗИЧЕСКИХ СТРАНИЦ eMMU ---
    POP  H
	PUSH H                 			; HL = Базовый адрес PCB
    LXI  D, O_PAGES_MAP             ; Смещение карты физических фреймов (+8)
    DAD  D
    MVI  C, 4                       ; Нарушитель владел 4 сегментами памяти (0..3)

privilege_free_pages_loop:
    MOV  A, M                       ; A = Номер физической страницы в eMMU
    CPI  RES_FREE_MARKER            ; Страница уже свободна (0xFF)?
    JZ   privilege_page_next
    
    PUSH B
	PUSH H
    CALL k_free_physical_page       ; Возвращаем фрейм в глобальную карту RAM_BITMAP
    POP  H
	POP  B
    MVI  M, RES_FREE_MARKER         ; Обнулили маркер страницы в PCB (0xFF)

privilege_page_next:
    INX  H                          ; Переходим к следующему сегменту процесса
    DCR  C
    JNZ  privilege_free_pages_loop

    ; --- ШАГ 5: ПОЛНОЕ АВТОМАТИЧЕСКОЕ ЗАКРЫТИЕ ВСЕХ ФАЙЛОВ И СОКЕТОВ ---
    POP  H                          ; HL = Базовый адрес PCB нарушителя
    LXI  D, O_FILE_TABLE            ; Смещение локальной таблицы файлов (+20)
    DAD  D                          ; HL -> Начало O_FILE_TABLE процесса
    MVI  C, 8                       ; Итерируем по всем 8 слотам дескрипторов (FD 0..7)

privilege_close_fd_loop:
    MOV  A, M                       ; A = Глобальный системный индекс VFS (0..63)
    CPI  RES_FREE_MARKER            ; Дескриптор свободен (0xFF)?
    JZ   privilege_fd_next          ; Если пуст — шагаем мимо
    
    ; Слот занят — вызываем наш центральный VFS деаллокатор
    PUSH B
	PUSH H                 			; Сохранили итераторы и адрес таблицы файлов
;-!!!-
;    -!!!- CALL k_vfs_close_global_index   ; Освобождаем аппаратные сокеты чипа и пайпы ОЗУ!
;-!!!-
    POP  H
	POP  B                 			; Восстановили контекст
    
    MVI  M, RES_FREE_MARKER         ; Дескриптор в PCB официально очищен (0xFF)

privilege_fd_next:
    INX  H                          ; Сдвигаемся к следующему дескриптору
    DCR  C
    JNZ  privilege_close_fd_loop    ; Повторяем для всех 8 слотов задачи

    ; --- ШАГ 6: БЕСШОВНЫЙ СУПЕРВИЗОРНЫЙ ШЕДУЛЛИНГ ЖИВОЙ ЗАДАЧИ ---
    CALL scheduler                  ; Планировщик атомарно ищет живой READY поток в системе
    STA  NEXT_PID
    CALL switch_mmu_context         ; ЭВМ MEGA-580 переключает К555ИР26 на новые фреймы
    
    ; Передаем аппаратный EOI (End of Interrupt) в контроллер КР580ВН59
    MVI  A, 020H
    OUT  MASTER_8259_CMD            ; Сбросили триггер текущего уровня IRQ7 в ВН59

    ; Реставрируем контекст РОН (Уже из стека ядра совершенно нового, готового процесса!)
    POP  H
    POP  D
    POP  B
    POP  PSW                        
    
    EI                              ; АТОМАРНО СНИМАЕМ БЛОКИРОВКУ СИСТЕМНОЙ ШИНЫ ПРЕРЫВАНИЙ!
    RET                             ; Аппаратный прыжок в код живой задачи пользователя!

privilege_panic_route:
    ; --- КРИТИЧЕСКИЙ СБОЙ ЯДРА: НАРУШЕНИЕ НА ШИНЕ RING 0 ---
    DI                              ; Запереть прерывания намертво
    HLT                             ; Полный останов кристалла ЦП КР580ВМ80А

#include "./kernel/vfs.asm"
; =============================================================================
; /kernel/vfs.asm - ИСПОЛНЯЕМЫЙ КОД ПОДСИС ТЕМЫ ВИРТУАЛЬНОЙ ФАЙЛОВОЙ СИСТЕМЫ
; =============================================================================
; MEGA-580 OS - МОДУЛЬ VFS: ИСПОЛНЯЕМЫЙ КОД ЦЕНТРАЛЬНЫХ ДИСПЕТЧЕРОВ
; =============================================================================
; -----------------------------------------------------------------------------
; ПОДПРОГРАММА ИНИЦИАЛИЗАЦИИ ТАБЛИЦЫ ПЕРЕКЛЮЧАТЕЛЕЙ VFS
; -----------------------------------------------------------------------------
k_vfs_subsys_init:
    ; --- ЭТАП 1: ПОЛНОЕ ЗАНУЛЕНИЕ ГЛОБАЛЬНОЙ ТАБЛИЦЫ ФАЙЛОВ (1280 БАЙТ) ---
    LXI  H, SYS_FILE_TABLE
    LXI  D, MAX_SYS_FILES * SYS_FILE_SLOT_SIZE
    XRA  A

_vfs_clear_ft_loop:
    MOV  M, A
    INX  H
    DCX  D
    MOV  A, D
    ORA  E
    JZ   _vfs_clear_ft_done
    XRA  A
    JMP  _vfs_clear_ft_loop
_vfs_clear_ft_done:

    ; --- ЭТАП 2: ЗАНУЛЕНИЕ ТАБЛИЦЫ КОММУТАТОРА ДРАЙВЕРОВ (320 БАЙТ) ---
    LXI  H, VFS_SWITCH_TABLE
    LXI  D, VFS_MAX_TYPES * VFS_ROW_SIZE
    XRA  A

_vfs_clear_sw_loop:
    MOV  M, A
    INX  H
    DCX  D
    MOV  A, D
    ORA  E
    JZ   _vfs_clear_sw_done
    XRA  A
    JMP  _vfs_clear_sw_loop
_vfs_clear_sw_done:

    ; --- ЭТАП 3: ОЧИСТКА СЛУЖЕБНЫХ ЯЧЕЕК, ISR И K_TMP_* (30 БАЙТ) ---
    ; 9 байт скаляров + 16 байт ISR + 5 байт K_TMP_* = 30 байт
    LXI  H, VFS_DISPATCH_MAJOR  
    MVI  B, 9 + 16 + 5          ; ИСПРАВЛЕНО: 30 вместо 28
    XRA  A                      

_vfs_clear_sys_vars_loop:
    MOV  M, A                   
    INX  H
    DCR  B                      
    JNZ  _vfs_clear_sys_vars_loop 

    ; --- ЭТАП 4: ЗАНУЛЕНИЕ ТАБЛИЦЫ МОНТИРОВАНИЯ УЗЛОВ (96 БАЙТ) ---
    LXI  H, DEV_MOUNT_TABLE
    MVI  B, MAX_MOUNT_DEVS * MNT_ENTRY_SZ 
    XRA  A                      

_vfs_clear_mnt_loop:
    MOV  M, A                   
    INX  H
    DCR  B                      
    JNZ  _vfs_clear_mnt_loop    
    
    RET                         ; Возврат в глобальную точку инициализации

; -----------------------------------------------------------------------------
; СИСТЕМНЫЙ ШЛЮЗ МОДУЛЬНОЙ РЕГИСТРАЦИИ ДРАЙВЕРОВ (Ring 0 CALL)
; -----------------------------------------------------------------------------
; Вход:  A  = Утвержденный Major Number драйвера (1..31).
;        HL = Адрес структуры 5 методов драйвера (10 байт в памяти модуля).
; -----------------------------------------------------------------------------
k_vfs_register_driver:
    ; Вход:  A  = Major-номер регистрируемого драйвера (1..31)
    ;        HL = Физический 16-битный адрес структуры 5 векторов функций драйвера
    ;        Прерывания заперты (DI), стек в Ring 0.
    PUSH PSW
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили полный контекст супервизора

    ; === ШАГ 1: АППАРАТНАЯ ВАЛИДАЦИЯ ГРАНИЦ MAJOR (1..31) ===
    CPI  1                          
    JC   _vfs_reg_err_inval         ; Если A == 0 — ошибка EINVAL
    
    CPI  VFS_MAX_TYPES              
    JNC  _vfs_reg_err_inval         ; Если A >= 32 — ошибка EINVAL

    ; === ШАГ 2: БЕЗОПАСНЫЙ РАСЧЕТ АДРЕСА СТРОКИ КОММУТАТОРА ===
    MOV  B, H
    MOV  C, L                       ; BC = Истинный адрес структуры методов драйвера

    ; Вычисляем смещение: HL = Major * 10
    MOV  L, A
    MVI  H, 0                       ; HL = Major
    DAD  H                          ; HL = Major * 2
    PUSH H                          ; Спрятали Major * 2 на вершину стека ядра
    DAD  H                          ; HL = Major * 4
    DAD  H                          ; HL = Major * 8
    POP  D                          ; DE = Major * 2
    DAD  D                          ; HL = (Major * 8) + (Major * 2) = Major * 10

    LXI  D, VFS_SWITCH_TABLE
    DAD  D                          ; HL = Физический адрес целевой строки в коммутаторе
    
    XCHG                            ; DE = Адрес строки коммутатора (Куда писать)
    MOV  H, B
    MOV  L, C                       ; HL = Адрес структуры методов драйвера (Откуда читать)

    ; === ШАГ 3: БЫСТРОЕ ТАБЛИЧНОЕ КОПИРОВАНИЕ 10 БАЙТ ВЕКТOРОВ ===
    MVI  B, VFS_ROW_SIZE            ; Счетчик копирования = 10 байт

_vfs_register_copy_loop:
    MOV  A, M                       
    STAX D                          
    INX  H                          
    INX  D                          
    DCR  B                          
    JNZ  _vfs_register_copy_loop    

    POP  H
    POP  D
    POP  B
    POP  PSW                        ; Восстановили все РОН в исходное состояние
    RET                             ; УСПЕХ: Флаги и РОН не затерты ошибками

_vfs_reg_err_inval:
    POP  H
    POP  D
    POP  B
    POP  PSW                        ; Сняли базовый сохраненный контекст
    MVI  A, EINVAL                  ; ЖЕСТКИЙ ПОСИКС-ФИКС: Возвращаем канонический код 22 (0x16)
    RET

; === Системная заглушка нереализованных методов VFS ===
k_vfs_enotsupp:
    MVI  A, ENODEV                  ; ЖЕСТКИЙ ПОСИКС-ФИКС: Возвращаем канонический код 19 (0x13)
    RET

; =============================================================================
; НАЗВАНИЕ: vfs.asm (Выделение свободного глобального дескриптора)
; =============================================================================
k_vfs_malloc_file:
    ; Вход:  A = Major-номер драйвера для установки в F_TYPE (1..31)
    ;        Прерывания гарантированно заперты (DI), стек в Ring 0.
    ; Задача: Найти первый свободный слот в глобальной SYS_FILE_TABLE (F_TYPE == 0).
    ;         Инициализировать счетчик ссылок F_REF = 1, сбросить остальные поля.
    ; Выход: В случае успеха:
    ;           Флаг переноса CY = 0 (Успех)
    ;           Пара HL = Точный 16-битный физический адрес выделенного слота в ядре.
    ;        В случае ошибки (Таблица файлов переполнена, лимит POSIX ENFILE):
    ;           Флаг переноса CY = 1 (Провал)
    ;           Пара HL = 0000H
    PUSH B
    PUSH D                          ; Сохраняем РОН супервизора
    
    PUSH PSW                        ; КРИТИЧЕСКИЙ ФИКС: Спрятали исходный Major-номер (регистр A) 
                                    ; на вершину стека ядра от затирания в цикле!

    LXI  H, SYS_FILE_TABLE          ; HL = Стартовый адрес глобальной таблицы файлов
    MVI  B, MAX_SYS_FILES           ; B = Счетчик цикла (128 глобальных файлов)

_vfs_malloc_scan_loop:
    MOV  A, M                       ; A = Значение поля F_TYPE (+0) текущего слота
    CPI  VFS_TYPE_FREE              ; Проверяем, свободен ли слот (00h)?
    JZ   _vfs_malloc_slot_found     ; Слот найден! Переходим к инициализации

    ; Слот занят. Сдвигаем HL на следующую строку таблицы (SYS_FILE_SLOT_SIZE = 10)
    LXI  D, SYS_FILE_SLOT_SIZE
    DAD  D                          ; HL переместился на начало следующего слота
    
    DCR  B                          ; Уменьшаем счетчик проходов
    JNZ  _vfs_malloc_scan_loop      ; Повторяем для всех 128 дескрипторов

    ; --- ОШИБКА: ТАБЛИЦА ФАЙЛОВ ПЕРЕПОЛНЕНА (ENFILE) ---
    POP  PSW                        ; Сняли со стека неиспользованный Major-номер (баланс стека)
    LXI  H, 0000H                   ; Обнуляем HL в знак ошибки
    STC                             ; Устанавливаем флаг провала CY = 1
    JMP  _vfs_malloc_exit           ; Уходим на выход

_vfs_malloc_slot_found:
    ; --- ИНИЦИАЛИЗАЦИЯ НАЙДЕННОГО СЛОТА ---
    ; В HL сейчас лежит точный базовый адрес найденной 10-байтовой строки.
    
    ; Защита: полностью зануляем внутренности слота перед возвратом
    PUSH H                          ; Сохранили базовый адрес для возврата
    MVI  C, SYS_FILE_SLOT_SIZE      ; Счетчик зануления = 10 байт
_vfs_malloc_clear_slot:
    MVI  M, 00H                     ; Пишем 00h по всей длине слота
    INX  H
    DCR  C
    JNZ  _vfs_malloc_clear_slot
    
    POP  H                          ; HL = Восстановили базовый адрес строки (+0)
    
    POP  PSW                        ; ИСПРАВЛЕНИЕ БАГА: Извлекли из стека наш оригинальный 
                                    ; Major-номер обратно в Аккумулятор A!

    ; Устанавливаем F_TYPE = A (Истинный Major-номер)
    MOV  M, A                       ; Теперь сюда пишется корректный номер драйвера (1..31)
    
    ; Устанавливаем канонический счетчик ссылок: F_REF (+2) = 1
    INX  H
    INX  H                          ; HL указывает строго на поле F_REF (+2)
    MVI  M, 001H                    ; Выставляем 1 активную ссылку дескриптора (v1.4.7)
    
    ; Возвращаем HL на базовый адрес строки (+0) для корректного ABI ядра
    DCX  H
    DCX  H                          ; HL -> Снова базовая точка выделенного слота
    
    ANA  A                          ; СБРОС ФЛАГА ПЕРЕНОСА: Аппаратно выставляем CY = 0 (Успех)

_vfs_malloc_exit:
    POP  D
    POP  B                          ; Восстановили РОН супервизора
    RET                             ; Сквозной возврат в вызывающий сисколл (sys_open)

; =============================================================================
; РАСЧЕТ АДРЕСА СТРУКТУРЫ ОТКРЫТОГО ФАЙЛА
; =============================================================================
; Вход:  D = Локальный дескриптор пользователя FD (0..15).
; Выход: HL = Абсолютный физический адрес 16-байтовой структуры файла в ядре.
; =============================================================================
k_vfs_get_file_struct_address:
    ; Вход:  D  = Локальный файловый дескриптор процесса Ring 3 (FD 0..15)
    ;        Прерывания заперты (DI), стек в Ring 0.
    ; Выход: В случае успеха:
    ;           Флаг переноса CY = 0
    ;           Пара HL = Точный 16-битный адрес 10-байтового слота в SYS_FILE_TABLE
    ;        В случае ошибки (EBADF - дескриптор закрыт или нелегален):
    ;           Флаг переноса CY = 1
    ;           Пара HL = 0000H
    ; ВНИМАНИЕ: Все РОН пользователя (включая входящий D) полностью сохраняются!
    PUSH B
    PUSH D                          ; КРИТИЧЕСКИЙ ФИКС: Спрятали DE пользователя в стек ядра

    LHLD CURRENT_PCB_PTR            ; HL = Физический базовый адрес активного PCB
    
    ; Вычисляем адрес ячейки локального дескриптора внутри структуры PCB
    MOV  A, D                       ; A = Входящий FD из регистра D
    ANI  00FH                       ; Жесткая маска защиты границ (FD строго 0..15)
    ADI  O_FILE_TABLE               ; A = Внутреннее смещение до нужного FD в PCB
    
    ; Переносим смещение в пару BC, чтобы не трогать сохраненный в стеке DE
    MOV  C, A
    MVI  B, 0                       ; BC = 16-битное смещение внутри PCB
    DAD  B                          ; HL -> Указывает точно на ячейку локального FD в PCB

    MOV  A, M                       ; A = Номер глобального системного дескриптора (0..127)
    CPI  RES_FREE_MARKER            ; Проверяем, не равен ли он 0xFF (Свободный слот)?
    JZ   _vfs_get_struct_err        ; Если 0xFF — дескриптор не открыт, уходим на ошибку

    ; === ШАГ 2: ВЫЧИСЛЕНИЕ АДРЕСА СТРОКИ В SYS_FILE_TABLE ===
    MOV  L, A
    MVI  H, 0                       ; HL = Чистый глобальный индекс файла (0..127)
    
    ; Математическое быстрое умножение индекса на каноничные 10 байт:
    ; Формула: HL * 10 = (HL * 8) + (HL * 2)
    DAD  H                          ; HL = Индекс * 2
    PUSH H                          ; Временно сохранили Индекс * 2 в стек ядра
    DAD  H                          ; HL = Индекс * 4
    DAD  H                          ; HL = Индекс * 8
    POP  B                          ; BC = Индекс * 2 (Извлекли без затирания DE!)
    DAD  B                          ; HL = (Индекс * 8) + (Индекс * 2) = Индекс * 10
    
    ; Прибавляем физическую базу глобальной таблицы файлов ядра
    LXI  B, SYS_FILE_TABLE
    DAD  B                          ; HL -> Указывает на точный адрес 10-байтового слота
    
    ANA  A                          ; АППАРАТНЫЙ СБРОС: Сбрасываем CY = 0 (Успех)
    JMP  _vfs_get_struct_exit

_vfs_get_struct_err:
    LXI  H, 0000H                   ; Возвращаем пустой указатель
    STC                             ; АППАРАТНЫЙ ФЛАГ ОШИБКИ: CY = 1 (POSIX EBADF)

_vfs_get_struct_exit:
    POP  D                          ; ПОЛНЫЙ ФИКС: Восстановили оригинальный DE пользователя!
    POP  B
    RET

; =============================================================================
; НАЗВАНИЕ: vfs.asm (Центральный атомарный коммутатор методов драйверов)
; =============================================================================
k_vfs_dispatch:
    ; Вход:  HL = Физический 16-битный адрес 10-байтового слота в SYS_FILE_TABLE
    ;        C  = Смещение запрашиваемого метода операции внутри строки драйвера
    ;        DE, BC_user = Входящие аргументы сисколла от пользователя (буфер, длина)
    ;        Прерывания заперты (DI), стек в Ring 0.
    
    ; === ШАГ 1: ТОТАЛЬНОЕ СПАСЕНИЕ ПОЛЬЗОВАТЕЛЬСКИХ АРГУМЕНТОВ ===
    PUSH B                          ; Спрятали BC пользователя (включая длину/аргумент)
    PUSH D                          ; Спрятали DE пользователя (включая адрес буфера/cmd)
    
    ; Теперь регистры B, C, D, E полностью в нашем распоряжении!
    MOV  B, C                       ; B = Смещение метода драйвера (0, 2, 4, 6, 8)
    
    SHLD VFS_DRV_ROW_PTR            ; Кэшируем адрес структуры файла в ОЗУ ядра
    
    ; Извлекаем Major и Minor из структуры
    MOV  A, M                       ; A = Major-номер устройства (F_TYPE)
    STA  VFS_DISPATCH_MAJOR         ; Зафиксировали в кэш
    
    INX  H                          ; HL -> Поле F_MINOR (+1)
    MOV  A, M                       ; A = Minor-номер (F_MINOR)
    STA  VFS_DISPATCH_MINOR         ; Зафиксировали в кэш

    ; === ШАГ 2: ВЫЧИСЛЕНИЕ АДРЕСА СТРОКИ ДРАЙВЕРА В VFS_SWITCH_TABLE ===
    LDA  VFS_DISPATCH_MAJOR         ; A = Major-номер (0..31)
    
    ; Умножаем Major на канонический размер строки коммутатора (VFS_ROW_SIZE = 10)
    MOV  L, A
    MVI  H, 0                       ; HL = Major
    DAD  H                          ; HL = Major * 2
    PUSH H                          ; Спрятали Major * 2 на вершину стека ядра
    DAD  H                          ; HL = Major * 4
    DAD  H                          ; HL = Major * 8
    POP  D                          ; DE = Major * 2
    DAD  D                          ; HL = Major * 10
    
    LXI  D, VFS_SWITCH_TABLE
    DAD  D                          ; HL = Базовый адрес целевой строки драйвера
    
    ; Прибавляем смещение метода (из сохранённого регистра B)
    MOV  E, B
    MVI  D, 0                       ; DE = Смещение метода (0, 2, 4, 6, 8)
    DAD  D                          ; HL -> Точная ячейка DW с адресом функции

    ; === ШАГ 3: ИЗВЛЕЧЕНИЕ АДРЕСА ФУНКЦИИ И ВАЛИДАЦИЯ ===
    MOV  E, M
    INX  H
    MOV  D, M                       ; DE = Физический адрес обработчика в драйвере
    
    ; Проверяем, зарегистрирован ли метод драйвера (Адрес == 0000H)?
    MOV  A, D
    ORA  E                          ; Логическое ИЛИ над байтами адреса
    JNZ  _vfs_dispatch_execute      ; Если адрес != 0000H — метод готов
    
    ; Метод отсутствует -> Подменяем адрес перехода на ENODEV заглушку
    LXI  D, k_vfs_enotsupp          ; DE = Адрес канонического стаба k_vfs_enotsupp

_vfs_dispatch_execute:
    ; Прячем целевой адрес функции (DE) в память ядра, чтобы освободить регистры 
    ; под извлечение оригинальных пользовательских параметров из стека
    XCHG                            ; HL = Адрес функции драйвера, DE = Мусор
    SHLD K_TMP_PC                   ; Временно спрятали адрес функции в ячейку ядра

    ; === ШАГ 4: ВОССТАНОВЛЕНИЕ КОНТЕКСТА И ФИНАЛЬНЫЙ ВЫХОД ===
    POP  D                          ; ИДЕАЛЬНЫЙ ФИКС: Восстановили чистый буфер/cmd пользователя!
    POP  B                          ; ИДЕАЛЬНЫЙ ФИКС: Восстановили чистую длину/arg пользователя!
    
    LHLD VFS_DRV_ROW_PTR            ; HL = Адрес структуры открытого файла для драйвера (Параметр ABI)
    
    ; Собираем аппаратный прыжок через стек
    PUSH H                          ; Временно сохранили HL, чтобы не затереть его при LHLD
    LHLD K_TMP_PC                   ; HL = Физический адрес функции драйвера
    XTHL                            ; ТРЮК 8080: Поменяли местами HL и вершину стека!
                                    ; Теперь: В HL лежит оригинальная структура файла,
                                    ; а на вершине стека ядра находится адрес функции драйвера!
                                    
    RET                             ; Процессор снимает адрес функции со стека в PC 
                                    ; и прыгает в драйвер с абсолютно чистыми РОН!

; =============================================================================
; НАЗВАНИЕ: vfs.asm (Связывание глобального файла с локальным дескриптором FD)
; =============================================================================
k_vfs_bind_fd:
    ; Вход:  A  = Номер глобального системного дескриптора из SYS_FILE_TABLE (0..127)
    ;        Прерывания заперты (DI), стек в Ring 0.
    ; Задача: Линейно просканировать байты O_FILE_TABLE (+34..+49) внутри PCB 
    ;         текущей активной задачи (CURRENT_PCB_PTR). Найти первый свободный 
    ;         слот (0xFF) и привязать к нему глобальный индекс файла.
    ; Выход: В случае успеха:
    ;           Флаг переноса CY = 0 (Успех)
    ;           Регистр A = Локальный номер файлового дескриптора процесса (FD 0..15)
    ;        В случае ошибки (Локальная таблица процесса переполнена, лимит EMFILE):
    ;           Флаг переноса CY = 1 (Провал)
    ;           Регистр A = EMFILE (Канонический POSIX-код ошибки 24)
    ; ВНИМАНИЕ: Все РОН супервизора (за исключением целевого A) сохраняются.
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст планировщика

    MOV  C, A                       ; C = Наш глобальный индекс файла (0..127)

    LHLD CURRENT_PCB_PTR            ; HL = Физический базовый адрес активного PCB задачи
    LXI  D, O_FILE_TABLE
    DAD  D                          ; HL указывает точно на старт O_FILE_TABLE (+34)

    MVI  B, 16                      ; Счетчик цикла = 16 локальных файловых дескрипторов
    MVI  E, 0                       ; E = Текущий проверяемый локальный FD (0..15)

_vfs_bind_scan_loop:
    MOV  A, M                       ; Читаем значение байта дескриптора из PCB процесса
    CPI  RES_FREE_MARKER            ; Проверяем, свободен ли локальный FD (Равен ли 0xFF)?
    JZ   _vfs_bind_slot_found       ; Свободный слот найден! Переходим к связыванию

    INX  H                          ; Сдвигаем HL на следующий дескриптор в PCB (+1 байт)
    INR  E                          ; Переходим к следующему индексу FD (E++)
    
    DCR  B                          ; Уменьшаем счетчик проходов
    JNZ  _vfs_bind_scan_loop        ; Повторяем для всей таблицы из 16 дескрипторов

    ; --- ОШИБКА: ЛОКАЛЬНАЯ ТАБЛИЦА ФАЙЛОВ ПРОЦЕССА ПЕРЕПОЛНЕНА (EMFILE) ---
    MVI  A, EMFILE                  ; A = Код ошибки POSIX EMFILE (Too many open files = 24)
    STC                             ; АППАРАТНЫЙ ФЛАГ ПРОВАЛА: CY = 1 (Провал)
    JMP  _vfs_bind_exit             ; Уходим на выход

_vfs_bind_slot_found:
    ; --- СВЯЗЫВАНИЕ И ФИКСАЦИЯ ДЕСКРИПТОРА ---
    MOV  M, C                       ; Прошиваем глобальный индекс файла (из C) в ОЗУ текущего PCB!
    
    MOV  A, E                       ; Аккумулятор A = Вычисленный локальный номер дескриптора (0..15)
    ANA  A                          ; АППАРАТНЫЙ СБРОС: Сбрасываем флаг переноса CY = 0 (УСПЕХ)

_vfs_bind_exit:
    POP  H
    POP  D
    POP  B                          ; Восстановили РОН супервизора
    RET                             ; Сквозной возврат в вызывающий сисколл (sys_open)

; =============================================================================
; НАЗВАНИЕ: vfs.asm (Диспетчер закрытия дескрипторов и освобождения ресурсов)
; =============================================================================
k_vfs_close_fd:
    ; Вход:  D = Локальный файловый дескриптор процесса Ring 3 (FD 0..15)
    ;        Прерывания гарантированно заперты (DI), стек в Ring 0.
    ; Задача: Найти глобальный индекс файла в PCB, очистить локальный FD.
    ;         Уменьшить F_REF в SYS_FILE_TABLE. Если F_REF == 0, вызвать метод 
    ;         V_OP_CLOSE соответствующего мажорного драйвера устройства.
    ; Выход: В случае успеха:
    ;           Флаг переноса CY = 0 (Успех), регистр A = 00H
    ;        В случае ошибки (EBADF - дескриптор не существует или уже свободен):
    ;           Флаг переноса CY = 1 (Провал), регистр A = EBADF (9)
    ; ВНИМАНИЕ: Все РОН супервизора полностью сохраняются (кроме A).
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст планировщика

    ; --- ШАГ 1: ИЗВЛЕЧЕНИЕ И ОЧИСТКА ЛОКАЛЬНОГО FD В PCB ---
    LHLD CURRENT_PCB_PTR            ; HL = Физическая база PCB активной задачи
    MOV  A, D                       ; A = Локальный FD из регистра D
    ANI  00FH                       ; Защитная маска границ (FD строго 0..15)
    ADI  O_FILE_TABLE               ; A = Смещение до нужного слота внутри PCB
    
    MOV  C, A
    MVI  B, 0                       ; BC = 16-битное смещение
    DAD  B                          ; HL -> Указывает точно на ячейку FD в PCB
    
    MOV  A, M                       ; A = Глобальный системный индекс файла (0..127)
    CPI  RES_FREE_MARKER            ; Проверяем, не свободен ли он уже (0xFF)?
    JZ   _vfs_close_err_ebadf       ; Если 0xFF — возвращаем ошибку EBADF (9)
    
    MOV  C, A                       ; C = Сохранили глобальный индекс файла (0..127)
    MVI  M, RES_FREE_MARKER         ; АТОМАРНАЯ ОЧИСТКА: Локальный FD в PCB сброшен в 0xFF!

    ; --- ШАГ 2: ВЫЧИСЛЕНИЕ АДРЕСА СТРОКИ В SYS_FILE_TABLE ---
    MOV  L, C
    MVI  H, 0                       ; HL = Чистый глобальный индекс файла (0..127)
    
    ; Математическое быстрое умножение индекса на каноничные 10 байт:
    DAD  H                          ; * 2
    PUSH H                          
    DAD  H                          ; * 4
    DAD  H                          ; * 8
    POP  B                          ; BC = Индекс * 2
    DAD  B                          ; HL = Индекс * 10
    
    LXI  B, SYS_FILE_TABLE
    DAD  B                          ; HL = Точный физический адрес 10-байтового слота файла
    SHLD VFS_CLOSE_STRUCT_PTR       ; Сохранили адрес структуры во временный кэш ядра

    ; --- ШАГ 3: ДЕКРЕМЕНТ POSIX СЧЕТЧИКА ССЫЛОК F_REF ---
    LXI  D, F_REF
    DAD  D                          ; HL -> Указывает на поле F_REF (+2) структуры файла
    DCR  M                          ; F_REF-- (Уменьшаем количество удержаний дескриптора)
    MOV  A, M                       ; A = Текущее значение F_REF после декремента
    JNZ  _vfs_close_success         ; Если F_REF > 0, файл ещё открыт в других процессах -> На выход

    ; === ШАГ 4: СЧЕТЧИК ССЫЛОК ОБНУЛИЛСЯ — ФИЗИЧЕСКОЕ ЗАКРЫТИЕ ДРАЙВЕРА ===
    ; Нам нужно вызвать метод V_OP_CLOSE драйвера. Наш HL сейчас на F_REF (+2).
    ; Извлекаем Major и Minor из структуры. Нам нельзя портить пользовательские РОН.
    LHLD VFS_CLOSE_STRUCT_PTR       ; HL = База структуры открытого файла
    
    MOV  A, M                       ; A = Major-номер устройства (F_TYPE)
    STA  VFS_CLOSE_MAJOR_TMP        ; Кэшируем во временную ячейку закрытия
    
    INX  H                          ; HL -> Поле F_MINOR (+1)
    MOV  A, M                       ; A = Minor-номер физического порта
    STA  VFS_CLOSE_MINOR_TMP        ; Кэшируем во временную ячейку закрытия

    ; Вызываем центральный атомарный коммутатор vfs_dispatch. 
    ; Параметры: HL = Физический адрес структуры открытого файла
    ;             C  = Смещение метода драйвера (V_OP_CLOSE = 2)
    LHLD VFS_CLOSE_STRUCT_PTR       ; HL = Структура файла для ABI драйвера
    MVI  C, V_OP_CLOSE              ; C = 2 (Константа метода закрытия из vfs.inc)
    
    ; ВНИМАНИЕ: k_vfs_dispatch полностью сохраняет РОН супервизора, 
    ; считывает Major/Minor и выполняет PUSH + RET в код драйвера.
    ; Чтобы после выполнения кода драйвера управление вернулось сюда, в k_vfs_close_fd,
    ; мы имитируем CALL: заталкиваем адрес возврата на стек ядра!
    LXI  B, _vfs_close_driver_return
    PUSH B                          ; Адрес возврата теперь на вершине стека ядра
    JMP  k_vfs_dispatch             ; Безусловный прыжок в коммутатор. Он сделает RET в драйвер.

_vfs_close_driver_return:
    ; Драйвер физического устройства отработал и вернул управление сюда через свой RET.
    ; Полностью затираем освобождённый глобальный слот файла в SYS_FILE_TABLE, выставляя F_TYPE = 0
    LHLD VFS_CLOSE_STRUCT_PTR       ; HL = База освобождённого слота
    MVI  M, VFS_TYPE_FREE           ; F_TYPE = 00h (Слот официально объявлен свободным в ядре)

_vfs_close_success:
    XRA  A                          ; A = 00H, сброс флага переноса: CY = 0 (УСПЕХ)
    JMP  _vfs_close_final

_vfs_close_err_ebadf:
    MVI  A, EBADF                   ; A = POSIX ошибка EBADF (Bad file number = 9)
    STC                             ; АППАРАТНЫЙ ФЛАГ ПРОВАЛА: CY = 1

_vfs_close_final:
    POP  H
    POP  D
    POP  B                          ; Восстановили РОН супервизора в исходное состояние
    RET                             ; Сквозной возврат в вызывающий сисколл (sys_close)

; =============================================================================
; НАЗВАНИЕ: vfs.asm (Транслятор символьных путей оборудования /dev/*)
; =============================================================================
k_vfs_resolve_dev:
    ; Вход:  DE = Физический 16-битный адрес ASCII-строки пути в Ring 3
    ;        Прерывания заперты (DI), стек в Ring 0.
    ; Выход: CY = 0 (H = Major, L = Minor), CY = 1 (HL = 0000H при ошибке ENOENT)
    PUSH B
    PUSH D                          ; Сохранили контекст (DE_user на вершине стека)

    ; --- ШАГ 1: АКТИВАЦИЯ РЕЖИМА KERNEL_OVERRIDE ---
    MVI  A, KERNEL_OVERRIDE_ON
    OUT  EMMU_OVERRIDE             ; Открыли Сегмент 2 на User RAM [1.3]
    
    LXI  B, DEV_MOUNT_TABLE         ; BC = Начало таблицы монтирования
    MVI  A, MAX_MOUNT_DEVS          ; A = Лимит сканирования (16 узлов)
    STA  K_TMP_SLOTS_CNT

_vfs_dev_scan_loop:
    ; === Сохраняем текущий указатель таблицы BC в кэш-ячейки ядра ===
    MOV  A, C
    STA  K_TMP_CURR_LO              
    MOV  A, B
    STA  K_TMP_CURR_HI

    ; === Извлекаем адрес эталонной строки из таблицы монтирования ===
    ; Переносим BC в HL, чтобы безопасно прочитать 16-битный указатель
    MOV  L, C
    MOV  H, B                       ; HL = Текущая позиция в таблице монтирования
    MOV  E, M                       ; E = Младший байт адреса эталонной строки
    INX  H
    MOV  D, M                       ; D = Старший байт адреса эталонной строки
    ; Теперь DE = Адрес эталонной строки ("ttyS0" и т.д. в ПЗУ ядра)
    
    ; === Извлекаем адрес пользовательской строки из стека ядра ===
    ; DE_user лежит на вершине стека (SP+0 = E, SP+1 = D)
    PUSH D                          ; Временно спрятали адрес эталона, освобождая DE
    LXI  H, 2                       ; Смещение +2, так как мы только что сделали PUSH D!
    DAD  SP                         ; HL указывает на ячейку сохранённого DE_user
    MOV  E, M                       ; E = Младший байт DE_user
    INX  H
    MOV  D, M                       ; D = Старший байт DE_user
    
    ; Переносим адрес пользовательской строки в пару HL
    MOV  H, D
    MOV  L, E                       ; HL = Адрес пользовательской строки в Окне 2 [1.3]
    POP  D                          ; DE = Восстановили адрес эталонной строки ядра
    ; Теперь строго: DE = Адрес эталона Ring 0, HL = Адрес пользователя Ring 3! [1.3]

_vfs_dev_string_cmp_loop:
    LDAX D                          ; A = Символ эталонной строки ядра
    CMP  M                          ; Сравниваем с символом из Ring 3 [1.3]
    JNZ  _vfs_dev_next_mount_slot   ; Не совпало — на следующий слот
    
    ORA  A                          ; Проверяем нуль-терминатор конца строки
    JZ   _vfs_dev_node_matched      ; Нашли полное совпадение!
    
    INX  D                          ; Шаг вперед по строке ядра
    INX  H                          ; Шаг вперед по строке пользователя в Окне 2 [1.3]
    JMP  _vfs_dev_string_cmp_loop

_vfs_dev_next_mount_slot:
    ; Восстанавливаем указатель таблицы из временных ячеек
    LDA  K_TMP_CURR_LO
    MOV  C, A
    LDA  K_TMP_CURR_HI
    MOV  B, A                       ; Пара BC снова указывает на текущий слот таблицы
    
    MOV  L, C
    MOV  H, B                       ; HL = Текущий узел монтирования
    LXI  D, MNT_ENTRY_SZ            ; Шаг равен каноничным 6 байтам
    DAD  D
    MOV  B, H
    MOV  C, L                       ; BC указывает на начало следующего слота

    LDA  K_TMP_SLOTS_CNT
    DCR  A                          ; Уменьшаем счетчик слотов
    STA  K_TMP_SLOTS_CNT
    JNZ  _vfs_dev_scan_loop         ; Продолжаем сканирование таблицы

    ; --- ОШИБКА: УЗЕЛ НЕ НАЙДЕН (POSIX ENOENT) ---
    MVI  A, KERNEL_OVERRIDE_OFF
    OUT  EMMU_OVERRIDE             ; Аппаратно закрываем оверран памяти [1.3]
    
    LXI  H, 0000H                   ; Возвращаем пустой указатель
    MVI  A, ENOENT                  ; A = Канонический код ошибки 2
    STC                             ; Взводим флаг ошибки CY = 1
    JMP  _vfs_resolve_exit

_vfs_dev_node_matched:
    ; Восстанавливаем указатель таблицы для считывания Major/Minor
    LDA  K_TMP_CURR_LO
    MOV  C, A
    LDA  K_TMP_CURR_HI
    MOV  B, A
    
    MOV  L, C
    MOV  H, B                       ; HL = База совпавшего слота таблицы
    LXI  D, O_MNT_MAJOR
    DAD  D                          ; HL -> Поле O_MNT_MAJOR (+2)
    MOV  E, M                       ; E = Major
    
    INX  H                          ; HL -> Поле O_MNT_MINOR (+3)
    MOV  D, M                       ; D = Minor
    
    MVI  A, KERNEL_OVERRIDE_OFF
    OUT  EMMU_OVERRIDE             ; Аппаратно закрываем оверран памяти [1.3]

    MOV  H, E                       ; H = Major
    MOV  L, D                       ; L = Minor
    ANA  A                          ; Сброс флага ошибки: CY = 0 (УСПЕХ)

_vfs_resolve_exit:
    POP  D
    POP  B                          ; Восстановили РОН супервизора
    RET

; =============================================================================
; ПРОЦЕДУРА: vfs_mknod (УНИВЕРСАЛЬНАЯ БЕЗСТЕКОВАЯ ВЕРСИЯ С ВАЛИДАЦИЕЙ ГРАНИЦ)
; Вход:  A  = Тип создаваемого узла (I_TYPE_REGULAR, I_TYPE_CHRDEV, I_TYPE_BLKDEV)
;        C  = Major-номер драйвера (Для терминалов = 4)
;        B  = Minor-номер устройства / порта (0..3)
;        DE = Физический адрес ASCIIZ-строки полного пути к файлу
; Задача: Найти свободный Inode, выделить чистое имя из пути методом реверсивного
;         поиска разделителя '/', прошить атрибуты и скопировать имя в RAM-диск.
; Выход: CY = 0 — Успех. Узел интегрирован в топологию VFS.
;        CY = 1 — Ошибка: Превышен лимит слотов или передано пустое имя (A = код).
;        Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: vfs_mknod (СИНТАКСИЧЕСКИ ВЕРИФИЦИРОВАННАЯ КАНOНИЧЕСКАЯ ВЕРСИЯ)
; =============================================================================
vfs_mknod:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    ; --- ЭТАП 0: БЕЗОПАСНАЯ ИЗОЛЯЦИЯ ПАРАМЕТРОВ В ПАМЯТЬ ЯДРА ---
    STA  _vfs_mknod_tmp_type        ; Спрятали входной тип узла
    MOV  A, C
    STA  _vfs_mknod_tmp_major       ; Спрятали Major-номер
    MOV  A, B
    STA  _vfs_mknod_tmp_minor       ; Спрятали Minor-номер

    ; === ЭТАП 1: РЕВЕРСИВНЫЙ ТОКЕНИЗАТОР (ОБНАРУЖЕНИЕ КОНЦА СТРОКИ) ===
    MOV  H, D
    MOV  L, E                       ; HL = начало строки пути (из DE)
    
    ; Валидация на пустую строку
    MOV  A, M
    ORA  A
    JZ   _vfs_mknod_err_empty       ; Первым же байтом идет 00H — авария!

_vfs_mknod_seek_end:
    MOV  A, M
    ORA  A                          ; Нашли терминальный ноль?
    JZ   _vfs_mknod_end_found       ; Да — HL указывает на замыкающий ноль
    INX  H
    JMP  _vfs_mknod_seek_end

_vfs_mknod_end_found:
    ; === ЭТАП 2: ОБРАТНЫЙ ПОИСК РАЗДЕЛИТЕЛЯ '/' ===
_vfs_mknod_reverse_loop:
    DCX  H
    
    ; Валидация на выход за границы начала строки
    MOV  A, L
    CMP  E
    JNZ  _vfs_mknod_check_slash
    MOV  A, H
    CMP  D
    JZ   _vfs_mknod_name_isolated_direct  ; Откатились до самого начала пути (нет слешей)
    
_vfs_mknod_check_slash:
    MOV  A, M
    CPI  '/'                        ; Встретили косую черту?
    JZ   _vfs_mknod_name_isolated   ; Да — имя файла выделено!
    JMP  _vfs_mknod_reverse_loop

_vfs_mknod_name_isolated:
    INX  H                          ; Сдвиг вперед: HL указывает строго на первый символ имени

_vfs_mknod_name_isolated_direct:
    ; Валидация на пустое имя (например, если путь заканчивается на слеш "/dev/")
    MOV  A, M
    ORA  A
    JZ   _vfs_mknod_err_empty       ; Имя отсутствует — авария!
    
    XCHG                            ; DE = Вычисленный точный адрес чистого имени файла
                                    ; Теперь пара DE зафиксирована как источник для копирования.

    ; === ЭТАП 3: РЕЕНТЕРАБЕЛЬНЫЙ ПОИСК СВОБОДНОГО СЛОТА В ОЗУ ===
    LXI  H, VFS_INODE_TABLE         ; HL = Начало массива Inode
    MVI  B, VFS_MAX_INODES          ; Регистр B = Счетчик цикла (64 слота)

_vfs_mknod_scan_loop:
    MOV  A, M                       ; A = Считали I_TYPE текущего слота строго в аккумулятор
    CPI  I_TYPE_FREE                ; Слот свободен (00H)?
    JZ   _vfs_mknod_slot_found      ; Да — уходим на заполнение!
    
    ; Слот занят — шагаем вперед на размер структуры (+16 байт)
    PUSH D                          ; ← ИСПРАВЛЕНО СИНТАКСИЧЕСКИ (Вместо PUSH DE)
    LXI  D, INODE_STRUCT_SIZE       ; DE = 16
    DAD  D                          ; HL = HL + 16
    POP  D                          ; ← ИСПРАВЛЕНО СИНТАКСИЧЕСКИ (Вместо POP DE)
    
    DCR  B                          ; Декремент счетчика в изолированном регистре B
    JNZ  _vfs_mknod_scan_loop

    ; Таблица RAM-диска переполнена
    POP  H
	POP  D
	POP  B        ; Полностью восстановили оригинальные РОН
    STC                             ; CY = 1 (Провал: No space left on device)
    RET

_vfs_mknod_slot_found:
    ; === ЭТАП 4: АТОМАРНАЯ ПРОШИВКА АТРИБУТОВ УЗЛА ИЗ ПАМЯТИ ЯДРА ===
    LDA  _vfs_mknod_tmp_type
    MOV  M, A                       ; 1. Прошили ТИП УЗЛА (01H, 02H или 03H)
    
    INX  H                          ; HL -> O_I_MAJOR (+1)
    LDA  _vfs_mknod_tmp_major
    MOV  M, A                       ; 2. Прошили MAJOR-номер драйвера
    
    INX  H                          ; HL -> O_I_MINOR (+2)
    LDA  _vfs_mknod_tmp_minor
    MOV  M, A                       ; 3. Прошили MINOR-номер порта / устройства
    
    INX  H                          ; HL -> O_I_NAME (+3) — Буфер ASCIIZ-имени

    ; === ЭТАП 5: ПОБАЙТОВОЕ КУРЬЕРСКОЕ КОПИРОВАНИЕ ИМЕНИ ===
    MVI  C, 11                      ; Защитный лимит длины = 11 байт (10 символов + ноль)

_vfs_mknod_copy_name:
    LDAX D                          ; ← ИСПРАВЛЕНО СИНТАКСИЧЕСКИ (Вместо LDAX DE)
    MOV  M, A                       ; Записали в структуру Inode (HL)
    ORA  A                          ; Достигли конца строки (терминального нуля)?
    JZ   _vfs_mknod_copy_done       ; Да — копирование успешно завершено!
    
    INX  D                          ; ← ИСПРАВЛЕНО СИНТАКСИЧЕСКИ (Вместо INX DE)
    INX  H                          ; Инкремент указателя приемника
    DCR  C                          ; Уменьшаем защитный лимит длины
    JNZ  _vfs_mknod_copy_name
    
    MVI  M, 00H                     ; Оверран длины — принудительно глушим буфер нулем

_vfs_mknod_copy_done:
    POP  H
	POP  D
	POP  B        ; Идеальное каноническое восстановление РОН супервизора по LIFO
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Полный рантайм-успех!)
    RET

_vfs_mknod_err_empty:
    POP  H
	POP  D
	POP  B        ; Симметрично очистили оригинальный РОН-кадр со стека
    MVI  A, EINVAL                  ; Аккумулятор А = 0x16 (Код ошибки недопустимого аргумента)
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Провал валдиации пути)
    RET

#include "./kernel/chrdev.asm"
; =============================================================================
; НАЗВАНИЕ: chrdev.asm (Системный Plug-and-Play регистратор драйверов)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль VFS
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: k_register_chrdev
; Вход:  A  = Целевой MAJOR номер устройства (0..31).
;        HL = Физический адрес функции write драйвера (HAL-мост).
;        DE = Физический адрес функции read драйвера (HAL-мост).
; Задача: Проверить Major на выход за границы таблицы. Рассчитать смещение 
;         Major * 4 и атомарно прошить адреса методов в SYS_CHRDEV_SWITCH.
; Выход: CY = 0 — Драйвер успешно встроен в коммутатор VFS.
;        CY = 1 — Провал: Передан недопустимый Major >= 32 (Защита памяти ядра).
;        Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
k_register_chrdev:
    ; --- ЭТАП 1: РАНТАЙМ-КОНТРОЛЬ СИСТЕМНЫХ ГРАНИЦ MAJOR ---
    CPI  VFS_MAX_TYPES              ; Сравниваем переданный Major с лимитом 32 [1.3]
    JNC  _k_reg_chrdev_fault        ; Если Major >= 32 — прерываем операцию (защита памяти) [1.3]

    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0
    PUSH PSW                        ; Спасли валидированный MAJOR номер на стек

    ; --- ЭТАП 2: ВЫЧИСЛЕНИЕ СМЕЩЕНИЯ (MAJOR * 4) ЧЕРЕЗ СДВИГИ i8080 ---
    ADD  A                          ; A = MAJOR * 2
    ADD  A                          ; A = MAJOR * 4
    MOV  C, A
    MVI  B, 00H                     ; BC = Точное байт-смещение слота в таблице ОЗУ

    ; --- ЭТАП 3: РАСЧЕТ И ПРИВЯЗКА К РЕЛОЦИРУЕМОЙ ТАБЛИЦЕ ОЗУ ---
    LXI  H, SYS_CHRDEV_SWITCH       ; Символический релоцируемый адрес таблицы из BSS [1.3]
    DAD  B                          ; HL = SYS_CHRDEV_SWITCH + (MAJOR * 4)

    ; Извлекаем оригинальный адрес метода write (HL_old) со стека без нарушения LIFO
    ; На вершине стека сейчас лежит сохраненный PSW, а под ним (SP+2) — оригинальный HL_old.
    ; Чтобы достать его атомарно, временно снимем PSW, сделаем обмен, и вернем PSW на место.
    POP  PSW                        ; Извлекли MAJOR в аккумулятор А
    XTHL                            ; ТРЮК i8080: HL = оригинальный HL_old (метод write),
                                    ; а на стек (SP+0) лег наш вычисленный адрес таблицы ОЗУ!
    MOV  C, L
    MOV  B, H                       ; BC = Истинный физический адрес функции write драйвера
    XTHL                            ; HL = Восстановили адрес таблицы ОЗУ, BC = метод write
    PUSH PSW                        ; Вернули MAJOR на вершину стека для баланса LIFO

    ; --- ЭТАП 4: АТОМАРНАЯ ФИКСАЦИЯ МЕТОДОВ ДРАЙВЕРА В ТАБЛИЦЕ ---
    MOV  M, C                       ; Прошили младший байт адреса функции write
    INX  H
    MOV  M, B                       ; Прошили старший байт адреса функции write
    INX  H                          ; HL перешагнул на поле O_CHR_READ (+2)

    ; Прошиваем метод READ (Адрес передан и сохранен в регистровой паре DE)
    MOV  M, E                       ; Прошили младший байт адреса функции read
    INX  H
    MOV  M, D                       ; Прошили старший байт адреса функции read

    POP  PSW                        ; Вытолкнули MAJOR со стека
    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление РОН супервизора
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Успех)
    RET

_k_reg_chrdev_fault:
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Ложный Major-номер)
    RET

; =============================================================================
; НАЗВАНИЕ: chrdev.asm (Табличный сквозной коммутатор записи VFS)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль VFS
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: vfs_chrdev_write
; Вход:  А  = Выводимый ASCII-символ.
;        C  = Major-номер символьного устройства, извлеченный из Inode (0..31).
;        B  = Minor-номер конкретного порта / устройства из Inode (0..3).
; Задача: Валидировать Major. Рассчитать адрес слота в SYS_CHRDEV_SWITCH,
;         извлечь 16-битный указатель метода write драйвера и выполнить 
;         косвенный переход по PCHL с сохранением РОН.
; Выход: Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
vfs_chrdev_write:
    ; --- ЭТАП 1: ПРЕДВАРИТЕЛЬНЫЙ КОНТРОЛЬ СИСТЕМНЫХ ГРАНИЦ MAJOR ---
    MOV  A, C                       ; А = MAJOR номер устройства из Inode
    CPI  VFS_MAX_TYPES              ; Запрос выходит за рамки таблицы (>=32)?
    JNC  _chr_table_wr_fault        ; Да — прерываем операцию (защита от краха ядра) [1.3]

    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    MOV  E, A                       ; ЭВАКУАЦИЯ: спрятали выводимый символ в регистр E [1.3]

    ; --- ЭТАП 2: ТАБЛИЧНЫЙ РАСЧЕТ СМЕЩЕНИЯ (MAJOR * 4) ---
    MOV  A, C                       ; А = Валидированный MAJOR номер
    ADD  A                          ; A = MAJOR * 2
    ADD  A                          ; A = MAJOR * 4
    MOV  L, A
    MVI  H, 00H                     ; HL = Смещение слота драйвера

    ; --- ЭТАП 3: ИЗВЛЕЧЕНИЕ АДРЕСА HAL-ШЛЮЗА ИЗ ОЗУ ТАБЛИЦЫ ---
    LXI  D, SYS_CHRDEV_SWITCH       ; Релоцируемый базовый адрес из BFS-кучи [1.3]
    DAD  D                          ; HL -> Указывает точно на поле O_CHR_WRITE слота MAJOR
    
    MOV  A, M
    INX  H
    MOV  H, M
    MOV  L, A                       ; HL = Исполняемый физический адрес HAL-моста (напр. tty_write_bridge)
    
    ; Проверка на пустой указатель (если для этого MAJOR драйвер еще не зарегистрирован)
    MOV  A, H
    ORA  L
    JZ   _chr_table_wr_empty        ; Указатель равен 0000H — пассивный сброс байта

    ; --- ЭТАП 4: ВОССТАНОВЛЕНИЕ КОНТРАКТА И КОСВЕННЫЙ ПРЫЖОК ПО PCHL ---
    MOV  A, E                       ; ВОССТАНОВЛЕНИЕ: вернули выводимый ASCII-символ в аккумулятор А [1.3]
    ; Регистр B по-прежнему содержит Minor-номер для вызываемого моста драйвера

    LXI  D, _chr_table_wr_ret       ; Вручную положили адрес возврата на стек Ring 0
    PUSH D
    PCHL                             ; Прыжок на исполнение в зарегистрированный мост драйвера!

_chr_table_wr_empty:
_chr_table_wr_ret:
    POP  H
    POP  D
    POP  B                          ; Идеальное каноническое восстановление РОН супервизора по LIFO
_chr_table_wr_fault:
    RET

; =============================================================================
; НАЗВАНИЕ: chrdev.asm (Табличный сквозной коммутатор чтения VFS)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль VFS
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: vfs_chrdev_read
; Вход:  C  = Major-номер символьного устройства, извлеченный из Inode (0..31).
;        B  = Minor-номер конкретного порта / устройства из Inode (0..3).
; Задача: Валидировать Major. Рассчитать адрес слота в SYS_CHRDEV_SWITCH,
;         извлечь 16-битный указатель метода read драйвера и выполнить
;         косвенный переход по PCHL. Защитить принятый символ от затирания POP.
; Выход: А  = Принятый из драйвера ASCII-символ (00H — если буфер пуст / пустой слот).
;        Все остальные РОН (BC, DE, HL) полностью сохранены по контракту.
; =============================================================================
vfs_chrdev_read:
    ; --- ЭТАП 1: ПРЕДВАРИТЕЛЬНЫЙ КОНТРОЛЬ СИСТЕМНЫХ ГРАНИЦ MAJOR ---
    MOV  A, C                       ; А = MAJOR номер устройства из Inode
    CPI  VFS_MAX_TYPES              ; Запрос выходит за рамки таблицы (>=32)?
    JC   _chr_table_rd_valid        ; В границах — шагаем на обработку
    
    XRA  A                          ; Вне границ — принудительно возвращаем 00H
    RET

_chr_table_rd_valid:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    ; --- ЭТАП 2: ТАБЛИЧНЫЙ РАСЧЕТ СМЕЩЕНИЯ К ПОЛЮ O_CHR_READ (MAJOR * 4 + 2) ---
    MOV  A, C                       ; А = Валидированный MAJOR номер
    ADD  A                          ; A = MAJOR * 2
    ADD  A                          ; A = MAJOR * 4
    MOV  L, A
    MVI  H, 00H                     ; HL = Смещение начала слота Major
    
    LXI  D, SYS_CHRDEV_SWITCH       ; Релоцируемый базовый адрес таблицы из BSS [1.3]
    DAD  D                          ; HL -> Указывает на поле O_CHR_WRITE слота MAJOR
    INX  H
    INX  H                          ; HL -> Указывает точно на поле O_CHR_READ (+2) слота MAJOR

    ; --- ЭТАП 3: ИЗВЛЕЧЕНИЕ АДРЕСА HAL-ШЛЮЗА ИЗ ОЗУ ТАБЛИЦЫ ---
    MOV  A, M
    INX  H
    MOV  H, M
    MOV  L, A                       ; HL = Исполняемый физический адрес HAL-моста (напр. tty_read_bridge)
    
    ; Проверка на пустой указатель
    MOV  A, H
    ORA  L
    JZ   _chr_table_rd_empty        ; Указатель равен 0000H — возвращаем дефолтный нуль 00H

    ; --- ЭТАП 4: КОСВЕННЫЙ ПРЫЖОК ПО PCHL И ЭВАКУАЦИЯ РЕЗУЛЬТАТА ---
    ; Регистр B по-прежнему содержит Minor-номер для вызываемого моста драйвера
    LXI  D, _chr_table_rd_ret       ; Вручную положили адрес возврата на стек Ring 0
    PUSH D
    PCHL                             ; Прыжок на исполнение в зарегистрированный мост драйвера!

_chr_table_rd_empty:
    MVI  E, 00H                     ; Если слот пуст — фиксируем дефолтный нуль в регистре E
    JMP  _chr_table_rd_done

_chr_table_rd_ret:
    ; Мы вернулись из физического моста (например, tty_read_bridge). 
    ; Символ лежит в аккумуляторе А. Все остальные РОН мостом сохранены.
    MOV  E, A                       ; ИЗОЛЯЦИЯ: немедленно спрятали принятый символ в регистр E [1.3]
                                    ; Теперь А можно затирать командами восстановления контекста!

_chr_table_rd_done:
    POP  H
    POP  D
    POP  B                          ; Идеальное каноническое восстановление РОН супервизора по LIFO
    MOV  A, E                       ; ВЫДАЧА РЕЗУЛЬТАТА: перенесли защищенный символ из E в аккумулятор А [1.3]
    RET
#include "./kernel/pcb.asm"
; =============================================================================
; /kernel/pcb.asm - ДИНАМИЧЕСКИЙ ПРИОРИТЕТНЫЙ ПЛАНИРОВЩИК И КОНТЕКСТНЫЙ ДИСПЕТЧЕР
; =============================================================================
; R2AKT, 03/07/2026.
; -----------------------------------------------------------------------------
; ЦЕНТРАЛЬНАЯ ПОДПРОГРАММА: СКАНИРОВАНИЕ И НАЧИСЛЕНИЕ ДИНАМИЧЕСКИХ ПРИОРИТЕТОВ
; -----------------------------------------------------------------------------
; Вызывается из прерываний Ring 0 при DI.
; Выход: А = PID процесса, назначенного на исполнение (NEXT_PID).
; =============================================================================
scheduler:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили РОН супервизора в KERNEL_STACK

    ; --- ЭТАП 1: ШТРАФОВАНИЕ ВЫПОЛНЯВШЕГОСЯ ПРОЦЕССА ---
    LHLD CURRENT_PCB_PTR            ; HL = Адрес активного PCB из кэша ядра
    MOV  A, H
    ORA  L
    JZ   sched_find_candidate       ; Если холодный старт (указатель 0) — пропускаем

    ; Проверяем статус задачи
    PUSH H                          ; Локальный снапшот базы для Фазы 1
    LXI  D, O_STATUS
    DAD  D                          ; HL -> O_STATUS (+1)
    MOV  A, M
    CPI  ST_RUNNING
    JNZ  sched_skip_penalty         ; Если процесс сам ушел в сон (ST_WAITING) — не штрафуем
    
    MVI  M, ST_READY                ; Вернули вытесненный процесс в queue готовности

    ; Увеличиваем штрафной счетчик использованного процессорного времени
    POP  H
    PUSH H                          ; Восстановили базу текущего PCB
    LXI  D, O_CPU_TICKS
    DAD  D                          ; HL -> O_CPU_TICKS (+19)
    MOV  A, M
    CPI  0FFh                       ; Защита от переполнения байта
    JZ   skip_tick_inc              
    INR  M                          ; O_CPU_TICKS++
skip_tick_inc:

    ; === БЕЗОПАСНЫЙ ПЕРЕСЧЕТ ДИНАМИЧЕСКОГО ПРИОРИТЕТА С НАСЫЩЕНИЕМ ===
    POP  H
    PUSH H
    LXI  D, O_PRIO_STATIC
    DAD  D                          ; HL -> O_PRIO_STATIC (+16)
    MOV  A, M                       ; A = Базовый статический приоритет
    
    INX  H                          ; HL -> O_PRIO_NICE (+17)
    ADD  M                          ; A = STATIC + NICE
    JNC  _sched_add_ticks           ; Если нет переноса — переходим к тикам
    MVI  A, 0FFh                    ; Переполнение! Принудительно выставляем потолок 255
    JMP  _sched_write_prio          ; Сразу пишем максимум, тики уже не изменят лимит

_sched_add_ticks:
    INX  H                          ; HL -> O_PRIO_DYNAMIC (+18)
    INX  H                          ; HL -> O_CPU_TICKS (+19)
    ADD  M                          ; A = (STATIC + NICE) + CPU_TICKS
    JNC  _sched_save_calc           ; Если нет переноса — пишем честный результат
    MVI  A, 0FFh                    ; Переполнение! Насыщаем до 255
    JMP  _sched_write_prio

_sched_save_calc:
    DCX  H                          ; Фикс указателя: HL -> O_PRIO_DYNAMIC (+18)
    MOV  M, A                       ; Зафиксировали вычисленный приоритет
    JMP  sched_skip_penalty

_sched_write_prio:
    ; Специфический маркер для записи насыщения, если HL ушел на +19
    POP  H
    PUSH H                          ; Восстановили чистую базу PCB
    LXI  D, O_PRIO_DYNAMIC
    DAD  D                          ; HL -> O_PRIO_DYNAMIC (+18)
    MVI  M, 0FFh                    ; Записали жесткий лимит 0xFF (255)

sched_skip_penalty:
    POP  H                          ; Очистили локальный снапшот адреса базы PCB

sched_find_candidate:
    ; --- ЭТАП 2: ПОИСК READY-ЗАДАЧИ С НАИЛУЧШИМ ПРИOРИТЕТОМ ---
    MVI  A, 0FFh
    STA  SCHED_BEST_PRIO            ; Инициализируем минимум наихудшим весом (255)
    
    XRA  A                          ; A = 00h
    STA  SCHED_BEST_PID             ; Дефолтный кандидат принудительно = PID 0 (Idle task)

    LXI  H, PCB_TABLE               ; HL -> Стартовый адрес таблицы задач
    MVI  B, MAX_PROCS               ; Счетчик цикла = 32 слота

sched_scan_loop:
    PUSH H                          ; Сохранили физический адрес текущего PCB на итерации
    
    ; Проверяем статус существования процесса (O_STATUS == ST_FREE)?
    LXI  D, O_STATUS
    DAD  D                          ; HL -> O_STATUS (+1)
    MOV  A, M
    CPI  ST_FREE                    
    JZ   sched_pop_next_slot        ; Если слот пуст — шагаем на следующий процесс
    
    CPI  ST_READY                   ; Процесс готов к выполнению (02h)?
    JNZ  sched_check_zombie         ; Если не READY (сон, зомби) — проверяем перед Aging

    ; Процесс готов! Извлекаем его динамический приоритет O_PRIO_DYNAMIC (+18)
    POP  H
    PUSH H                          ; Удержали адрес базы на стеке
    LXI  D, O_PRIO_DYNAMIC
    DAD  D                          ; HL -> O_PRIO_DYNAMIC (+18)
    MOV  A, M                       ; A = Текущий динамический приоритет задачи
    
    LXI  H, SCHED_BEST_PRIO
    CMP  M                          ; Сравниваем текущий приоритет с рекордом (A - M)
    JNC  sched_check_zombie_direct  ; Если приоритет хуже или равен рекорду — на Aging

    ; Нашли процесс с лучшим приоритетом!
    STA  SCHED_BEST_PRIO            ; Обновили рекорд минимума
    POP  H
    PUSH H                          ; Восстановили адрес проверяемого PCB
    MOV  A, M                       ; A = O_PID текущего процесса (+0)
    STA  SCHED_BEST_PID             ; Зафиксировали PID лучшего кандидата
    
    JMP  sched_pop_next_slot        

sched_check_zombie_direct:
    JMP  sched_aging_execute

sched_check_zombie:
    CPI  ST_ZOMBIE                  ; Проверяем считанный O_STATUS
    JZ   sched_pop_next_slot        ; Если Zombie — полностью изолируем от Aging

sched_aging_process:
sched_aging_execute:
    POP  H
    PUSH H                          ; Сбалансированный доступ к базе PCB
    LXI  D, O_CPU_TICKS
    DAD  D                          ; HL -> O_CPU_TICKS (+19)
    MOV  A, M
    ORA  A                          ; Проверка на 0
    JZ   sched_pop_next_slot        ; Штраф уже равен 0 — уменьшать некуда
    DCR  M                          ; O_CPU_TICKS-- (Приоритет растет вверх!)

sched_pop_next_slot:
    POP  H                          ; Балансировка стека ядра завершена

sched_next_slot:
    LXI  D, PCB_SIZE                ; Шаг равен каноничным 64 байтам
    DAD  D                          ; HL переместился на следующий PCB
    DCR  B
    JNZ  sched_scan_loop            ; Повторяем для всех 32 слотов таблицы процессов

    ; --- ЭТАП 3: ФИКСАЦИЯ РЕЗУЛЬТАТА И СБРОС ТИКОВ ИЗБРАННИКА ---
    LDA  SCHED_BEST_PID
    STA  NEXT_PID                   ; Назначили PID следующей исполняемой задачи

    ; Вычисляем адрес PCB выбранного процесса: База = PCB_TABLE + (NEXT_PID * 64)
    MOV  L, A
    MVI  H, 0
    DAD  H                          ; *2
    DAD  H                          ; *4
    DAD  H                          ; *8
    DAD  H                          ; *16
    DAD  H                          ; *32
    DAD  H                          ; HL = NEXT_PID * 64
    LXI  D, PCB_TABLE
    DAD  D                          ; HL = физический адрес PCB выбранного процесса
    
    ; Обнуляем счётчик тиков O_CPU_TICKS избранной задачи
    LXI  D, O_CPU_TICKS
    DAD  D                          ; HL -> O_CPU_TICKS (+19)
    MVI  M, 00H                     ; Сброс штрафных тиков для запускаемого процесса

    POP  H
    POP  D
    POP  B                          ; Восстановили РОН супервизора
    LDA  NEXT_PID                   ; Возврат результирующего PID в аккумуляторе А
    RET

; -----------------------------------------------------------------------------
; АППАРАТНЫЙ ДИСПЕТЧЕР КОНТЕКСТОВ: switch_mmu_context
; -----------------------------------------------------------------------------
; Атомарно прошивает flat-карту памяти Ring 3 и обновляет кэш CURRENT_PCB_PTR.
; Вызывается строго внутри критических секций ядра при заблокированных прерываниях (DI).
; =============================================================================
switch_mmu_context:
    ; Вход: Прерывания запрещены (DI). SP указывает на KERNEL_STACK.
    ;       SP процесса УЖЕ сохранён в O_SAVED_SP вызывающим кодом.

    ; === ЭТАП 1: АКТИВАЦИЯ ИДЕНТИФИКАТОРОВ НОВОЙ ЗАДАЧИ ===
    LDA  NEXT_PID
    STA  CURRENT_PID

    ; Вычисляем адрес нового PCB: HL = PCB_TABLE + (NEXT_PID * 64)
    MOV  L, A
    MVI  H, 0
    DAD  H                          ; *2
    DAD  H                          ; *4
    DAD  H                          ; *8
    DAD  H                          ; *16
    DAD  H                          ; *32
    DAD  H                          ; *64
    LXI  D, PCB_TABLE
    DAD  D
    SHLD CURRENT_PCB_PTR

    ; Выставляем статус ST_RUNNING (+1)
    LXI  D, O_STATUS
    DAD  D
    MVI  M, ST_RUNNING

    ; === ЭТАП 2: РЕКОНФИГУРАЦИЯ eMMU ===
    ; Переход от O_STATUS (+1) к O_PAGES_MAP (+8). Разница = 7 байт.
    LXI  D, 0007H
    DAD  D

    ; Прошиваем окна К555ИР26
    MOV  A, M
    OUT  EMMU_PAGE_REG0
    INX  H
    MOV  A, M
    OUT  EMMU_PAGE_REG1
    INX  H
    MOV  A, M
    OUT  EMMU_PAGE_REG2
    INX  H
    MOV  A, M
    OUT  EMMU_PAGE_REG3

    ; === ЭТАП 3: ВОССТАНОВЛЕНИЕ СТЭКА НОВОЙ ЗАДАЧИ ===
    LHLD CURRENT_PCB_PTR
    LXI  D, O_SAVED_SP
    DAD  D
    MOV  E, M
    INX  H
    MOV  D, M                       ; DE = SP новой задачи

    XCHG
    SPHL                            ; Переключаемся на стек новой задачи

    ; Восстанавливаем РОН
    POP  H
    POP  D
    POP  B
    POP  PSW

    RET                             ; Возврат в Ring 3

; =============================================================================
; k_pcb_subsys_init - ИНИЦИАЛИЗАЦИЯ ПОДСИСТЕМЫ ПЛАНИРОВАНИЯ И ТАБЛИЦЫ PCB
; =============================================================================
; Вход:  Cold Boot, Ring 0, прерывания запрещены.
; Задача: Полностью подготовить PCB_TABLE (32 слота × 64 байта = 2 КБ)
;         и управляющие ячейки планировщика к работе.
; Выход: CURRENT_PCB_PTR указывает на PCB PID 0 (idle-задача ядра).
; =============================================================================
k_pcb_subsys_init:
    ; === ШАГ 1: ПОЛНЫЙ СБРОС УПРАВЛЯЮЩИХ ЯЧЕЕК ПЛАНИРОВЩИКА ===
    XRA  A
    STA  CURRENT_PID
    STA  NEXT_PID
    STA  SCHED_BEST_PRIO
    STA  SCHED_BEST_PID
    STA  CPU_USAGE

    ; === ШАГ 2: РАЗМЕТКА ТАБЛИЦЫ PCB (32 СЛОТА ПО 64 БАЙТА) ===
    LXI  H, PCB_TABLE
    MVI  C, 0                    ; C = текущий PID (0..31)

_init_pcb_loop:
    ; --- 2.1: Полное зануление 64-байтного слота ---
    PUSH H                       ; Сохраняем базу текущего слота
    MVI  B, PCB_SIZE             ; B = 64
_clear_pcb_slot:
    MVI  M, 00H
    INX  H
    DCR  B
    JNZ  _clear_pcb_slot
    POP  H                       ; Восстанавливаем базу слота

    ; --- 2.2: Установка специфических маркеров структуры ---
    ; O_PID (+0) = текущий PID (C)
    MOV  M, C

    ; O_STATUS (+1) = ST_FREE (слот свободен)
    INX  H
    MVI  M, ST_FREE

    ; O_PPID (+6) = RES_FREE_MARKER (родитель отсутствует)
    ; ИСПРАВЛЕНО: Используем точное смещение вместо POP/PUSH
    PUSH H                       ; ← ДОБАВЛЕНО: Сохраняем базу
    LXI  D, O_PPID
    DAD  D
    MVI  M, RES_FREE_MARKER
    POP  H                       ; ← Восстанавливаем базу

    ; O_TTY_INDEX (+24) = RES_FREE_MARKER (отвязан от TTY)
    PUSH H                       ; ← ДОБАВЛЕНО: Сохраняем базу
    LXI  D, O_TTY_INDEX
    DAD  D
    MVI  M, RES_FREE_MARKER
    POP  H                       ; ← Восстанавливаем базу

    ; O_FILE_TABLE (+34..+49) = 16 дескрипторов по RES_FREE_MARKER
    PUSH H                       ; ← ДОБАВЛЕНО: Сохраняем базу
    LXI  D, O_FILE_TABLE
    DAD  D                       ; HL -> O_FILE_TABLE
    MVI  B, 16                   ; 16 файловых дескрипторов
_init_file_table_loop:
    MVI  M, RES_FREE_MARKER      ; FD свободен (0xFF)
    INX  H
    DCR  B
    JNZ  _init_file_table_loop
    POP  H                       ; ← Восстанавливаем базу

    ; --- 2.3: Переход к следующему слоту таблицы ---
    LXI  D, PCB_SIZE             ; PCB_SIZE = 64
    DAD  D                       ; HL = начало следующего слота

    INR  C                       ; PID++
    MOV  A, C
    CPI  MAX_PROCS               ; MAX_PROCS = 32
    JNZ  _init_pcb_loop          ; Повторяем для всех 32 слотов

    ; === ШАГ 3: АВТОРИЗОВАННАЯ КОНФИГУРАЦИЯ PID 0 (IDLE-ЗАДАЧА ЯДРА) ===
    LXI  H, PCB_TABLE            ; HL = база PID 0

    ; O_STATUS (+1) = ST_RUNNING (ядро выполняется на CPU)
    LXI  D, O_STATUS
    DAD  D
    MVI  M, ST_RUNNING

    ; O_UID (+20) = 0 (ROOT), O_GID (+21) = 0
    LXI  H, PCB_TABLE
    LXI  D, O_UID
    DAD  D
    MVI  M, 00H                  ; UID = 0 (Superuser)
    INX  H
    MVI  M, 00H                  ; GID = 0

    ; O_PAGES_MAP (+8..+11) = [0, 1, 2, 3] — физические страницы ядра
    LXI  H, PCB_TABLE
    LXI  D, O_PAGES_MAP
    DAD  D
    MVI  M, 00H                  ; Сегмент 0 = физ. страница 0
    INX  H
    MVI  M, 01H                  ; Сегмент 1 = физ. страница 1
    INX  H
    MVI  M, 02H                  ; Сегмент 2 = физ. страница 2
    INX  H
    MVI  M, 03H                  ; Сегмент 3 = физ. страница 3

    ; O_PRIO_STATIC (+16) = 0 (высший базовый приоритет)
    ; O_PRIO_NICE (+17) = 20 (нейтральный nice-фактор)
    ; O_PRIO_DYNAMIC (+18) = 20 (стартовый динамический вес)
    LXI  H, PCB_TABLE
    LXI  D, O_PRIO_STATIC
    DAD  D
    MVI  M, 00H                  ; STATIC = 0
    INX  H
    MVI  M, 20                   ; NICE = 20
    INX  H
    MVI  M, 20                   ; DYNAMIC = 20

    ; O_PPID (+6) = RES_FREE_MARKER (у ядра нет родителя)
    LXI  H, PCB_TABLE
    LXI  D, O_PPID
    DAD  D
    MVI  M, RES_FREE_MARKER

    ; O_TTY_INDEX (+24) = RES_FREE_MARKER (ядро не привязано к TTY)
    LXI  H, PCB_TABLE
    LXI  D, O_TTY_INDEX
    DAD  D
    MVI  M, RES_FREE_MARKER

    ; O_FILE_TABLE (+34..+49) = 16 × 0xFF (у ядра нет открытых файлов)
    LXI  H, PCB_TABLE
    LXI  D, O_FILE_TABLE
    DAD  D
    MVI  B, 16
_init_pid0_fd_loop:
    MVI  M, RES_FREE_MARKER
    INX  H
    DCR  B
    JNZ  _init_pid0_fd_loop

    ; === ШАГ 4: ФИКСАЦИЯ КЭШ-УКАЗАТЕЛЯ ЯДРА ===
    LXI  H, PCB_TABLE
    SHLD CURRENT_PCB_PTR         ; Кэш указывает на настроенный PID 0

    RET                          ; Возврат в k_power_on_init

; =============================================================================
k_calc_cpu_usage:
    ; Вход: Вызывается планировщиком или системным таймером (вектор 0x0038).
    ; Задача: Подсчитать количество пользовательских задач в состоянии ST_READY
    ;         и спроецировать результат в метрику CPU_USAGE (0..4).
    PUSH B
    PUSH D
    PUSH H                          ; Сохраняем контекст супервизора

    XRA  A                          ; A = 0 (Счетчик готовых задач)
    MOV  C, A                       ; C = 0 (Текущее число ST_READY процессов)
    
    LXI  H, PCB_TABLE               ; HL -> Начало таблицы процессов
    MVI  B, MAX_PROCS               ; Счетчик цикла = 32 слота

_cpu_scan_loop:
    PUSH H                          ; Сохраняем базовый адрес текущего PCB
    
    ; Проверяем O_PID. Слот IDLE-процесса (PID = 0) исключаем из расчёта нагрузки.
    MOV  A, M
    ORA  A                          ; Проверка на PID == 0
    JZ   _cpu_skip_slot             ; Пропускаем swapper
    
    ; Переходим к проверке статуса
    LXI  D, O_STATUS
    DAD  D                          ; HL -> O_STATUS (+1)
    MOV  A, M
    CPI  ST_READY                   ; Задача ожидает выполнения?
    JNZ  _cpu_skip_slot             ; Если спит, свободна или зомби — не считаем
    
    INR  C                          ; Увеличиваем счётчик готовых процессов

_cpu_skip_slot:
    POP  H                          ; Восстанавливаем базу текущего PCB
    LXI  D, PCB_SIZE                ; Шаг в 64 байта
    DAD  D                          ; Сдвиг на следующий PCB
    
    DCR  B                          ; Уменьшаем счётчик слотов
    JNZ  _cpu_scan_loop             ; Повторяем для всех 32 процессов

    ; --- ЭТАП 2: ТАБЛИЧНОЕ МАСШТАБИРОВАНИЕ В ДИАПАЗОН 0..4 ---
    MOV  A, C                       ; A = Общее число найденных READY процессов
    
    CPI  1
    JC   _load_0                    ; Если 0 процессов -> Загрузка 0%
    
    CPI  2
    JC   _load_25                   ; Если 1 процесс   -> Загрузка 25%
    
    CPI  3
    JC   _load_50                   ; Если 2 процесса  -> Загрузка 50%
    
    CPI  4
    JC   _load_75                   ; Если 3 процесса  -> Загрузка 75%
    
    ; Если процессов >= 4, то наступает 100% насыщение очереди
    MVI  A, CPU_LOAD_100
    JMP  _write_metric

_load_0:
    MVI  A, CPU_LOAD_0
    JMP  _write_metric

_load_25:
    MVI  A, CPU_LOAD_25
    JMP  _write_metric

_load_50:
    MVI  A, CPU_LOAD_50
    JMP  _write_metric

_load_75:
    MVI  A, CPU_LOAD_75

_write_metric:
    STA  CPU_USAGE                  ; Записываем результат (0..4) в память ядра

    POP  H
    POP  D
    POP  B                          ; Восстанавливаем контекст супервизора
    RET
#include "./kernel/syscall.asm"
; =============================================================================
; ТОЧКА ВХОДА SYSCALL ENTRY
; =============================================================================
sys_call_entry:
	DI							; Отключаем прерывания

    ; === ФАЗА 1: ТЕНЕВОЕ СОХРАНЕНИЕ ПОЛЬЗОВАТЕЛЬСКОГО КОНТЕКСТА ===
    ; В SP сейчас стек Ring 3 вызывающей задачи. eMMU уже забросил туда PC.
    PUSH PSW                    ; Сохраняем Аккумулятор и Флаги (A, F) в стек Ring 0
    PUSH B                      ; Сохраняем регистры B, C задачи в стек Ring 0
    PUSH D                      ; Сохраняем регистры D, E задачи в стек Ring 0
    PUSH H                      ; Сохраняем регистры H, L задачи в стек Ring 0

    ; Переключаемся на изолированный системный стек Ядра ОС
    LXI  H, 0
    DAD  SP                     ; HL = текущий упакованный SP процесса
    LXI  SP, KERNEL_STACK_TOP   ; Загружаем чистый изолированный стек ядра ОС
    PUSH H	                    ; Временно прячем пользовательский SP в стек ядра

    LHLD CURRENT_PCB_PTR        ; HL = Адрес активного PCB из кэша ядра

    ; Прибавляем смещение O_SAVED_SP (+3) строго последовательно
    LXI  D, O_SAVED_SP          ; DE = смещение до поля (0003H)
    DAD  D                      ; HL = База_PCB + O_SAVED_SP
    
    POP  D                      ; DE = извлеченный из стека ядра пользовательский SP
    MOV  M, E                   ; Запись младшего байта SP
    INX  H
    MOV  M, D                   ; Запись старшего байта SP

    ; === ФАЗА 2: ДЕШИФРАЦИЯ И АВТОРИЗАЦИЯ СИС-ВЫЗОВА ===
    ; Номер системного вызова передан в регистре C
    MOV  A, C
    CPI  DEF_SYS_MAX_SYSCALLS + 1    ; Проверяем границы таблицы системных вызовов
    JNC  syscall_bad_number     ; Если номер больше лимита — возвращаем ENOSYS

    ; Вычисляем адрес перехода по таблице указателей: Смещение = Номер * 2
    MOV  L, C
    MVI  H, 0
    DAD  H                      ; HL = Номер Syscall * 2
    LXI  D, SYSCALL_TABLE
    DAD  D                      ; HL указывает точно на ячейку DW в таблице
    MOV  E, M
    INX  H
    MOV  D, M                   ; DE = физический адрес функции syscall в ядре

    ; Передаем управление на функцию ядра. 
    ; Поскольку параметры от пользователя пришли в DE и HL задачи, а мы их 
    ; теневым образом сохранили в стек, при необходимости функция ядра может 
    ; извлечь их оттуда или прочитать напрямую, если они не затерлись при расчете.
    ; Имитируем вызов CALL через стек:
    PUSH D	                    ; Забрасываем адрес функции ядра в стек
    LXI  H, syscall_return      ; Регистрируем точку возврата после исполнения
    PUSH H
    PCHL                        ; Программный прыжок на исполнение системной функции

syscall_return:
    ; Системная функция выполнилась и вернула код результата в Аккумуляторе (A)
    MOV  C, A                   ; Временно спасем код результата в C
    
    ; Записываем результат выполнения в поле O_SYSCALL_RES (+5) текущего PCB
    LHLD CURRENT_PCB_PTR        ; HL = базовый адрес PCB текущей задачи
    LXI  D, O_SYSCALL_RES
    DAD  D                      ; HL указывает на O_SYSCALL_RES
    MOV  M, C                   ; Результат системного вызова жестко зафиксирован

syscall_exit:
    ; === ФАЗА 3: ВОССТАНОВЛЕНИЕ КОНТЕКСТА И ВЫХОД В USER SPACE ===
	LHLD CURRENT_PCB_PTR        ; HL = базовый адрес PCB текущей задачи
    LXI  D, O_SAVED_SP
    DAD  D                      ; HL указывает на сохраненный SP
    MOV  E, M
    INX  H
    MOV  D, M                   ; DE = восстановленный SP задачи
    XCHG                        ; HL = новый SP
    SPHL                        ; Процессор переключился обратно на стек Ring 3

	; Запускаем проверку дефолтных политик сигналов (включая SIGBUS)
    ;CALL k_signal_default_policy_check
	
    ; Извлекаем теневые регистры из стека Ring 3 пользовательского пространства
    POP  H                      ; Восстановили H, L задачи
    POP  D                      ; Восстановили D, E задачи
    POP  B                      ; Восстановили B, C задачи
    POP  PSW                    ; Восстановили Аккумулятор и Флаги (A, F) задачи

	EI                          ; Снова разрешаем аппаратную карусель прерываний в Ring 3

    ; На вершине стека Ring 3 остался лежать только PC
    RET                         ; Переход обратно в задачу. Аппаратный сигнал ~{RET_STROBE} 
                                ; на плате сбросит KERNEL_MODE обратно в Ring 3!

syscall_bad_number:
    MVI  A, ENOSYS              ; Код ошибки: ENOSYS (Функция не реализована)
    JMP  syscall_return

; =============================================================================
; ЦЕНТРАЛЬНЫЙ СИНХРОННЫЙ ШЛЮЗ ВЫХОДА СИСКОЛЛОВ
; =============================================================================
syscall_exit_route:
    DI                              ; Критическая секция ядра

    ; СТРАХОВОЧНЫЙ ИНВАРИАНТ: Принудительно взводим Firewall через константу
    MVI  A, KERNEL_OVERRIDE_OFF
    OUT  EMMU_OVERRIDE             ; Аппаратно закрываем оверран памяти [1.3]

    ; Восстанавливаем регистровый контекст Ring 3 задачи из KERNEL_STACK
    POP  H
    POP  D
    POP  B
    POP  PSW                        
    
    EI                              ; Разрешили аппаратные прерывания ВН59
    RET                             ; Аппаратный прыжок обратно в Ring 3

; =============================================================================
; ВОЗВРАТ С ОШИБКОЙ ПРИ ОТСУТСТВИИ СИСТЕМНОГО ВЫЗОВА
; =============================================================================
syscall_nosys:
    MVI  A, ENOSYS               ; Возвращает ошибку 0xE5 (Функция не реализована)
    RET

; =============================================================================
; НАЗВАНИЕ: pcb.asm (Аварийное завершение и уничтожение процесса)
; ТОКЕН:    TOKEN::MEGA-580_OS_v1.5.9_SYS_EXIT_FATAL_STABLE_BUILD_20260705
; =============================================================================
sys_exit_fatal:
    MOV  C, A

    ; --- ШАГ 1: ФИКСАЦИЯ СТАТУСА ST_ZOMBIE И КОДА ВОЗВРАТА ---
    LHLD CURRENT_PCB_PTR
    PUSH H
    
    LXI  D, O_STATUS
    DAD  D
    MVI  M, ST_ZOMBIE
    
    POP  H
    PUSH H
    LXI  D, O_SYSCALL_RES
    DAD  D
    MOV  M, C
    POP  H

    ; --- ШАГ 2: ОСВОБОЖДЕНИЕ I/O ПОРТОВ ---
    LXI  H, GLOBAL_RESOURCE_TABLE
    MVI  B, 0
    LDA  CURRENT_PID
    MOV  C, A

_exit_fatal_ports_loop:
    MOV  A, M
    CMP  C
    JNZ  _exit_fatal_skip_port
    MVI  M, RES_FREE_MARKER

_exit_fatal_skip_port:
    INX  H
    INR  B
    MOV  A, B
    CPI  0
    JNZ  _exit_fatal_ports_loop

    ; --- ШАГ 3: ОСВОБОЖДЕНИЕ ФИЗИЧЕСКИХ СТРАНИЦ ---
    LHLD CURRENT_PCB_PTR
    LXI  D, O_PAGES_MAP
    DAD  D
    MVI  B, 4

_exit_fatal_ram_loop:
    MOV  A, M
    CPI  RES_FREE_MARKER
    JZ   _exit_fatal_skip_ram
    
    PUSH B
    PUSH H
    CALL k_free_physical_page       ; ← ИСПРАВЛЕНО: правильное имя функции
    
    POP  H
    POP  B
    MVI  M, RES_FREE_MARKER

_exit_fatal_skip_ram:
    INX  H
    DCR  B
    JNZ  _exit_fatal_ram_loop

    ; --- ШАГ 4: СБРОС СТЭКА И ВЫХОД ---
    LXI  SP, KERNEL_STACK_TOP
    
    CALL scheduler
    STA  NEXT_PID
    
    MVI  A, 020H
    OUT  MASTER_8259_CMD            
    
    EI                              ; ← КРИТИЧЕСКИ ВАЖНО: Разрешаем прерывания!
    
    JMP  switch_mmu_context

#include "sys_write.asm"
; =============================================================================
; ИСПРАВЛЕННЫЙ МОНОЛИТНЫЙ СИСТЕМНЫЙ ВЫЗОВ sys_write (ТАБЛИЧНЫЙ МЕТОД VFS)
; =============================================================================
sys_write:
    PUSH B
	PUSH D
	PUSH H        ; Законсервировали контекст задачи

    ; Валидация и жесткое маскирование входного дескриптора пользователя
    MOV  A, D
    ANI  00Fh                       ; ИСПРАВЛЕНО: Очистили старшие биты регистра D!
    STA  VFS_DISPATCH_MINOR         ; Временно сохранили чистый FD (0..15)
    
    LHLD CURRENT_PCB_PTR            ; HL = Адрес PCB активного процесса
    
    LDA  VFS_DISPATCH_MINOR
    ADI  O_FILE_TABLE               ; Смещение к таблице файлов задачи
    MOV  E, A
	MVI D, 0
    DAD  D
    
    MOV  A, M                       ; A = Индекс в глобальной SYS_FILE_TABLE (0..253)
    CPI  RES_FREE_MARKER            ; Дескриптор открыт?
    JZ   write_table_err_badf

    ; Извлекаем физический адрес 16-байтовой структуры открытого файла
    MOV  D, A                       ; Передали индекс в D для нашей подпрограммы
    CALL k_vfs_get_file_struct_address ; HL = Точный адрес файла в SYS_FILE_TABLE
    MOV  A, H
	ORA L
    JZ   write_table_err_badf       ; Страховочная проверка указателя
    
    SHLD VFS_DRV_ROW_PTR            ; Запомнили адрес структуры открытого файла

    ; Извлекаем Major-тип и Minor-номер устройства из 16-байтовой структуры ядра
    MOV  A, M                       ; A = Major Number из поля F_TYPE (+0)
    STA  VFS_DISPATCH_MAJOR
    INX  H
    MOV  A, M                       ; A = Minor Number из поля F_MINOR (+1)
    STA  VFS_DISPATCH_MINOR         ; Зафиксировали внутренний Minor дескриптор

    ; Вычисляем адрес строки в таблице переключателей: VFS_SWITCH_TABLE + (Major * 10)
    LDA  VFS_DISPATCH_MAJOR
    MOV  L, A
	MVI H, 0
    DAD  H                          ; Major * 2
    PUSH H
    DAD  H
	DAD  H                 ; Major * 8
    POP  D
	DAD  D                 ; HL = Major * 10
    LXI  D, VFS_SWITCH_TABLE
	DAD D 							; HL -> Строка нужного VFS-драйвера
    
    ; Сдвигаем указатель к адресу метода write (Смещение V_OP_WRITE = +6)
    LXI  D, V_OP_WRITE
    DAD  D                          ; HL указывает точно на адрес функции write
    
    ; Извлекаем 16-битный адрес функции из таблицы переключателей
    MOV  A, M
	INX H
	MOV H, M
	MOV L, A 						; HL = Адрес функции драйвера

    ; Реставрируем РОН-параметры для драйвера периферии перед PCHL прыжком
    POP  H                          ; Восстановили оригинальный HL (Адрес буфера Ring 3)
    XCHG                            ; DE = Адрес буфера Ring 3 пользователя
    POP  B                          ; BC = Количество байт для записи
    POP  PSW                        ; Сбалансировали стек ядра Ring 0 от пары PSW
    
    LDA  VFS_DISPATCH_MINOR         ; Аккумулятор А = Чистый Minor устройства (1..254)

    ; --- МГНОВЕННЫЙ АППАРАТНЫЙ ПРЫЖОК НА ДРАЙВЕР УСТРОЙСТВА ЧЕРЕЗ PCHL ---
    PUSH H                          ; Поместили адрес функции драйвера на стек
    PCHL                            ; Драйвер отработает и сделает RET прямо в syscall_exit!

write_table_err_badf:
    POP  H
	POP  D
	POP  B         ; Восстановили оригинальный РОН-контекст задачи
    MVI  A, 0FFh                    ; Код ошибки EBADF (0xFF)
    RET
#include "./kernel/hw.asm"
;
;[ОЗУ Ring 0 Ядра]
;0x0040 ┌──────────────────────────────────────┐
;       │ ВЕДУЩИЙ (Master) КР580ВН59           │
;       │ IRQ0 .. IRQ7                         │ 24 байта (8 слотов × 3 байта)
;0x0057 └──────────────────────────────────────┘
;0x0058 ┌──────────────────────────────────────┐
;       │ ВЕДОМЫЙ (Slave) КР580ВН59 на IRQ6    │
;       │ IRQ8 .. IRQ15                        │ 24 байта (8 слотов × 3 байта)
;0x006F └──────────────────────────────────────┘
;
; =============================================================================
; НАЗВАНИЕ: hw_init.asm (Инициализация КР580ВН59 с полной предмаскировкой линий)
; =============================================================================
; =============================================================================
; НАЗВАНИЕ: hw_init.asm (Инициализация КР580ВН59 с двухфазным автодетектом)
; ТОКЕН:    TOKEN::MEGA-580_OS_v1.5.68_HW_INT_INIT_PROBING_STABLE_20260708
; Вход:  Cold Boot, Ring 0, прерывания гарантированно заперты (DI).
; Задача: Проверить исправность ВН59, инициализировать без ICW4, выставить
;         базу векторов 0x0040, намертво замаскировать линии и забить заглушками.
; Выход: CY = 0 — Контроллер прерываний успешно обнаружен и инициализирован.
;        CY = 1 — Контроллер отсутствует или неисправен (Авария БИС).
;        Все РОН (BC, DE, HL) полностью сохранены согласно контракту HAL.
; =============================================================================
hw_int_init:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст супервизора Ring 0

    ; === ЭТАП 1: ДВУХФАЗНЫЙ АППАРАТНЫЙ ТЕСТ РЕГИСТРА IMR ===
    ; --- Фаза 1.1: Проверка паттерна 0x5A ---
    MVI  A, 05AH                    ; Тестовая маска 1 (01011010b)
    OUT  MASTER_8259_DATA           ; Попытка записи в регистр масок ВН59
    NOP \ NOP                       ; Стабилизация шины данных eMMU РЕВ_2.0
    IN   MASTER_8259_DATA           ; Считали обратно
    CPI  05AH                       ; Совпало?
    JNZ  _hw_int_probe_fail         ; Нет — чип не отвечает!

    ; --- Фаза 1.2: Проверка инверсного паттерна 0xA5 (Защита от залипания шины) ---
    MVI  A, 0A5H                    ; Тестовая маска 2 (10100101b)
    OUT  MASTER_8259_DATA           ; Отправили в IMR
    NOP \ NOP
    IN   MASTER_8259_DATA           ; Считали обратно
    CPI  0A5H                       ; Совпало?
    JNZ  _hw_int_probe_fail         ; Нет — аппаратный сбой БИС!

    ; === ЭТАП 2: ПАСПОРТНАЯ ПРОШИВКА КР580ВН59 ===
    ; ICW1: Работа по фронту (Edge), одиночный режим (SNGL=1), без ICW4 (IC4=0) -> 012H
    MVI  A, 012H             
    OUT  MASTER_8259_CMD
    
    ; ICW2: Базовое смещение векторов в памяти = 0x0040
    MVI  A, SYS_ISR_TABLE_BASE      ; 040H
    OUT  MASTER_8259_DATA
    
    ; === ЭТАП 3: НАМЕРТВО МАСКИРУЕМ ВСЕ ЛИНИИ ПОСЛЕ УСПЕШНОГО ТЕСТА ===
    ; OCW1: Записываем 11111111B = 0FFH. Контроллер аппаратно закрыт до 
    ; вызова k_register_isr конкретными драйверами периферии.
    MVI  A, 0FFH
    OUT  MASTER_8259_DATA

    ; === ЭТАП 4: СТАТИЧЕСКАЯ ЗАБИВКА ТАБЛИЦЫ С ШАГОМ 3 БАЙТА ===
    LXI  H, SYS_ISR_TABLE_BASE      ; HL = 0x0040
    MVI  B, SYS_MAX_IRQS            ; Счетчик цикла = 8 аппаратных слотов

_hw_int_fill_loop:
    MVI  M, OPCODE_CALL             ; Прописали [0xCD] (CALL)
    INX  H
    
    LXI  D, hw_stub                 ; DE = Физический адрес безопасной заглушки ядра
    MOV  M, E                       ; Прописали младший байт адреса hw_stub
    INX  H
    MOV  M, D                       ; Прописали старший байт адреса hw_stub
    INX  H                          ; Фиксированный шаг: HL сместился на +3 байта!
    
    DCR  B
    JNZ  _hw_int_fill_loop

    POP  H
    POP  D
    POP  B                          ; Полное восстановление оригинального контекста РОН
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Контроллер прерываний ОК)
    RET

_hw_int_probe_fail:
    POP  H
    POP  D
    POP  B                          ; Полное восстановление оригинального контекста РОН
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Аппаратный тупик: ВН59 неисправен!)
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_sys_init
; Вход:  Cold Boot, Ring 0, прерывания гарантированно заперты (DI).
; Задача: Проверить наличие БИС ВИ53 №1. Если чип исправен — настроить Канал 0
;         в Режим 3 с делителем 20 000 для генерации тиков IRQ0 каждые 20 мс.
; Выход: CY = 0 — Системный таймер успешно обнаружен, протестирован и запущен.
;        CY = 1 — Авария: БИС ВИ53 №1 отсутствует или повреждена на шине.
;        Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
hw_sys_init:
    PUSH B
    PUSH D
    PUSH H

    ; === ЭТАП 1: АВТОДЕТЕКТ ЧЕРЕЗ РЕЖИМ 0 ===
    ; Программируем Канал 0 в Режим 0
    MVI  A, PIT_CW_CH0_M0           ; 030H
    OUT  SYS_PIT_CMD

    ; Записываем максимальное значение 0xFFFF
    MVI  A, 0FFH
    OUT  SYS_PIT_CH0
    OUT  SYS_PIT_CH0                ; LSB = MSB = 0xFF

    ; Немедленно выдаем Latch Counter (минимум задержки!)
    MVI  A, PIT_CW_LATCH_CH0
    OUT  SYS_PIT_CMD

    ; Считываем значение
    IN   SYS_PIT_CH0
    MOV  B, A                       ; B = LSB
    IN   SYS_PIT_CH0
    MOV  C, A                       ; C = MSB

    ; Проверяем: значение должно быть близко к 0xFFFF
    ; (возможно, 0xFFFE или 0xFFFD из-за задержки)
    MOV  A, C
    CPI  0FFH
    JNZ  _hw_sys_pit_fail           ; MSB не 0xFF — чип отсутствует!

    MOV  A, B
    CPI  0FEH                       ; LSB может быть 0xFF, 0xFE или 0xFD
    JC   _hw_sys_pit_fail           ; Если LSB < 0xFE — слишком далеко от 0xFFFF

    ; === ЭТАП 2: РАБОЧЕЕ ПРОГРАММИРОВАНИЕ НА КВАНТ 20 МС (50 ГЦ) ===
    ; Канал 0, Чтение/Запись LSB/MSB, Режим 3 (Генератор меандра)
    MVI  A, PIT_CW_CH0_M3           ; 036H
    OUT  SYS_PIT_CMD
    
    ; Прошиваем канонический делитель 20 000 (4E20H) строго по ТУ: LSB -> MSB
    MVI  A, 020H                    ; Младший байт делителя (0x20)
    OUT  SYS_PIT_CH0
    MVI  A, 04EH                    ; Старший байт делителя (0x4E)
    OUT  SYS_PIT_CH0

    POP  H
    POP  D
    POP  B                          ; Полное восстановление оригинального контекста РОН
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Таймер успешно запущен)
    RET

_hw_sys_pit_fail:
    POP  H
    POP  D
    POP  B
    STC                             ; CY = 1 (провал)
    RET

; =============================================================================
; УНИВЕРСАЛЬНАЯ АППАРАТНАЯ ЗАГЛУШКА ЯДРА (СЛОТЫ IRQ0 - IRQ7 И ЛОЖНЫЕ ТИКИ)
; =============================================================================
hw_stub:
    ; Вход: Сюда процессор прыгает при срабатывании пустых IRQ,
    ;       Либо при перенаправлении ложного (Spurious IRQ) тика IRQ7 из Violation.
    ; Внимание: Если мы пришли сюда по ложному тику с адреса 0x007C (после JZ),
    ; регистры и стек Ring 3 находятся в идеальной чистоте, PUSH-данных нет!

    PUSH PSW                        ; Сохраняем аккумулятор на время отправки EOI
    
    ; Проверим, как именно мы сюда попали: если ISR пуст — это ложный тик
    MVI  A, 00BH
    OUT  MASTER_8259_CMD
    IN   MASTER_8259_CMD            ; Читаем актуальное состояние регистра ISR
    CPI  00H
    JZ   hw_stub_exit               ; Если ISR полностью пуст — это ложный тик, EOI не шлем

    ; Это легитимное пустое прерывание от линий IRQ0-IRQ7 — шлем неспецифический EOI
    MVI  A, 020H
    OUT  MASTER_8259_CMD

hw_stub_exit:
    POP  PSW                        ; Восстановили аккумулятор
    EI                              ; Снова разрешаем аппаратную карусель прерываний в Ring 3
    RET                             ; Возврат к прерванной кодовой строке пользователя
#include "./kernel/tty_core.asm"
;*
;[User Space (Ring 3)]
;└── write(fd, buf, len) / read(fd, buf, len)
;     │
;     ▼ (Аппаратное прерывание INT / RST 6)
;[Шлюз Системных Вызовов (Ring 0)]
;└── sys_call_entry (main.asm)
;     ├── sys_write (sys_io.asm) ──► vfs_chrdev_write (chrdev.asm) ──┐
;     └── sys_read  (sys_io.asm) ──► vfs_chrdev_read  (chrdev.asm) ──┤
;                                                                    │
;    ┌───────────────────────────────────────────────────────────────┘
;    ▼ (Динамическая индексация по таблице SYS_CHRDEV_SWITCH [MAJOR_TTY = 4])
;[Коммутационный слой VFS -> HAL Мосты]
;     ├── tty_write_bridge (tty.asm) [inline расчет: Minor * 160]
;     │    └── Физический косвенный вызов через PCHL драйвера (из хвоста слота TTY)
;     │         ├── hw_i8251_put_char (hw_i8251.asm) ──► [ Кремний КР580ВВ51А ]
;     │         └── hw_ns16550_put_char (hw_ns16550.asm) ──► [ Кремний NS16550 ]
;     │
;     └── tty_read_bridge (tty.asm) [inline расчет: Minor * 160]
;          └── Атомарное извлечение байта (под DI/EI) из ОЗУ Ring 0
;               └── TTY_TABLE[Minor].O_TTY_RX_BUFFER
;*
; =============================================================================
; /kernel/tty_core.asm - ИСПОЛНЯЕМЫЙ КОД ПОДСИС ТЕМЫ ТЕРМИНАЛЬНОГО ДВИЖКА ЯДРА
; =============================================================================
; =============================================================================
; НАЗВАНИЕ: tty_core.asm (Инициализация структур ОЗУ массива TTY)
; =============================================================================
k_tty_subsys_init:
    ; Вход:  Cold Boot, Ring 0, прерывания гарантированно заперты (DI).
    ; Задача: Полностью очистить и инициализировать все 4 независимых TTY-слота
    ;         внутри TTY_TABLE каноническими стартовыми значениями.
    
    LXI  H, TTY_TABLE               ; HL = Базовый физический адрес старта массива TTY
    MVI  B, MAX_TTY_DEVS            ; B = Счетчик внешнего цикла (4 консоли)

_tty_quad_alignment_loop:
    PUSH H                          ; Сохранили базовый адрес начала текущего 160-байтового слота

    ; --- ЭТАП 1: Полное предварительное зануление всего 160-байтового слота TTY ---
    MVI  C, TTY_STRUCT_SIZE         ; C = 160 байт
_tty_clear_row_loop:
    MVI  M, 00H
    INX  H
    DCR  C
    JNZ  _tty_clear_row_loop

    ; --- ЭТАП 2: Точечная инициализация POSIX атрибутов слота ---
    POP  H                          ; HL = Восстановили базовый адрес текущего TTY слота
    PUSH H                          ; Отложили на стек для перехода к следующей строке

    ; Прописываем O_TTY_C_IFLAG (+134) из дефолтных констант tty.inc
    LXI  D, O_TTY_C_IFLAG
    DAD  D                          ; HL -> Поле O_TTY_C_IFLAG (+134)
    MVI  M, DEF_C_IFLAG
    
    ; Прописываем O_TTY_C_OFLAG (+135) из дефолтных констант tty.inc
    INX  H                          ; HL -> Поле O_TTY_C_OFLAG (+135)
    MVI  M, DEF_C_OFLAG
    
    ; Прописываем O_TTY_C_LFLAG (+136) из дефолтных констант tty.inc
    INX  H                          ; HL -> Поле O_TTY_C_LFLAG (+136)
    MVI  M, DEF_C_LFLAG

    ; Инициализируем 8 байт массива управляющих символов O_TTY_C_CC (+137..+144)
    INX  H                          ; HL -> O_TTY_C_CC[VEOF] (+137)
    MVI  M, DEF_VEOF                ; Ctrl+D
    INX  H
    MVI  M, DEF_VEOL                ; \n
    INX  H
    MVI  M, DEF_VERASE              ; Backspace
    INX  H
    MVI  M, DEF_VKILL               ; Ctrl+U
    INX  H
    MVI  M, DEF_VINTR               ; Ctrl+C
    INX  H
    MVI  M, DEF_VQUIT               ; Ctrl+\
    INX  H
    MVI  M, DEF_VSTART              ; Ctrl+Q
    INX  H
    MVI  M, DEF_VSTOP               ; Ctrl+S

    ; Извлекаем чистую базу слота, чтобы исключить накопление ошибок INX H
    POP  H
    PUSH H
    LXI  D, O_TTY_WAIT_PID
    DAD  D                          ; HL -> Указывает точно на поле O_TTY_WAIT_PID (+145)
    MVI  M, UNBOUND_WAIT_PID        ; Зафиксировали 0xFF
    
    ; Явная инициализация группы переднего плана по строгому смещению структуры
    POP  H
    PUSH H
    LXI  D, O_TTY_PGRP
    DAD  D                          ; HL -> Указывает точно на поле O_TTY_PGRP (+147)
    MVI  M, UNBOUND_WAIT_PID        ; Зафиксировали 0xFF (Группа переднего плана отвязана)

    ; --- ЭТАП 3: Шаг к следующему TTY слоту таблицы ---
    POP  H                          ; HL = Базовый адрес текущего TTY слота
    LXI  D, TTY_STRUCT_SIZE         ; Сдвиг равен ровно 160 байтам (00A0h)
    DAD  D                          ; HL указывает строго на старт следующей TTY структуры
    
    DCR  B                          ; Уменьшаем счётчик сконфигурированных консолей
    JNZ  _tty_quad_alignment_loop   ; Повторяем цикл, пока не настроим все 4 терминала
    
    RET                             ; Возврат в k_power_on_init

; =============================================================================
; НАЗВАНИЕ: tty.asm (Диспетчер последовательной сборки активных TTY-слотов)
; =============================================================================
; =============================================================================
; НАЗВАНИЕ: tty.asm (Инстанцирующий диспетчер последовательной сборки карусели)
; ТОКЕН:    TOKEN::MEGA-580_OS_v1.5.81_K_TTY_CAROUSEL_INSTANCED_BUILD_20260709
; =============================================================================

; =============================================================================
; ПРОЦЕДУРА: k_tty_carousel_auto_build
; Вход:  Cold Boot, Ring 0, прерывания гарантированно заперты (DI).
; Задача: Перебрать все 4 физических порта, протестировать наличие железа
;         с приоритетом КР580ВВ51А, и связать их с ОЗУ-структурами ПОСЛЕДОВАТЕЛЬНО
;         методом SMC-инстанцирования базы в тела обработчиков прерываний.
; Выход: Все РОН полностью сохранены. Прерывания заперты.
; =============================================================================
k_tty_carousel_auto_build:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли контекст супервизора Ring 0

    ; Инициализируем динамический указатель целевого логического TTY-слота
    LXI  D, TTY_TABLE               ; DE = Текущий свободный слот ОЗУ (на старте TTY0)

    ; --- ТЕСТИРОВАНИЕ АДРЕСА ПОРТА 0xA0 ---
    MVI  A, 0A0H
    CALL _tty_probe_hardware_gate
    
    ; --- ТЕСТИРОВАНИЕ АДРЕСА ПОРТА 0xB0 ---
    MVI  A, 0B0H
    CALL _tty_probe_hardware_gate
    
    ; --- ТЕСТИРОВАНИЕ АДРЕСА ПОРТА 0xC0 ---
    MVI  A, 0C0H
    CALL _tty_probe_hardware_gate
    
    ; --- ТЕСТИРОВАНИЕ АДРЕСА ПОРТА 0xD0 ---
    MVI  A, 0D0H
    CALL _tty_probe_hardware_gate

    POP  H
    POP  D
    POP  B                          ; Полное восстановление РОН супервизора
    RET

; =============================================================================
; ПОДПРОГРАММА: _tty_probe_hardware_gate
; Вход:  DE = Физический адрес ТЕКУЩЕГО СВОБОДНОГО TTY-слота в ОЗУ ядра
;        A  = Проверяемый физический базовый порт (0xA0, 0xB0, 0xC0, 0xD0)
; =============================================================================
_tty_probe_hardware_gate:
    PUSH B
    PUSH H                          ; Сохранили контекст текущего шага сканирования
    PUSH PSW                        ; Спасли проверяемый порт на стек

    ; 1. Временно прописываем порт и дефолтные делители в текущий свободный слот DE
    MOV  H, D
    MOV  L, E                       ; HL = Текущий свободный слот ОЗУ
    PUSH H                          ; Запомнили базу структуры
    LXI  B, O_TTY_HW_BASE_PORT
    DAD  B                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  M, A                       ; Записали тестируемый порт
    
    INX  H                          ; HL -> O_TTY_HW_DIV_LOW (+156)
    MVI  M, 00CH                    ; Дефолт speed = 9600 бод (делитель 12)
    INX  H                          ; HL -> O_TTY_HW_DIV_HIGH (+157)
    MVI  M, 00H
    POP  H                          ; HL = Восстановили чистую базу слота

    ; 2. ПРИОРИТЕТНЫЙ ТЕСТ №1: Двухчиповый автоопрос КР580ВВ51А + КР580ВИ53
    CALL hw_i8251_init              ; Запуск физического инициализатора. Сохраняет DE!
    JNC  _gate_i8251_found          ; CY=0 -> Нашли стабильную связку ВВ51!

    ; 3. РЕЗЕРВНЫЙ ТЕСТ №2: Автоопрос чипа NS16550 (Если ВВ51 ответил ошибкой)
    CALL hw_ns16550_init            ; Запуск инициализатора 16550. Сохраняет DE!
    JNC  _gate_ns16550_found        ; CY=0 -> Нашли альтернативный 16550!

    ; 4. АППАРАТНАЯ ПУСТОТА: Ни одного чипа на этом адресе нет
    POP  PSW                        ; Очистили стек от сохраненного порта
    POP  H
    POP  B                          ; Восстановили РОН. DE ОСТАЛСЯ НА МЕСТЕ!
    RET                             ; Слот DE будет перезаписан следующим физическим портом

_gate_i8251_found:
    ; === СВЯЗКА КР580ВВ51А + КР580ВИ53 НАЙДЕНА! ВНЕДРЯЕМ SMC-ИНСТАНС БАЗЫ ===
    ; Нам нужно прошить адрес слота (из пары DE) в операнд инструкции LXI D внутри ISR.
    ; Адрес команды: _smc_isr_51_base. Операнд младшего байта: +1, старшего: +2.
    MOV  A, E                       ; А = Младший байт физического адреса ОЗУ-слота
    STA  _smc_isr_51_base + 1       ; Атомарно прошили младший байт операнда LXI D! [1.3]
    MOV  A, D                       ; А = Старший байт физического адреса ОЗУ-слота
    STA  _smc_isr_51_base + 2       ; Атомарно прошили старший байт операнда LXI D! [1.3]

    ; Физический адрес базы ОЗУ-слота жестко вплавлен в код обработчика. Регистрируем вектор:
    POP  PSW                        ; Восстановили базовый порт в аккумулятор А
    CALL _gate_calculate_irq        ; Вычислили номер IRQ-линии ВН59 (А = 1..4)
    
    LXI  H, hw_i8251_isr            ; HL = Адрес индивидуального быстрого ISR драйвера ВВ51
    CALL k_register_isr             ; Пропатчили CALL-вектор ВН59 и открыли линию! [1.3]
    JMP  _gate_slot_allocated       ; Слот успешно занят, уходим на сдвиг указателя ОЗУ

_gate_ns16550_found:
    ; === МИКРОСХЕМА NS16550 НАЙДЕНА! ВНЕДРЯЕМ SMC-ИНСТАНС БАЗЫ ===
    ; Прошиваем адрес слота (из пары DE) в операнд LXI D обработчика hw_ns16550_isr.
    ; Адрес команды: _smc_isr_ns_base. Операнд младшего байта: +1, старшего: +2.
    MOV  A, E                       ; А = Младший байт физического адреса ОЗУ-слота
    STA  _smc_isr_ns_base + 1       ; Атомарно прошили младший байт операнда LXI D! [1.3]
    MOV  A, D                       ; А = Старший байт физического адреса ОЗУ-слота
    STA  _smc_isr_ns_base + 2       ; Атомарно прошили старший байт операнда LXI D! [1.3]

    ; Физический адрес базы ОЗУ-слота жестко вплавлен в код обработчика. Регистрируем вектор:
    POP  PSW                        ; Восстановили базовый порт в аккумулятор А
    CALL _gate_calculate_irq        ; Вычислили номер IRQ-линии ВН59 (А = 1..4)
    
    LXI  H, hw_ns16550_isr          ; HL = Адрес индивидуального быстрого ISR драйвера 16550
    CALL k_register_isr             ; Пропатчили CALL-вектор ВН59 и открыли линию! [1.3]

_gate_slot_allocated:
    ; === СДВИГ УКАЗАТЕЛЯ: ЛОГИЧЕСКИЙ СЛOТ УСПЕШНО ЗАНЯТ, ШАГАЕМ ВПЕРЕД ===
    MOV  H, D
    MOV  L, E                       ; HL = Текущий занятый слот
    LXI  D, TTY_STRUCT_SIZE         ; DE = 160 (00A0H) — шаг структуры слота [1.3]
    DAD  D                          ; HL = HL + 160 (Адрес следующего чистого ОЗУ-слота таблицы)
    
    XCHG                            ; DE = Указатель на следующий СВОБОДНЫЙ логический слот ОЗУ!
    
    POP  H
    POP  B                          ; Полностью восстановили контекст текущей итерации
    RET

; =============================================================================
; ПОДПРОГРАММА: _gate_calculate_irq
; Вход:  A = Базовый физический порт данных консоли (0xA0, 0xB0, 0xC0, 0xD0)
; Выход: A = Номер соответствующей аппаратной линии прерывания IRQ (1..4)
; =============================================================================
_gate_calculate_irq:
    CPI  0A0H
	JNZ _g_irq_b0
	MVI A, 1
	RET
_g_irq_b0:
    CPI  0B0H
	JNZ _g_irq_c0
	MVI A, 2
	RET
_g_irq_c0:
    CPI  0C0H
	JNZ _g_irq_d0
	MVI A, 3
	RET
_g_irq_d0:
    MVI  A, 4
	RET

; =============================================================================
; НАЗВАНИЕ: tty.asm (Авторегистратор TTY-драйвера в коммутаторе VFS)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль ТЕРМИНАЛОВ
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: k_tty_register_vfs
; Вход:  Cold Boot, Ring 0, прерывания заперты (DI).
; Задача: Зарегистрировать HAL-мосты чтения/записи подсистемы терминалов
;         в глобальной таблице SYS_CHRDEV_SWITCH под MAJOR-номером 4 (MAJOR_TTY).
; Выход: CY = 0 — Успех. Класс терминалов интегрирован в коммутатор VFS.
;        CY = 1 — Критическая ошибка: Неверный Major-номер (Защита границ таблицы).
;        Все РОН (BC, DE, HL) полностью сохранены по контракту LIFO.
; =============================================================================
k_tty_register_vfs:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    ; --- ЭТАП 1: ПОДГOТOВКА ПАРАМЕТРOВ ДЛЯ СИСТЕМНОГO РЕГИСТРАТOРА VFS ---
    MVI  A, MAJOR_TTY               ; А  = MAJOR_TTY (Константа 4 из tty.inc) [1.3]
    LXI  H, tty_write_bridge         ; HL = Физический адрес HAL-моста записи TTY [1.3]
    LXI  D, tty_read_bridge          ; DE = Физический адрес HAL-моста чтения TTY [1.3]

    ; --- ЭТАП 2: АТОМАРНАЯ СВЯЗКА В ОЗУ ТАБЛИЦЕ ДРАЙВЕРOВ ЯДРА ---
    CALL k_register_chrdev          ; Вызов Plug-and-Play регистратора VFS [1.3]
                                    ; (При успехе возвращает CY=0, при ошибке границ — CY=1)
    
    ; Перехват ошибки границ таблицы Major-номеров (<32)
    JC   _k_tty_reg_vfs_fault

    ; --- ЭТАП 3: КАНOНИЧЕСКOЕ ВОССТАНОВЛЕНИЕ КОНТЕКСТА (УСПЕХ) ---
    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление РОН по LIFO
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Полный успех операции)
    RET

; =============================================================================
; КАНАЛ АВАРИЙНОГО ВОЗВРАТА ОШИБКИ
; =============================================================================
_k_tty_reg_vfs_fault:
    POP  H
    POP  D
    POP  B                          ; Зеркально разгрузили оригинальный РОН-кадр со стека
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Провал коммутации)
    RET

; =============================================================================
; НАЗВАНИЕ: tty.asm (Канонический HAL-мост отправки TTY_WRITE_BRIDGE)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль ТЕРМИНАЛОВ
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: tty_write_bridge
; Вход:  А  = Выводимый ASCII-символ.
;        B  = Номер Minor (0..3), полученный от коммутатора символьных устройств.
; Задача: По Minor-номеру мгновенно вычислить адрес ОЗУ-структуры TTY слота,
;         извлечь из неё адрес физического метода put_char конкретного чипа 
;         и выполнить косвенный переход по трюку PCHL.
; Выход: Все РОН (BC, DE, HL) полностью сохранены согласно контракту Варианта B.
; =============================================================================
tty_write_bridge:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    MOV  C, A                       ; C = ЭВАКУАЦИЯ: сохранили выводимый символ от разрушения

    ; === ЭТАП 1: МГНОВЕННЫЙ 16-БИТНЫЙ РАСЧЕТ АДРЕСА TTY-СТРУКТУРЫ ===
    MOV  A, B                       ; А = Minor (0..3)
    MOV  L, A
    MVI  H, 00H                     ; HL = Minor (0000H .. 0003H)
    
    ; Быстрое умножение Minor на 160 через сдвиги i8080: (Minor * 128) + (Minor * 32)
    DAD  H
	DAD  H
	DAD  H
	DAD  H
	DAD  H ; HL = Minor * 32
    XCHG                             ; DE = Minor * 32
    DAD  H
	DAD  H                  ; HL = (Minor * 32) * 4 = Minor * 128
    DAD  D                           ; HL = (Minor * 128) + (Minor * 32) = Minor * 160
    
    LXI  D, TTY_TABLE               ; Символический релоцируемый адрес начала таблицы
    DAD  D                           ; HL = Физический адрес структуры активного TTY-слота!
    XCHG                             ; DE = Зафиксировали базу TTY-структуры в паре DE [1.3]

    ; === ЭТАП 2: ИЗВЛЕЧЕНИЕ ФИЗИЧЕСКОГО ВЕКТОРА ДРАЙВЕРА ИЗ ХВОСТА СЛOТА ===
    MOV  H, D
    MOV  L, E                       ; HL = Перенесли базу слота в HL для DAD-индексации
    LXI  B, O_TTY_HW_PUT_CHAR       ; Смещение к указателю метода отправки (+158)
    DAD  B                           ; HL -> Точный адрес ячейки памяти метода драйвера
    
    MOV  A, M
    INX  H
    MOV  H, M
    MOV  L, A                       ; HL = Истинный физический адрес hw_i8251_put_char / 16550

    ; === ЭТАП 3: ВОССТАНОВЛЕНИЕ КОНТРАКТА И КОСВЕННЫЙ ВЫСТРЕЛ ЧЕРЕЗ PCHL ===
    MOV  A, C                       ; А = Восстановили выводимый ASCII-символ
    ; Регистровая пара DE содержит истинный базовый адрес TTY-структуры для драйвера
    
    LXI  B, _tty_wr_bridge_ret      ; Вручную затолкнули адрес возврата в стек супервизора
    PUSH B
    PCHL                             ; Прыжок на исполнение в тело физического put_char чипа!

_tty_wr_bridge_ret:
    POP  H
    POP  D
    POP  B                          ; Идеальное каноническое восстановление РОН по LIFO
    RET

; =============================================================================
; НАЗВАНИЕ: tty.asm (Канонический HAL-мост приема TTY_READ_BRIDGE)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль ТЕРМИНАЛОВ
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: tty_read_bridge
; Вход:  B  = Номер Minor (0..3), полученный от коммутатора символьных устройств.
; Задача: Локализовать ОЗУ-структуру TTY слота, атомарно (под DI/EI) проверить
;         наличие данных в O_TTY_RX_COUNT. Если есть — извлечь байт по RX_TAIL,
;         инкрементировать индекс с зацикливанием и обновить счетчик.
; Выход: А  = Принятый ASCII-символ (Если буфер пуст — возвращает 00H).
;        Все остальные РОН (BC, DE, HL) полностью сохранены по контракту.
; =============================================================================
tty_read_bridge:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    ; === ЭТАП 1: МГНОВЕННЫЙ 16-БИТНЫЙ РАСЧЕТ АДРЕСА TTY-СТРУКТУРЫ ===
    MOV  A, B                       ; А = Minor (0..3)
    MOV  L, A
    MVI  H, 00H                     ; HL = Minor (0000H .. 0003H)
    
    ; Быстрое умножение Minor на 160: (Minor * 128) + (Minor * 32)
    DAD  H
	DAD  H
	DAD  H
	DAD  H
	DAD  H ; HL = Minor * 32
    XCHG                             ; DE = Minor * 32
    DAD  H
	DAD  H                  ; HL = (Minor * 32) * 4 = Minor * 128
    DAD  D                           ; HL = (Minor * 128) + (Minor * 32) = Minor * 160
    
    LXI  D, TTY_TABLE               ; Релоцируемый адрес начала таблицы слотов
    DAD  D                           ; HL = Физический адрес структуры активного TTY-слота!
    XCHG                             ; DE = Зафиксировали базу TTY-структуры в паре DE

    ; === ЭТАП 2: КОНТРОЛЬ НАЛИЧИЯ ДАННЫХ ПОД ЗАЩИТОЙ КРИТИЧЕСКОЙ СЕКЦИИ ===
    DI                              ; Заперли прерывания! Защита от коллизии с ISR [1.3]
    
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  B, O_TTY_RX_COUNT
    DAD  B                          ; HL -> O_TTY_RX_COUNT
    MOV  A, M
    ORA  A                          ; RX_COUNT == 0 (Очередь приема ОЗУ пуста)?
    JZ   _tty_rd_buffer_empty       ; Да — уходим на безопасный неблокирующий выход

    ; === ЭТАП 3: ВЫБОРКА СИМВОЛА ИЗ КОЛЬЦЕВОГО БУФЕРА ===
    DCX  H                          ; HL -> O_TTY_RX_TAIL (Смещение +1)
    MOV  C, M                       ; C = RX_TAIL_old (Текущий индекс чтения)
    
    ; Инкремент и циклический заворот указателя чтения в памяти ядра
    INR  M                          ; RX_TAIL++
    MOV  A, M
    CPI  TTY_BUF_SIZE               ; Достигли физического края кольца (64 байта)?
    JC   _tty_rd_no_wrap
    MVI  M, 00H                     ; Циклический сброс указателя: TAIL = 0

_tty_rd_no_wrap:
    ; Двухступенчатый расчет физического адреса байта: База + O_TTY_RX_BUFFER + TAIL_old
    MOV  H, D
    MOV  L, E                       ; HL = Восстановили чистую базу TTY-слота
    PUSH D                          ; Спрятали базу слота на стек Ring 0
    LXI  D, O_TTY_RX_BUFFER
    DAD  D                          ; HL = База + O_TTY_RX_BUFFER
    
    MOV  E, C
    MVI  D, 00H                     ; DE = 0000H + RX_TAIL_old
    DAD  D                          ; HL = (База + O_TTY_RX_BUFFER) + RX_TAIL_old! Указатель точен!
    MOV  A, M                       ; А = Истинный ASCII-символ из ОЗУ ядра Ring 0!
    MOV  C, A                       ; C = Временно спрятали символ в регистр C
    POP  D                          ; DE = Восстановили базу TTY-слота

    ; Декремент счетчика непрочитанных символов в структуре слота
    MOV  H, D
    MOV  L, E
    LXI  B, O_TTY_RX_COUNT
    DAD  B                          ; HL -> O_TTY_RX_COUNT
    DCR  M                          ; O_TTY_RX_COUNT--

    EI                              ; Открыли прерывания! Вышли из критической секции [1.3]
    MOV  A, C                       ; А = Символ готов к передаче в коммутатор
    JMP  _tty_rd_exit

_tty_rd_buffer_empty:
    EI                              ; Открыли прерывания перед выходом! [1.3]
    XRA  A                          ; А = 00H (Признак отсутствия символа в неблокирующем режиме)

_tty_rd_exit:
    POP  H
    POP  D
    POP  B                          ; Полное восстановление РОН супервизора по LIFO
    RET

; =============================================================================
; ПРОЦЕДУРА: vfs_mount_tty_nodes
; Вход:  DE = Физический адрес первого СВОБОДНОГО слота TTY в памяти ядра, 
;             вернувшийся после выполнения k_tty_carousel_auto_build.
; Задача: По разнице адресов определить число реально найденных чипов UART,
;         последовательно зарегистрировать для них файлы устройств /dev/ttyX
;         с MAJOR=4 и MINOR=0..3 в RAM-диске VFS.
; Выход: Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
vfs_mount_tty_nodes:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст супервизора Ring 0

    ; === ЭТАП 1: ИСПРАВЛЕННОЕ 16-БИТНОЕ ВЫЧИСЛЕНИЕ ДЕЛЬТЫ АДРЕСОВ ===
    LXI  H, TTY_TABLE
    MOV  A, E
    SUB  L
    MOV  E, A                       ; E = младший байт дельты
    MOV  A, D
    SBB  H                          ; A = старший байт дельты с переносом
    MOV  D, A                       ; DE = 16-битная дельта

    ; === ЭТАП 2: ДЕЛЕНИЕ НА 160 С КАНOНИЧЕСКИМ КОНТРОЛЕМ ПЕРЕНОСА ===
    MVI  B, 0                       ; B = Итоговый счетчик активных Minor (0..4)

_vfs_tty_calc_active:
    MOV  A, E
    ORA  D
    JZ   _vfs_tty_mount_start       ; Если DE = 0, чистый расчет окончен, уходим на монтаж
    
    LXI  H, -160                    ; HL = 0xFF60 (Дополнительный код числа 160)
    DAD  D                          ; HL = DE - 160
    
    ; ИСПРАВЛЕНО: Если CY=0, значит DE было меньше 160 (заем бита). 
    ; Это признак завершения деления либо остаточная ошибка выравнивания ОЗУ!
    JNC  _vfs_tty_mount_start       
    
    MOV  D, H
    MOV  E, L                       ; DE = Успешно декрементированная дельта (DE - 160)
    INR  B                          ; Увеличиваем счетчик найденных терминалов
    JMP  _vfs_tty_calc_active

_vfs_tty_mount_start:
    MOV  A, B                       ; A = Общее количество живых терминалов
    ORA  A
    JZ   _vfs_tty_no_uart_panic     ; Если 0 — ни одного UART не найдено (Kernel Panic!)
    MOV  C, A                       ; C = Лимит цикла монтирования файлов устройств

    MVI  B, 0                       ; B = Текущий монтируемый Minor-номер (0..3)

_vfs_tty_mount_loop:
    PUSH B                          ; ← ИСПРАВЛЕНО: Сохраняем ВСЮ пару BC на стек!
                                    ; [Стек: B = Minor, C = Оставшийся лимит цикла]

    ; Подготавливаем параметры для системного вызова vfs_mknod()
    MOV  A, B                       ; A = Текущий Minor (0..3)
    CALL _vfs_tty_get_string_ptr    ; Выход: DE = Адрес ASCIIZ-строки пути
    
    MVI  C, 4                       ; MAJOR_TTY = 4 
    ; Регистр B по-прежнему содержит текущий Minor-номер
    
    CALL vfs_mknod                  ; Создаем специальный символьный Inode в VFS [1.3]

    POP  B                          ; ← ИСПРАВЛЕНО: Извлекаем ВСЮ пару BC со стека!
                                    ; Теперь B = наш Minor, C = наш лимит цикла
    INR  B                          ; Переходим к следующему Minor (Minor++)
    DCR  C                          ; Уменьшаем счетчик оставшихся проходов (Лимит--)
    JNZ  _vfs_tty_mount_loop        ; Цикл продолжается, пока C != 0
    
    POP  H
    POP  D
    POP  B                          ; Полное восстановление оригинального РОН-контекста
    RET

_vfs_tty_no_uart_panic:
    LXI  H, _vfs_tty_panic_msg_no_uart
    JMP  kernel_panic_no_tty           ; Намертво вешаем систему — нет консоли вывода

kernel_panic_no_tty:
	; Фатальная ошибка старта: TTY0 не найден.
    ; Выключаем прерывания и намертво вешаем процессор.
    DI
    HLT
	JMP  kernel_panic_no_tty

; =============================================================================
; ПОДПРОГРАММА: _vfs_tty_get_string_ptr (ИЗОЛИРОВАННАЯ С ПРОВЕРКОЙ ГРАНИЦ)
; Вход:  A = Номер Minor (0..3)
; Выход: DE = Физический адрес ASCIIZ-строки пути устройства
; =============================================================================
_vfs_tty_get_string_ptr:
    CPI  0
	JZ  _vfs_tty_ret_dev0
    CPI  1
	JZ  _vfs_tty_ret_dev1
    CPI  2
	JZ  _vfs_tty_ret_dev2
    CPI  3
	JZ  _vfs_tty_ret_dev3
    
    ; Перехват критической коллизии: A > 3 — индекс разрушен!
    LXI  H, _vfs_tty_panic_msg_inv_minor
    JMP  kernel_panic_tty_indx_err

_vfs_tty_ret_dev0:
    LXI  D, _vfs_tty_str_dev0
	RET
_vfs_tty_ret_dev1:
    LXI  D, _vfs_tty_str_dev1
	RET
_vfs_tty_ret_dev2:
    LXI  D, _vfs_tty_str_dev2
	RET
_vfs_tty_ret_dev3:
    LXI  D, _vfs_tty_str_dev3
	RET

kernel_panic_tty_indx_err:
	; Фатальная ошибка старта: Нарушение структуры TTY.
    ; Выключаем прерывания и намертво вешаем процессор.
    DI
    HLT
	JMP  kernel_panic_tty_indx_err

; --- Изолированные статические системные ASCIIZ-строки (Секция ROM VFS) ---
_vfs_tty_str_dev0:              DB  "/dev/tty0", 0
_vfs_tty_str_dev1:              DB  "/dev/tty1", 0
_vfs_tty_str_dev2:              DB  "/dev/tty2", 0
_vfs_tty_str_dev3:              DB  "/dev/tty3", 0
_vfs_tty_panic_msg_no_uart:     DB  "VFS CRITICAL: NO ACTIVE UART DEVICES FOUND!", 0
_vfs_tty_panic_msg_inv_minor:   DB  "VFS CRITICAL: INVALID TTY MINOR NUMBER!", 0


#include "./kernel/hw_i8251.asm"
;HAL-функции для КР580ВВ51А: hw_i8251_poll_status, hw_i8251_put_char, hw_i8251_get_char
; -----------------------------------------------------------------------------
; Инициализация USART КР580ВВ51А (9600,8N1, фактор K=16)
; -----------------------------------------------------------------------------
; =============================================================================
; ПРОЦЕДУРА: hw_i8251_init (ПОЛНАЯ ВЕРСИЯ С ДВУХЧИПОВЫМ АВТОДЕТЕКТОМ ВВ51+ВИ53)
; Вход:  DE = Физический адрес обрабатываемого TTY-слота (TTY0..TTY3).
; Выход: CY = 0 — Успех, ОБА чипа (ВВ51 и ВИ53) найдены и инициализированы.
;        CY = 1 — Отсутствует ВВ51 или отсутствует/неисправен ВИ53.
; =============================================================================
hw_i8251_init:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст супервизора Ring 0

    ; --- ЭТАП 0: ДИНАМИЧЕСКОЕ ИЗВЛЕЧЕНИЕ ПАРАМЕТРОВ ИЗ СЛOТА ---
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    
    PUSH H
    LXI  B, O_TTY_HW_BASE_PORT
    DAD  B                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  C, M                       ; C = BASE_PORT данных чипа
    
    INX  H                          ; HL -> O_TTY_HW_DIV_LOW (+156)
    MOV  B, M                       ; B = DIV_LOW
    
    INX  H                          ; HL -> O_TTY_HW_DIV_HIGH (+157)
    MOV  A, M                       ; A = DIV_HIGH
    MOV  E, A                       ; E = DIV_HIGH
    POP  H                          ; HL = База TTY-слота

    ; --- ЭТАП 1: ВЫЧИСЛЕНИЕ АДРЕСОВ ПОРТОВ И SMC-ПАТЧИНГ ---
    ; 1.1: Командный порт ВВ51А (BASE_PORT + 1)
    MOV  A, C \ INR  A
    STA  _smc_prb_51_cmd + 1
	STA  _smc_prb_51_rst1 + 1
	STA  _smc_prb_51_rst2 + 1
    STA  _smc_prb_51_rst3 + 1
	STA  _smc_prb_51_int_rst + 1
	STA  _smc_prb_51_mode + 1
    STA  _smc_prb_51_start + 1

    ; 1.2: Управляющий порт КР580ВИ53 (BASE_PORT + 5)
    MOV  A, C
	ADI  5
    STA  _smc_prb_pit_cmd0 + 1
	STA  _smc_prb_pit_cmd1 + 1
    STA  _smc_prb_pit_test_cmd + 1
	STA  _smc_prb_pit_latch_cmd + 1

    ; 1.3: Порт Канала 0 ВИ53 (BASE_PORT + 2)
    MOV  A, C \ ADI  2
    STA  _smc_prb_pit_ch0_l + 1
	STA  _smc_prb_pit_ch0_h + 1
    STA  _smc_prb_pit_test_w_l + 1
	STA  _smc_prb_pit_test_w_h + 1
    STA  _smc_prb_pit_test_r_l + 1
	STA  _smc_prb_pit_test_r_h + 1

    ; 1.4: Порт Канала 1 ВИ53 (BASE_PORT + 3)
    MOV  A, C
	ADI  3
    STA  _smc_prb_pit_ch1_l + 1
	STA  _smc_prb_pit_ch1_h + 1

    ; === ЭТАП 1.1: АППАРАТНЫЙ АВТОДЕТЕКТ КР580ВВ51А ===
_smc_prb_51_cmd:
    IN   000H                       ; Читаем статус ВВ51
    CPI  0FFH
    JZ   _i8251_probe_fail_exit     ; Линия пуста — ВВ51 нет!

    ; === ЭТАП 1.2: АППАРАТНЫЙ АВТОДЕТЕКТ КР580ВИ53 (NEW!) ===
    ; Программируем Канал 0: Старший/Младший байт, Режим 0, Двоичный счет (0x30)
    MVI  A, 030H
_smc_prb_pit_test_cmd:
    OUT  000H                       ; Отправили приказ в управляющий порт ВИ53
    
    ; Записываем тестовое число 0xAA55 в Канал 0
    MVI  A, 055H                    ; Младший байт
_smc_prb_pit_test_w_l:
    OUT  000H
    MVI  A, 0AAH                    ; Старший байт
_smc_prb_pit_test_w_h:
    OUT  000H

    ; Команда Latch Counter для Канала 0 (0x00)
    XRA  A
_smc_prb_pit_latch_cmd:
    OUT  000H                       ; Фиксируем рантайм-значение триггера счетчика

    ; Считываем обратно и верифицируем младший байт
_smc_prb_pit_test_r_l:
    IN   000H
    CPI  055H                       
    JNZ  _i8251_probe_fail_exit     ; Не совпало — ВИ53 отсутствует или неисправен!

    ; Считываем обратно и верифицируем старший байт
_smc_prb_pit_test_r_h:
    IN   000H
    CPI  0AAH
    JNZ  _i8251_probe_fail_exit     ; Не совпало — ВИ53 отсутствует!

    ; === ОБА ЧИПА НАЙДЕНЫ И ОПРАШЕНЫ УСПЕШНО — ЗАПУСКАЕМ РАБОЧИЙ РЕЖИМ ===
    ; Инициализация ВВ51А
    XRA  A
_smc_prb_51_rst1:
    OUT  000H
_smc_prb_51_rst2:
	OUT 000H
_smc_prb_51_rst3:
	OUT 000H
    MVI  A, I8251_CMD_RESET
_smc_prb_51_int_rst:
	OUT 000H
	NOP
    MVI  A, I8251_MODE_8N1_X16
_smc_prb_51_mode:
	OUT 000H
	NOP
    MVI  A, I8251_CMD_START
_smc_prb_51_start:
	OUT 000H

    ; Рабочая перепрошивка ВИ53 на заданную в структуре скорость (Режим 3)
    MVI  A, PIT_CW_CH0_M3
_smc_prb_pit_cmd0:
	OUT 000H
    MOV  A, B
_smc_prb_pit_ch0_l:
	OUT 000H
    MOV  A, E
_smc_prb_pit_ch0_h:
	OUT 000H

    MVI  A, PIT_CW_CH1_M3
_smc_prb_pit_cmd1:
	OUT 000H
    MOV  A, B
_smc_prb_pit_ch1_l:
	OUT 000H
    MOV  A, E
_smc_prb_pit_ch1_h:
	OUT 000H

    ; === ЭТАП 2: ПРОШИВКА HAL-ВЕКТОРОВ В СЛОТ DE ===
    MOV  H, D
	MOV  L, E
    PUSH H
    LXI  D, O_TTY_HW_PUT_CHAR
	DAD  D
	LXI D, hw_i8251_put_char
	MOV M, E
	INX H
	MOV M, D
    POP  H
	PUSH H
    LXI  D, O_TTY_HW_GET_CHAR
	DAD  D
	LXI D, hw_i8251_get_char
	MOV M, E
	INX H
	MOV M, D
    POP  H
	PUSH H
    LXI  D, O_TTY_HW_POLL_STAT
	DAD  D
	LXI D, hw_i8251_poll_status
	MOV M, E
	INX H
	MOV M, D
    POP  H
	PUSH H
    LXI  D, O_TTY_HW_CHIP_TYPE
	DAD  D
	MVI M, CHIP_TYPE_I8251
    POP  H

    POP  H
	POP  D
	POP  B        ; Восстановили оригинальный контекст
    ANA  A                          ; CY = 0 (Полный успех детекта)
    RET

_i8251_probe_fail_exit:
    POP  H
	POP  D
	POP  B        ; Восстановили РОН супервизора
    STC                             ; CY = 1 (Авария: ВВ51 или ВИ53 не прошел тест!)
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_i8251_poll_status (ИСПРАВЛЕННАЯ ДИНАМИЧЕСКАЯ ВЕРСИЯ)
; Вход:  DE = Физический адрес 160-байтового TTY-слота (TTY0..TTY3)
; Задача: Считать аппаратный статус чипа ОДИН РАЗ по SMC-порту и вернуть маску HAL
; Выход: А  = Байт системного статуса HAL (биты TTY_HAL_TXRDY, TTY_HAL_RXRDY)
;        Регистры BC, DE, HL полностью сохранены согласно контракту HAL.
; =============================================================================
hw_i8251_poll_status:
    PUSH B
    PUSH H                          ; Сохранили РОН супервизора

    ; --- Извлекаем базовый порт из переданной структуры DE ---
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  B, O_TTY_HW_BASE_PORT
    DAD  B                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  A, M                       ; A = BASE_PORT данных чипа
    INR  A                          ; A = BASE_PORT + 1 (Порт команд/статуса ВВ51А)
    
    ; --- SMC-ПАТЧИНГ: Прошиваем вычисленный порт строго в операнд (+1) ---
    STA  _smc_stat_51_patch + 1

_smc_stat_51_execute:
    ; === СЧИТЫВАЕМ АППАРАТНЫЙ СТАТУС С КРЕМНИЯ РОВНО ОДИН РАЗ ===
    DB   0DBH                       ; Opcode IN
_smc_stat_51_patch:
    DB   000H                       ; Сюда SMC динамически подставит порт команд (BASE+1)
    MOV  B, A                       ; B = Зафиксированный сырой статус чипа ВВ51А

    ; --- АНАЛИЗ БИТА TXRDY (Бит 0 чипа -> Бит 0 HAL) ---
    ANI  I8251_STAT_TXRDY           ; Изолируем бит готовности передатчика
    JZ   _poll_51_check_rx          ; Передатчик занят — на проверку приема
    MVI  C, TTY_HAL_TXRDY           ; C = 01H (Взвели бит TXRDY в маске HAL)
    JMP  _poll_51_analyze_rx
    
_poll_51_check_rx:
    MVI  C, 00H                     ; Передатчик занят, стартовый сброс накопленной маски

_poll_51_analyze_rx:
    ; --- АНАЛИЗ БИТА RXRDY (Бит 1 чипа -> Бит 1 HAL) из ТОГО ЖЕ байта B ---
    MOV  A, B                       ; Восстановили сырой статус из кэша
    ANI  I8251_STAT_RXRDY           ; Изолируем бит готовности приемника
    JZ   _poll_51_exit              ; Данных в FIFO чипа нет — выходим
    
    MOV  A, C                       ; Извлекли накопленную маску HAL
    ORI  TTY_HAL_RXRDY              ; Атомарно взвели Бит 1 (A = A OR 02H)
    MOV  C, A

_poll_51_exit:
    MOV  A, C                       ; Итоговый системный HAL-статус передан в А
    POP  H
    POP  B                          ; Полное восстановление РОН
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_i8251_put_char (ИСПРАВЛЕННАЯ ДИНАМИЧЕСКАЯ ВЕРСИЯ)
; Вход:  A  = ASCII-символ для физической отправки
;        DE = Физический адрес 160-байтового TTY-слота (TTY0..TTY3)
; Задача: Прочитать порт из слота, SMC-патчинг операнда (+1) и отправка байта
; Выход: Все РОН полностью сохранены (включая DE) согласно контракту HAL.
; =============================================================================
hw_i8251_put_char:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст вызова Ring 0
    
    MOV  B, A                       ; B = Временно спрятали выводимый символ

    ; --- Извлекаем базовый порт из структуры TTY-слота ---
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  D, O_TTY_HW_BASE_PORT
    DAD  D                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  A, M                       ; A = реальный физический порт данных чипа (BASE_PORT+0)
    
    ; --- SMC-ПАТЧИНГ: Прошиваем порт строго в операнд (+1) ---
    STA  _smc_put_51_patch + 1

    MOV  A, B                       ; Восстановили символ в аккумулятор
_smc_put_51_execute:
    DB   0D3H                       ; Opcode OUT
_smc_put_51_patch:
    DB   000H                       ; Сюда SMC подставит порт данных (BASE+0)

    POP  H
    POP  D
    POP  B                          ; Восстановили РОН
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_i8251_get_char (ВАРИАНТ B: с сохранением DE)
; Вход:  DE = Физический адрес 160-байтового TTY-слота
; Задача: Прочитать адрес порта из слота, SMC-патчинг и приём байта
; Выход: А  = Принятый ASCII-символ
;        Все остальные РОН полностью сохранены (включая DE — ИСПРАВЛЕНО!)
; =============================================================================
hw_i8251_get_char:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст вызова Ring 0

    ; --- Извлекаем базовый порт из структуры TTY ---
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  D, O_TTY_HW_BASE_PORT
    DAD  D                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  A, M                       ; A = реальный физический порт данных чипа
    
    ; --- SMC-ПАТЧИНГ: прошиваем порт строго в операнд (+1) ---
    STA  _smc_get_51_patch + 1

    ; === Динамическая инструкция IN ===
    DB   0DBH                       ; Opcode IN
_smc_get_51_patch:
    DB   000H                       ; Патчится SMC-кодом выше

    ; === A теперь содержит принятый ASCII-символ ===
    ; Сохраняем символ во временную ячейку памяти ядра
    STA  _temp_get_char             ; ← КРИТИЧЕСКИЙ ФИКС: сохраняем в память

    ; === Каноническое восстановление РОН по LIFO ===
    POP  H                          ; HL = Восстановили оригинальный HL_old
    POP  D                          ; DE = Восстановили оригинальный DE_old
    POP  B                          ; BC = Восстановили оригинальный BC_old

    ; === Возврат символа в аккумулятор ===
    LDA  _temp_get_char             ; ← КРИТИЧЕСКИЙ ФИКС: восстанавливаем символ в A
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_i8251_tx_ctrl (ИСПРАВЛЕННАЯ ДИНАМИЧЕСКАЯ ВЕРСИЯ)
; Вход:  A  = Режим управления (00H = Отключить TxEN, 01H = Включить TxEN)
;        DE = Физический адрес 160-байтового TTY-слота (TTY0..TTY3)
; Задача: Рассчитать порт команд (BASE+1), SMC-патчинг операнда (+1) и выдача слова.
; Выход: Все РОН (включая А и F!) полностью сохранены согласно контракту HAL.
; =============================================================================
hw_i8251_tx_ctrl:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст РОН
    
    MOV  C, A                       ; C = Входной параметр режима (00H или 01H)
    PUSH PSW                        ; Сохранили исходный аккумулятор А и флаги F

    ; --- Извлекаем адрес базового порта из структуры TTY ---
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  D, O_TTY_HW_BASE_PORT
    DAD  D                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  A, M                       ; A = реальный порт данных (BASE_PORT+0)
    INR  A                          ; A = порт команд (BASE_PORT + 1)
    
    ; --- SMC-ПАТЧИНГ: Прошиваем порт строго в операнд (+1) ---
    STA  _smc_ctrl_51_patch + 1

    ; --- Формируем управляющее слово для БИС ---
    MOV  A, C                       ; Восстановили параметр режима
    ORA  A
    JZ   _tx_ctrl_51_disable        ; Если 00H — глушим передатчик

    ; Режим 01H: Включаем передатчик (TxEN=1, RxEN=1, RTS/DTR активны)
    MVI  A, I8251_CMD_START         ; 027H
    JMP  _smc_ctrl_51_execute

_tx_ctrl_51_disable:
    ; Режим 00H: Выключаем передатчик (TxEN=0, RxEN=1, RTS/DTR active)
    MVI  A, 026H                    ; 00100110b

_smc_ctrl_51_execute:
    DB   0D3H                       ; Opcode OUT
_smc_ctrl_51_patch:
    DB   000H                       ; Сюда SMC подставит порт команд (BASE+1)

    POP  PSW                        ; Восстановили оригинальный А и флаги F
    POP  H
    POP  D
    POP  B                          ; Полное восстановление РОН
    RET

; =============================================================================
; НАЗВАНИЕ: hw_i8251.asm (Специализированный монолитный ISR для КР580ВВ51А)
; Вход:  Аппаратный CALL по вектору IRQ от КР580ВН59. Прерывания заперты (DI).
;        Состояние РОН и SP — случайное (из прерванного контекста Ring 3).
; =============================================================================
hw_i8251_isr:
_smc_isr_51_base:
    ; === ЭТАП 0: АППАРАТНЫЙ ПОРТ ПРИВЯЗКИ БАЗЫ (SMC-ИНСТАНС) ===
    LXI  D, 0040H                   ; Опкод 0x11. Сюда карусель при старте ОДИН РАЗ
                                    ; прошьет истинный адрес структуры (например, TTY_TABLE+160).
                                    ; По умолчанию инициализирован безопасным мусором.

    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст прерванного процесса

    ; === ЭТАП 1: ДИНАМИЧЕСКИЙ SMC-РАСЧЕТ ФИЗИЧЕСКИХ ПОРТОВ ВВОДА-ВЫВОДА ===
    MOV  H, D
    MOV  L, E                       ; HL = Истинная рантайм-база выделенного TTY-слота
    LXI  B, O_TTY_HW_BASE_PORT
    DAD  B                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  A, M                       ; A = BASE_PORT данных чипа (0xA0, 0xB0, 0xC0, 0xD0)
    MOV  C, A                       ; C = BASE_PORT данные (например, 0xA0)
    INR  A                          ; A = BASE_PORT + 1 (Порт команд/статуса, например, 0xA1)
    
    ; Прошиваем порты ВВ51А строго в операнды (+1) текущих инструкций ISR
    STA  _isr_51_cmd_in + 1
    STA  _isr_51_cmd_out + 1
    MOV  A, C                       ; A = BASE_PORT данные
    STA  _isr_51_data_in + 1
    STA  _isr_51_data_out + 1      ; Настройка локальных SMC-операндов ввода-вывода завершена!

    ; === ЭТАП 2: АТОМАРНОЕ ЧТЕНИЕ АППАРАТНОГО СТАТУСА (РОВНО ОДИН РАЗ) ===
_isr_51_cmd_in:
    IN   000H                       ; Считали сырой статус БИС. Патчится на (BASE+1)
    MOV  B, A                       ; B = Локальный кэш сырого статуса чипа

    ; === ЭТАП 3: Rx-ВЕТКА (ПРИЕМ ASCII-СИМВОЛА) ===
    MOV  A, B
    ANI  I8251_STAT_RXRDY           ; Изолируем Бит 1 (RxRDY чипа)
    JZ   _isr_51_rx_done            ; Приемник пуст — шагаем к передатчику

_isr_51_data_in:
    IN   000H                       ; Считали байт из кремния. Патчится на (BASE+0)
    MOV  C, A                       ; C = Принятый символ

    PUSH D                          ; Сохранили базу TTY-слота на стек ядра Ring 0
    PUSH B                          ; Сохранили статус (B) и принятый символ (C)

    ; Проверка переполнения кольцевого буфера ОЗУ Ring 0
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  D, O_TTY_RX_COUNT          
    DAD  D                          ; HL -> O_TTY_RX_COUNT
    MOV  A, M
    CPI  TTY_BUF_SIZE               ; Буфер приема ОЗУ переполнен (64 байта)?
    JZ   _isr_51_rx_drop            ; Да — пассивный drop байта (защита памяти ядра)

    ; Буфер свободен — вычисляем индекс записи по HEAD
    DCX  H
    DCX  H                          ; HL -> O_TTY_RX_HEAD
    MOV  A, M                       ; A = RX_HEAD_old
    PUSH PSW                        ; Спасли HEAD_old на стек Ring 0

    INR  M                          ; RX_HEAD++ (Фиксация в памяти)
    MOV  A, M
    CPI  TTY_BUF_SIZE
    JC   _isr_51_rx_no_wrap
    MVI  M, 00H                     ; Циклический заворот HEAD = 0

_isr_51_rx_no_wrap:
    POP  PSW                        ; A = Извлекли сохраненный HEAD_old
    
    ; Канонический двухступенчатый DAD-расчет физического адреса записи
    MOV  H, D
    MOV  L, E                       ; HL = Истинная база TTY-слота
    PUSH D                          ; Спрятали DE
    
    LXI  D, O_TTY_RX_BUFFER
    DAD  D                          ; HL = База_TTY + O_TTY_RX_BUFFER
    
    MOV  E, A
    MVI  D, 00H                     ; DE = HEAD_old
    DAD  D                          ; HL = (База + O_TTY_RX_BUFFER) + HEAD_old! Указатель идеален!
    
    POP  D                          ; Восстановили DE = База TTY-слота
    MOV  M, C                       ; АТОМАРНАЯ ФИКСАЦИЯ: байт лег в ОЗУ Ring 0!

    ; Инкремент общего счетчика непрочитанных символов RX_COUNT
    MOV  H, D
    MOV  L, E
    LXI  D, O_TTY_RX_COUNT
    DAD  D
    INR  M                          ; O_TTY_RX_COUNT++

_isr_51_rx_drop:
    POP  B                          ; Восстановили статус и символ
    POP  D                          ; Восстановили истинную базу TTY-слота

_isr_51_rx_done:

    ; === ЭТАП 4: Tx-ВЕТКА (ОТПРАВКА ASCII-СИМВОЛА) ===
    MOV  A, B                       ; Извлекли сырой статус чипа из кэша
    ANI  I8251_STAT_TXRDY           ; Изолируем Бит 0 (TxRDY чипа)
    JZ   _isr_51_tx_done            ; Чип аппаратно занят — шагаем на выход

    ; Проверяем наличие готовых к выгрузке символов в очереди вывода ОЗУ
    PUSH D                          ; Сохраняем базу на стек
    PUSH B                          ; Сохраняем статус
    
    MOV  H, D
    MOV  L, E
    LXI  D, O_TTY_TX_COUNT
    DAD  D                          ; HL -> O_TTY_TX_COUNT
    MOV  A, M
    ORA  A                          ; TX_COUNT == 0?
    JZ   _isr_51_tx_close           ; Очередь пуста — глушим линию прерывания передатчика!

    ; Очередь ОЗУ содержит данные — извлекаем рантайм-индекс чтения по TAIL
    DCX  H                          ; HL -> O_TTY_TX_TAIL
    MOV  A, M                       ; A = TAIL_old
    PUSH PSW                        ; Спасли TAIL_old на стек
    
    INR  M                          ; TX_TAIL++ (Фиксация в памяти)
    MOV  A, M
    CPI  TTY_BUF_SIZE
    JC   _isr_51_tx_no_wrap
    MVI  M, 00H                     ; Циклический заворот TAIL = 0

_isr_51_tx_no_wrap:
    POP  PSW                        ; A = Извлекли сохраненный TAIL_old
    
    ; Канонический двухступенчатый DAD-расчет физического адреса чтения
    MOV  H, D
    MOV  L, E                       ; HL = Истинная база TTY-слота
    PUSH D                          ; Спрятали DE
    
    LXI  D, O_TTY_TX_BUFFER
    DAD  D                          ; HL = База + O_TTY_TX_BUFFER
    
    MOV  E, A
    MVI  D, 00H                     ; DE = TAIL_old
    DAD  D                          ; HL = (База + O_TTY_TX_BUFFER) + TAIL_old! Указатель точен!
    
    POP  D                          ; Восстановили DE = База TTY-слота
    MOV  A, M                       ; А = ASCII-символ, извлеченный из кольца вывода ОЗУ

_isr_51_data_out:
    OUT  000H                       ; ФИЗИЧЕСКИЙ ВЫСТРЕЛ В КРЕМНИЙ БИС! Патчится на (BASE+0)
    POP  B                          ; Восстановили статус из кэша

    ; Декрементируем счетчик выведенных символов TX_COUNT
    MOV  H, D
    MOV  L, E
    LXI  D, O_TTY_TX_COUNT
    DAD  D
    DCR  M                          ; O_TTY_TX_COUNT--
    
    POP  B                          ; Сбалансировали стек (статус)
    POP  D                          ; Восстановили базу TTY-слота
    JMP  _isr_51_tx_done

_isr_51_tx_close:
    POP  B                          ; Восстановили статус
    POP  D                          ; Восстановили базу TTY-слота
    
    ; Очередь ОЗУ пуста — принудительно прижимаем линию прерывания чипа к нулю!
    MVI  A, 026H                    ; Команда БИС: TxEN = 0, RxEN = 1, RTS/DTR активны
_isr_51_cmd_out:
    OUT  000H                       ; Выстрел в управляющее слово чипа. Патчится на (BASE+1)

_isr_51_tx_done:
    ; === ЭТАП 5: ЗАКРЫТИЕ ТРИГГЕРА ВН59 И СИНХРОННЫЙ ВЫХОД ===
    MVI  A, 020H
    OUT  MASTER_8259_CMD            ; Неспецифический EOI в КР580ВН59
    
    POP  H
    POP  D
    POP  B                          ; Полное восстановление рантайм-контекста РОН
    EI                              ; Разрешили аппаратный конвейер прерываний шины
    RET


#include "./kernel/hw_ns16550.asm"
; =============================================================================
; НАЗВАНИЕ: hw_ns16550.asm (Аппаратный драйвер чипа NS16550 с HAL API)
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: hw_ns16550_init (ВЕРСИЯ С АВТОДЕТЕКТОМ И HAL-РЕГИСТРАЦИЕЙ) 
; Вход:  DE = Физический адрес инициализируемого 160-байтового TTY-слота
;             В слоте должно быть предзаполнено поле O_TTY_HW_BASE_PORT (+155)
; Выход: CY = 0 — Успех, чип найден и инициализирован. Векторы HAL прошиты.
;        CY = 1 — Чип отсутствует на шине. Структура слота не модифицирована.
;        Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
hw_ns16550_init:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст супервизора

    ; --- ЭТАП 0: ИЗВЛЕЧЕНИЕ БАЗОВОГО ПОРТА ---
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  B, O_TTY_HW_BASE_PORT
    DAD  B                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  C, M                       ; C = BASE_PORT

    ; === ЭТАП 1: ТЕСТ НАЛИЧИЯ КРИСТАЛЛА (SCRATCH TEST) ===
    MOV  A, C
    ADI  REG_SCR                    ; A = BASE_PORT + 7
    STA  _smc_probe_scr_out + 1     ; ← ИСПРАВЛЕНО: патчим операнд, не opcode
    STA  _smc_probe_scr_in + 1      ; ← ИСПРАВЛЕНО

    MVI  A, 05AH                    ; Контрольный паттерн
_smc_probe_scr_out:
    OUT  000H                       ; Записали в Scratch-регистр

    NOP                             ; Задержка для стабилизации шины
    NOP

_smc_probe_scr_in:
    IN   000H                       ; Считали обратно
    CPI  05AH
    JNZ  _ns16550_probe_fail        ; Чипа нет на шине

    ; === ЭТАП 2: ПОЛНАЯ ПАСПОРТНАЯ ИНИЦИАЛИЗАЦИЯ ===
    ; Восстановим базу и извлечём делители
    MOV  H, D
    MOV  L, E
    PUSH H                          ; Сохранили базу
    LXI  B, O_TTY_HW_DIV_LOW
    DAD  B
    MOV  B, M                       ; B = DIV_LOW
    INX  H
    MOV  A, M                       ; A = DIV_HIGH
    MOV  E, A                       ; E = DIV_HIGH (защищён)
    POP  H                          ; HL = База

    ; Скорость (DLAB = 1)
    MOV  A, C
    ADI  REG_LCR
    STA  _smc_init_lcr1_p + 1       ; ← ИСПРАВЛЕНО: +1
    MVI  A, LCR_DLAB_ENABLE
_smc_init_lcr1_p:
    OUT  000H

    ; Младший байт делителя
    MOV  A, C
    ADI  REG_DLL
    STA  _smc_init_dll_p + 1        ; ← ИСПРАВЛЕНО: +1
    MOV  A, B                       ; A = DIV_LOW
_smc_init_dll_p:
    OUT  000H

    ; Старший байт делителя
    MOV  A, C
    ADI  REG_DLM
    STA  _smc_init_dlm_p + 1        ; ← ИСПРАВЛЕНО: +1
    MOV  A, E                       ; A = DIV_HIGH (из E)
_smc_init_dlm_p:
    OUT  000H

    ; Режим линии 8N1 и сброс DLAB
    MOV  A, C
    ADI  REG_LCR
    STA  _smc_init_lcr2_p + 1       ; ← ИСПРАВЛЕНО: +1
    MVI  A, LCR_WLS_8BIT OR LCR_STB_1STOP OR LCR_PEN_NO_PARITY
_smc_init_lcr2_p:
    OUT  000H

    ; Включение FIFO
    MOV  A, C
    ADI  REG_FCR
    STA  _smc_init_fcr_p + 1        ; ← ИСПРАВЛЕНО: +1
    MVI  A, FCR_FIFO_ENABLE OR FCR_RX_FIFO_RESET OR FCR_TX_FIFO_RESET
_smc_init_fcr_p:
    OUT  000H

    ; Включение прерываний чипа
    MOV  A, C
    ADI  REG_IER
    STA  _smc_init_ier_p + 1        ; ← ИСПРАВЛЕНО: +1
    MVI  A, IER_ENABLE_RX OR IER_ENABLE_TX OR IER_ENABLE_LSR
_smc_init_ier_p:
    OUT  000H

    ; === ЭТАП 3: ДИНАМИЧЕСКАЯ ПРОШИВКА HAL-ВЕКТОРОВ СТРОГО В СЛOТ DE ===
    ; ИСПРАВЛЕНО: База структуры загружается из незатертого регистра DE!
    MOV  H, D
    MOV  L, E                       ; HL = Истинный адрес слота из пары DE
    
    PUSH H
    LXI  D, O_TTY_HW_PUT_CHAR
	DAD  D
    LXI  D, hw_ns16550_put_char
	MOV M, E
	INX H
	MOV M, D
    POP  H
	PUSH H
    
    LXI  D, O_TTY_HW_GET_CHAR
	DAD  D
    LXI  D, hw_ns16550_get_char
	MOV M, E
	INX H
	MOV M, D
    POP  H
	PUSH H
    
    LXI  D, O_TTY_HW_POLL_STAT
	DAD  D
    LXI  D, hw_ns16550_poll_status
	MOV M, E
	INX H
	MOV M, D
    POP  H
	PUSH H
    
    LXI  D, O_TTY_HW_CHIP_TYPE
	DAD  D
    MVI  M, CHIP_TYPE_NS16550       ; Маркер = 02H
    POP  H

    POP  H
    POP  D
    POP  B                          ; Восстановили РОН супервизора
    ANA  A                          ; CY = 0 (успех)
    RET

_ns16550_probe_fail:
    POP  H
    POP  D
    POP  B                          ; Восстановили РОН
    STC                             ; CY = 1 (устройство отсутствует)
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_ns16550_poll_status (ОПТИМИЗИРОВАНО: ОДНО ЧТЕНИЕ РЕГИСТРА LSR)
; Вход:  DE = Физический адрес 160-байтового TTY-слота
; Задача: Считать Line Status Register (LSR) один раз и транслировать в маски HAL
; Выход: А  = Байт системного статуса HAL (биты TTY_HAL_TXRDY, TTY_HAL_RXRDY)
;        Регистры BC, DE, HL полностью сохранены.
; =============================================================================
hw_ns16550_poll_status:
    PUSH B
    PUSH H                          ; Сохранили РОН супервизора

    ; Извлекаем базовый порт из структуры TTY-слота
    MOV  H, D
    MOV  L, E
    LXI  B, O_TTY_HW_BASE_PORT
    DAD  B
    MOV  A, M                       ; A = BASE_PORT
    ADI  REG_LSR                    ; А = Физический порт регистра LSR (BASE + 5)
    STA  _smc_lsr_patch             ; Динамический патчинг команды IN

_smc_lsr_execute:
    ; === СЧИТЫВАЕМ АППАРАТНЫЙ СТАТУС С ТРИГГЕРА ЖЕЛИЗА РОВНО ОДИН РАЗ ===
    DB   0DBH                       ; Opcode IN
_smc_lsr_patch:
    DB   000H                       ; Сюда SMC подставит адрес регистра LSR
    MOV  B, A                       ; B = Сырой статус чипа 16550

    ; --- Анализ готовности передатчика (Бит 5 LSR - THRE) ---
    ANI  LSR_THRE
    JZ   _lsr_check_rx              ; Если бит 0 — FIFO передатчика занято
    MVI  C, TTY_HAL_TXRDY           ; Накопительный флаг HAL (Бит 0 = 1)
    JMP  _lsr_analyze_rx

_lsr_check_rx:
    MVI  C, 00H                     ; Передатчик занят, стартовый сброс маски HAL

_lsr_analyze_rx:
    ; --- Анализ готовности приемника (Бит 0 LSR - DR) из того же байта ---
    MOV  A, B                       ; Восстановили сохраненный статус из регистра B
    ANI  LSR_DATA_READY
    JZ   _lsr_exit                  ; В FIFO приемника пусто, выходим с текущей маской
    
    MOV  A, C
    ORI  TTY_HAL_RXRDY              ; Взвели бит готовности HAL приемника (Бит 1 = 1)
    MOV  C, A

_lsr_exit:
    MOV  A, C                       ; Результат транслирован в Аккумулятор А
    POP  H
    POP  B                          ; Полное восстановление РОН
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_ns16550_put_char
; Вход:  A  = ASCII-символ для физической отправки
;        DE = Физический адрес 160-байтового TTY-слота
; Задача: Считать адрес порта THR из слота, SMC-патчинг и запись в FIFO
; Выход: Все РОН (включая A+F!) полностью сохранены согласно контракту Варианта B
; =============================================================================
hw_ns16550_put_char:
    PUSH B
    PUSH D
    PUSH H
    MOV  B, A                       ; B = символ

    ; Извлекаем базовый порт (для регистра THR смещение равно 0, BASE_PORT + 0)
    MOV  H, D
    MOV  L, E
    LXI  D, O_TTY_HW_BASE_PORT
    DAD  D
    MOV  A, M                       ; A = BASE_PORT (порт регистра THR)
    STA  _smc_16550_thr_patch       ; SMC-модификация

    MOV  A, B                       ; Восстановили символ в А
_smc_16550_thr_execute:
    DB   0D3H                       ; Opcode OUT
_smc_16550_thr_patch:
    DB   000H                       ; Стреляем байтом прямо во встроенное FIFO чипа!

    POP  H
    POP  D
    POP  B
    RET

; =============================================================================
; ПРОЦЕДУРА: hw_ns16550_get_char
; Вход:  DE = Физический адрес 160-байтового TTY-слота
; Задача: Считать адрес порта RBR из слота, SMC-патчинг и забор байта из FIFO
; Выход: А  = Принятый ASCII-символ. Все остальные РОН полностью сохранены.
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: hw_ns16550_get_char (ПОЛНОСТЬЮ ИСПРАВЛЕННАЯ ЭТАЛОННАЯ ВЕРСИЯ)
; ТОКЕН:    TOKEN::MEGA-580_OS_v1.5.77_HW_NS16550_GET_CHAR_STABLE_20260708
; Вход:  DE = Физический адрес 160-байтового TTY-слота (TTY0..TTY3).
; Задача: Считать базовый порт, выполнить SMC-патчинг операнда (+1) и забрать
;         символ из регистра RBR чипа 16550 без разрушения РОН супервизора.
; Выход: А  = Принятый из FIFO ASCII-символ.
;        Регистры BC, DE, HL полностью сохранены согласно контракту HAL.
; =============================================================================
hw_ns16550_get_char:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст вызова Ring 0 супервизора

    ; --- Извлекаем базовый физический порт данных из структуры слота DE ---
    MOV  H, D
    MOV  L, E                       ; HL = Динамический адрес TTY-слота
    LXI  D, O_TTY_HW_BASE_PORT
    DAD  D                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  A, M                       ; A = BASE_PORT (Порт регистра RBR, смещение 0)
    
    ; --- SMC-ПАТЧИНГ: Прошиваем порт строго во второй байт (операнд +1) ---
    STA  _smc_16550_rbr_execute + 1

_smc_16550_rbr_execute:
    ; === ДИНАМИЧЕСКАЯ ИНСТРУКЦИЯ ВВОДА ИЗ КРЕМНИЯ NS16550 ===
    DB   0DBH                       ; Код операции (Opcode) инструкции IN
    DB   000H                       ; Сюда SMC-команда выше подставит реальный порт (BASE+0)

    ; === ЭВАКУАЦИЯ ПРИНЯТОГО СИМВОЛА В ТЕНЕВУЮ ЯЧЕЙКУ ОЗУ ЯДРА ===
    STA  _temp_ns_get_char          ; Атомарно сохранили символ в локальную память

    ; === КАНОНИЧЕСКОЕ ВОССТАНОВЛЕНИЕ РОН СУПЕРВИЗОРА ПО ИНВАРИАНТУ LIFO ===
    POP  H                          ; HL = Восстановили оригинальный HL_old
    POP  D                          ; DE = Восстановили оригинальный DE_old (База TTY)
    POP  B                          ; BC = Восстановили оригинальный BC_old

    ; === ВЫДАЧА РЕЗУЛЬТАТА В ШЛЮЗ ВОЗВРАТА ===
    LDA  _temp_ns_get_char          ; Аккумулятор А = Истинный принятый символ!
    RET                             ; Безопасный возврат, стек супервизора чист

; =============================================================================
; ПРОЦЕДУРА: hw_ns16550_tx_ctrl (УПРАВЛЕНИЕ МАСКОЙ ПРЕРЫВАНИЙ ПЕРЕДАТЧИКА 16550)
; ТОКЕН:    TOKEN::MEGA-580_OS_v1.5.55_K_HW_16550_TX_CTRL_FIXED_20260707
; Вход:  A  = Режим управления (00H = Запретить Tx-прерывание, 01H = Разрешить)
;        DE = Физический адрес 160-байтового TTY-слота
; Задача: Динамически пересчитать маску регистра IER (BASE+REG_IER) через SMC,
;         выполнив цикл Чтение-Модификация-Запись для сохранения Rx-бит.
; Выход: Все РОН (включая A и F!) полностью сохранены согласно контракту HAL.
; =============================================================================
hw_ns16550_tx_ctrl:
    PUSH B
    PUSH D
    PUSH H                          ; Сохранили контекст РОН супервизора
    
    MOV  C, A                       ; C = входной параметр режима (00H или 01H)
    PUSH PSW                        ; Сохранили исходный аккумулятор А и флаги F на стек

    ; --- ЭТАП 1: ВЫЧИСЛЕНИЕ ФИЗИЧЕСКОГО ПОРТА РЕГИСТРА REG_IER ---
    MOV  H, D
    MOV  L, E                       ; HL = База TTY-слота
    LXI  D, O_TTY_HW_BASE_PORT
    DAD  D                          ; HL -> O_TTY_HW_BASE_PORT (+155)
    MOV  A, M                       ; A = реальный базовый порт (например, 0B0H)
    ADI  REG_IER                    ; A = BASE_PORT + 1 (Порт регистра IER)
    
    ; --- SMC-ПАТЧИНГ: прошиваем вычисленный порт в команды IN и OUT ---
    STA  _smc_16550_ier_in_patch
    STA  _smc_16550_ier_out_patch   ; Модификация кода на лету окончена

    ; --- ЭТАП 2: ЦИКЛ ЧТЕНИЯ ТЕКУЩЕЙ МАСКИ ИЗ КРИСТАЛЛА ---
_smc_16550_ier_in_execute:
    DB   0DBH                       ; Opcode IN
_smc_16550_ier_in_patch:
    DB   000H                       ; Сюда подставится адрес регистра IER
    MOV  B, A                       ; B = текущее аппаратное состояние регистра IER

    ; --- ЭТАП 3: МОДИФИКАЦИЯ БИТА ПРЕРЫВАНИЯ TX (БИТ 1) ---
    MOV  A, C                       ; Восстановили параметр режима (00H или 01H)
    ORA  A
    JZ   _ns16550_tx_disable        ; Если 00H — гасим бит прерывания передатчика

    ; Режим 01H: Атомарно взводим бит IER_ENABLE_TX (Бит 1)
    MOV  A, B
    ORI  IER_ENABLE_TX              ; Взвели Бит 1 (A = B OR 02H)
    JMP  _smc_16550_ier_out_execute

_ns16550_tx_disable:
    ; Режим 00H: Атомарно гасим бит IER_ENABLE_TX через каноничную маску i8080
    ; ИСПРАВЛЕНО: Прямая побитовая маска 0FDH вместо синтаксической ошибки ANI NOT
    MOV  A, B
    ANI  0FDH                       ; 0FDH = 11111101B (Сбросили Бит 1, сохраняя Rx и ошибки)

    ; --- ЭТАП 4: ЗАПИСЬ ОБНОВЛЕННОЙ МАСКИ В КРИСТАЛЛ ---
_smc_16550_ier_out_execute:
    DB   0D3H                       ; Opcode OUT
_smc_16550_ier_out_patch:
    DB   000H                       ; Сюда подставится адрес регистра IER

    ; --- ЭТАП 5: ПОЛНОЕ ВОССТАНОВЛЕНИЕ КОНТЕНТА СОГЛАСНО КОНТРАКТУ ---
    POP  PSW                        ; Восстановили оригинальный А и флаги F
    POP  H
    POP  D
    POP  B                          ; Идеальный баланс РОН супервизора
    RET

; =============================================================================
; НАЗВАНИЕ: hw_ns16550.asm (Специализированный монолитный ISR для чипа NS16550)
; Вход:  Аппаратный CALL по вектору IRQ от КР580ВН59. Прерывания заперты (DI).
;        Состояние РОН и SP — случайное (из прерванного контекста Ring 3).
; =============================================================================
hw_ns16550_isr:
_smc_isr_ns_base:
    LXI  D, 0040H                   ; SMC-инстанс: карусель прошьёт адрес TTY-слота

    PUSH B
    PUSH D
    PUSH H

    ; === ЭТАП 1: SMC-РАСЧЕТ ПОРТОВ ===
    MOV  H, D
    MOV  L, E
    LXI  B, O_TTY_HW_BASE_PORT
    DAD  B
    MOV  C, M                       ; C = BASE_PORT
    
    MOV  A, C
	ADI  2
    STA  _isr_ns_iir_in + 1
    
    MOV  A, C
    STA  _isr_ns_data_in + 1
    STA  _isr_ns_data_out + 1
    
    MOV  A, C
	INR  A
    STA  _isr_ns_ier_in + 1
    STA  _isr_ns_ier_out + 1

    ; === ЭТАП 2: ЧТЕНИЕ IIR ===
_isr_ns_iir_in:
    IN   000H
    ANI  IIR_INT_ID_MASK
    MOV  B, A

    ; === ЭТАП 3: ДЕШИФРАЦИЯ ===
    CPI  IIR_RX_DATA_AVAIL
    JZ   _isr_ns_rx
    CPI  IIR_THR_EMPTY
    JZ   _isr_ns_tx
    CPI  IIR_RX_TIMEOUT
    JZ   _isr_ns_rx
    JMP  _isr_ns_done

_isr_ns_rx:
    ; === ЭТАП 4: Rx-ВЕТКА ===
_isr_ns_data_in:
    IN   000H
    MOV  C, A

    PUSH D
    PUSH B

    MOV  H, D
	MOV  L, E
    LXI  D, O_TTY_RX_COUNT
    DAD  D
    MOV  A, M
    CPI  TTY_BUF_SIZE
    JZ   _isr_ns_rx_drop

    DCX  H
	DCX  H
    MOV  A, M
    PUSH PSW                        ; Сохраняем HEAD_old

    INR  M
    MOV  A, M
	CPI  TTY_BUF_SIZE
	JC   _isr_ns_rx_no_wrap
    MVI  M, 00H

_isr_ns_rx_no_wrap:
    POP  PSW                        ; ← ИСПРАВЛЕНО: только ОДИН POP PSW!
    
    ; Двухступенчатый расчет адреса
    MOV  H, D
	MOV  L, E
    PUSH D
    LXI  D, O_TTY_RX_BUFFER
    DAD  D
    MOV  E, A
	MVI  D, 00H
    DAD  D
    POP  D
    MOV  M, C

    ; Инкремент RX_COUNT
    MOV  H, D
	MOV  L, E
    LXI  D, O_TTY_RX_COUNT
	DAD  D
    INR  M

_isr_ns_rx_drop:
    POP  B
    POP  D
    JMP  _isr_ns_done

_isr_ns_tx:
    ; === ЭТАП 5: Tx-ВЕТКА ===
    PUSH D
    PUSH B

    MOV  H, D
	MOV  L, E
    LXI  D, O_TTY_TX_COUNT
	DAD  D
    MOV  A, M
	ORA  A
    JZ   _isr_ns_tx_close

    DCX  H
    MOV  A, M
    PUSH PSW
    
    INR  M
    MOV  A, M
	CPI  TTY_BUF_SIZE
	JC   _isr_ns_tx_no_wrap
    MVI  M, 00H

_isr_ns_tx_no_wrap:
    POP  PSW
    
    ; Двухступенчатый расчет адреса
    MOV  H, D
	MOV  L, E
    PUSH D
    LXI  D, O_TTY_TX_BUFFER
	DAD  D
    MOV  E, A
	MVI  D, 00H
    DAD  D
    POP  D
    MOV  A, M

_isr_ns_data_out:
    OUT  000H
    POP  B                          ; Восстанавливаем статус

    ; Декремент TX_COUNT
    MOV  H, D
	MOV  L, E
    LXI  D, O_TTY_TX_COUNT
	DAD  D
    DCR  M
    
    POP  D                          ; ← ИСПРАВЛЕНО: только восстановление базы!
    JMP  _isr_ns_done

_isr_ns_tx_close:
    POP  B
    POP  D
    
_isr_ns_ier_in:
    IN   000H
    ANI  0FDH
_isr_ns_ier_out:
    OUT  000H

_isr_ns_done:
    MVI  A, 020H
    OUT  MASTER_8259_CMD

    POP  H
    POP  D
    POP  B
    EI
    RET
#include "./kernel/lp_core.asm"
;*
;[User Space (Ring 3)]
;└── write(fd, buf, len) / read(fd, buf, len)
;     │
;     ▼ (Аппаратное прерывание INT / RST 6)
;[Шлюз Системных Вызовов (Ring 0)]
;└── sys_call_entry (main.asm)
;     ├── sys_write (sys_io.asm) ──► vfs_chrdev_write (chrdev.asm) ──┐
;     └── sys_read  (sys_io.asm) ──► vfs_chrdev_read  (chrdev.asm) ──┤
;                                                                    │
;    ┌───────────────────────────────────────────────────────────────┘
;    ▼ (Динамическая индексация по таблице SYS_CHRDEV_SWITCH [MAJOR_LP = 7])
;[Коммутационный слой VFS -> HAL Мосты]
;     ├── lp_write_bridge (lp_core.asm) [inline расчет: Minor * 80]
;     │    ├── Атомарная укладка байта (под DI/EI) в FIFO-кольцо ОЗУ Ring 0
;     │    │    └── LP_TABLE[Minor].O_LP_BUFFER_RESERVED
;     │    └── Аппаратный старт заснувшего конвейера (Если BUFFER_COUNT == 0)
;     │         ├── OUT РРУ (BSR Взвод INTE A) ──► [ Кремний КР580ВВ55А ]
;     │         └── OUT Регистр управления ──► [ Кристалл Intel 82C11 ]
;     │
;     └── lp_read_bridge (lp_core.asm) [Валидация границ Minor]
;          └── Мгновенный POSIX-возврат константы 00H (Символ EOF — Конец файла)
;*
; =============================================================================
; НАЗВАНИЕ: lp_core.asm (Центральный высокоуровневый диспетчер подсистемы /dev/lp*)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль VFS / ЯДРО
; =============================================================================
; =============================================================================
; НАЗВАНИЕ: lp_core.asm (Логический конфигуратор ОЗУ подсистемы печати)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль ПЕЧАТИ
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: k_lp_subsys_init
; Вход:  Cold Boot, Ring 0, прерывания гарантированно заперты (DI).
; Задача: Обнулить все 160 байт глобального массива LP_TABLE, ликвидируя
;         мусор рантайма после подачи питания на ОЗУ eMMU РЕВ_2.0.
; Выход: Все РОН (BC, DE, HL) полностью сохранены согласно контракту HAL.
; =============================================================================
k_lp_subsys_init:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    ; --- ЭТАП 1: ПОДГОТОВКА УКАЗАТЕЛЕЙ ЦИКЛА ОЧИСТКИ ---
    LXI  H, LP_TABLE                ; HL = Релоцируемый адрес начала таблицы из BSS [1.3]
    
    ; Вычисляем полный объем очистки: 2 слота * 80 байт = 160 байт (0x00A0)
    MVI  B, LP_MAX_DEVICES * LP_STRUCT_SIZE ; B = Счетчик итераций (160 циклов)
    XRA  A                          ; A = 00H (Замыкающий маркер очистки)

    ; --- ЭТАП 2: ВЫСОКОСКОРОСТНОЙ ПОБАЙТОВЫЙ СКАН-СБРОС В ОЗУ ---
_lp_subsys_clear_loop:
    MOV  M, A                       ; Записали чистый нуль в текущую ячейку ОЗУ [1.3]
    INX  H                          ; Сдвинули указатель на следующий байт структуры
    DCR  B                          ; Уменьшаем счетчик оставшихся проходов
    JNZ  _lp_subsys_clear_loop     ; Цикл крутится, пока регистр B не сойдется в ноль

    ; --- ЭТАП 3: КАНОНИЧЕСКОЕ ВОССТАНОВЛЕНИЕ КОНТЕКСТА ---
    POP  H
    POP  D
    POP  B                          ; Полное восстановление РОН супервизора по LIFO
    RET

; =============================================================================
; НАЗВАНИЕ: lp_core.asm (Канонический высокоуровневый HAL-мост записи)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль ПЕЧАТИ
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: lp_write_bridge
; Вход:  А  = Выводимый ASCII-символ.
;        B  = Номер Minor (0..1), полученный от коммутатора символьных устройств.
; Задача: POSIX-валидация границ и флагов. Неблокирующее ожидание места в FIFO.
;         Атомарная запись байта в ОЗУ-кольцо и асинхронный разгон прерываний чипа.
; Выход: Все РОН полностью восстановлены по контракту HAL Варианта B.
; =============================================================================
lp_write_bridge:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    MOV  C, A                       ; C = ЭВАКУАЦИЯ: сохранили выводимый символ

    ; === ЭТАП 1: ВАЛИДАЦИЯ ГРАНИЦ MINOR-НОМЕРА ===
    MOV  A, B                       ; A = Minor (0..1)
    CPI  LP_MAX_DEVICES             ; Сравнение с лимитом (2) из lp.inc
    JNC  _lp_wr_err_inval           ; Если B >= 2 — ошибка EINVAL (Неверный аргумент)

    ; === ЭТАП 2: МГНОВЕННЫЙ РАСЧЁТ АДРЕСА СТРУКТУРЫ LP_SLOT (Minor * 80) ===
    MOV  L, A
    MVI  H, 00H                     ; HL = Minor (0000H .. 0001H)

    ; Быстрое умножение Minor на 80 через сдвиги: (Minor * 64) + (Minor * 16)
    DAD  H
	DAD  H
	DAD  H
	DAD  H  ; HL = Minor * 16
    XCHG                             ; DE = Minor * 16
    DAD  H
	DAD  H                  ; HL = (Minor * 16) * 4 = Minor * 64
    DAD  D                           ; HL = (Minor * 64) + (Minor * 16) = Minor * 80
    
    LXI  D, LP_TABLE                ; Релоцируемый базовый адрес таблицы из BSS
    DAD  D                           ; HL = Физический адрес структуры активного LP-слота!
    XCHG                             ; DE = Зафиксировали базу LP-структуры в паре DE

    ; === ЭТАП 3: ПРОВЕРКА ФЛАГА LP_OPEN (ПОРТ ДОЛЖЕН БЫТЬ ОТКРЫТ) ===
    MOV  H, D
    MOV  L, E                       ; HL = База LP-слота
    LXI  B, O_LP_FLAGS              ; Смещение +4 из lp.inc
    DAD  B                           ; HL -> O_LP_FLAGS
    MOV  A, M
    ANI  LP_OPEN                     ; Проверка бита 0 (0x01)
    JZ   _lp_wr_err_ebadf            ; Если 0 — порт не открыт (EBADF)

    ; === ЭТАП 4: ПРОВЕРКА ФЛАГА LP_ERROR_STATE (АППАРАТНАЯ ОШИБКА) ===
    MOV  A, M                       ; Восстановили флаги из кэша
    ANI  LP_ERROR_STATE              ; Проверка бита 2 (0x04)
    JNZ  _lp_wr_err_io               ; Если 1 — порт в состоянии фатальной ошибки (EIO)

    ; === ЭТАП 5: ЦИКЛ ОЖИДАНИЯ ОСВОБОЖДЕНИЯ МЕСТА В FIFO (С ТАЙМАУТОМ) ===
    MVI  H, 0FFH                     ; H = 255 (Таймаут ожидания)

_lp_wr_br_wait_fifo:
    PUSH D                          ; СТЭК-ЗАЩИТА: спрятали чистую базу слота в стек Ring 0!
    
    MOV  H, D
    MOV  L, E                       ; HL = Истинный адрес слота LPT
    LXI  B, O_LP_BUFFER_COUNT       ; Смещение +18 из lp.inc
    DAD  B                           ; HL -> O_LP_BUFFER_COUNT
    MOV  A, M                       ; A = Текущее количество байт в FIFO-очереди
    CPI  48                         ; Буфер полон (Достиг лимита 48 байт)?
    
    POP  D                          ; СТЭК-ВОССТАНОВЛЕНИЕ: вернули чистую базу слота в DE!
    JC   _lp_wr_br_space_ok         ; Место есть (COUNT < 48) — шагаем на запись

    ; Буфер полон — кратковременно открываем прерывания для выгрузки байт асинхронным ISR
    EI
	NOP
	NOP
	NOP
	NOP
	NOP
	DI

    ; Проверка и декремент 8-битного таймаута в регистре H
    MOV  A, H
    DCR  A                          ; H--
    JZ   _lp_wr_err_eagain           ; Таймаут исчерпан — уходим на отбой с EAGAIN
    MOV  H, A                       ; Сохранили обновленный таймаут в H
    JMP  _lp_wr_br_wait_fifo

_lp_wr_br_space_ok:
    ; === ЭТАП 6: АТОМАРНАЯ КРИТИЧЕСКАЯ СЕКЦИЯ ЗАПИСИ В FIFO ОЗУ ===
    DI                              ; НАМЕРТВО ЗАПЕРЛИ ПРЕРЫВАНИЯ! Защита от коллизии с ISR

    ; Вычисляем адрес записи по указателю HEAD
    MOV  H, D
    MOV  L, E                       ; ИСПРАВЛЕНО: Старший в старший (H=D), младший в младший (L=E)!
    LXI  B, O_LP_BUFFER_HEAD        ; Смещение +16 из lp.inc
    DAD  B                           ; HL -> O_LP_BUFFER_HEAD
    MOV  A, M                       ; А = HEAD_old
    STA  _lp_wr_br_tmp_head         ; ЭВАКУАЦИЯ: сбросили индекс в локальную переменную ОЗУ ядра

    ; Инкрементируем и зацикливаем HEAD на границе 48 байт
    INR  M                           ; O_LP_BUFFER_HEAD++ (Фиксация в памяти дескриптора)
    MOV  A, M
    CPI  48
    JC   _lp_wr_br_head_no_wrap
    MVI  M, 00H                      ; Циклический заворот HEAD = 0

_lp_wr_br_head_no_wrap:
    ; Двухступенчатый расчет физического адреса ячейки: База + 21 + HEAD_old
    MOV  H, D
    MOV  L, E                       ; HL = Восстановили чистую базу LP-слота
    PUSH D                           ; Спрятали базу слота на стек Ring 0

    LXI  D, 21                       ; Смещение начала сектора данных буфера FIFO
    DAD  D                           ; HL = База + 21
    
    LDA  _lp_wr_br_tmp_head          ; ИСПРАВЛЕНО: Загрузили истинный HEAD_old из переменной ОЗУ
    MOV  E, A
    MVI  D, 00H                      ; DE = 0000H + HEAD_old
    DAD  D                           ; HL = Точный физический адрес фиксации байта!
    MOV  M, C                        ; АТОМАРНАЯ ФИКСАЦИЯ: выводимый символ лег в ОЗУ Ring 0!
    POP  D                           ; DE = Восстановили базу LP-слота

    ; Инкрементируем общий счётчик байт в очереди вывода
    MOV  H, D
    MOV  L, E                       ; ИСПРАВЛЕНО: Восстановили HL параллельно структуре пары DE!
    LXI  B, O_LP_BUFFER_COUNT       ; Смещение +18 из lp.inc
    DAD  B                           ; HL -> O_LP_BUFFER_COUNT
    MOV  A, M                        ; A = BUFFER_COUNT_old
    INR  M                           ; O_LP_BUFFER_COUNT++ (Зафиксировали в памяти ядра)

    ; === ЭТАП 7: АППАРАТНЫЙ СТАРТ КОНВЕЙЕРА (ПИНАЕМ КРЕМНИЙ) ===
    ORA  A                           ; Проверяем BUFFER_COUNT_old
    JNZ  _lp_wr_br_exit_clear        ; Если буфер не был пуст — ISR уже крутится на шине, уходим!

    ; Извлекаем физический порт управления (O_LP_PORT_CTRL) для прямого пинка
    MOV  H, D
    MOV  L, E                       ; ИСПРАВЛЕНО: Восстановили HL параллельно DE!
    LXI  B, O_LP_PORT_CTRL          ; Смещение +3 из lp.inc
    DAD  B                           ; HL -> O_LP_PORT_CTRL
    MOV  C, M                        ; C = Физический порт управления (BASE+2 или BASE+1)

    ; Считываем тип активного чипа для корректной Handshake-сигнализации
    MOV  H, D
    MOV  L, E                       ; ИСПРАВЛЕНО: Восстановили HL параллельно DE!
    LXI  B, O_LP_HW_TYPE            ; Смещение +19 из lp.inc
    DAD  B                           ; HL -> O_LP_HW_TYPE
    MOV  A, M                        ; A = LP_TYPE_8255 / 82C11

    CPI  LP_TYPE_82C11
    JZ   _lp_wr_br_kick_c11          ; Прыгаем на разгон Intel 82C11

    ; --- Активация прерываний для КР580ВВ55А ---
    MOV  A, C
    INR  A                           ; A = (BASE+2) + 1 = BASE+3 (РРУ чипа ВВ55А)
    MOV  C, A
    
    MVI  A, 007H                     ; Наш проверенный BSR-фикс взвода триггера INTE A (PC3 Set)
    STA  _lp_wr_br_kick_out1 + 1     ; SMC патч порта вывода
_lp_wr_br_kick_out1:
    OUT  000H                       ; Прерывания ВВ55А взведены! Патчится на BASE+3
    JMP  _lp_wr_br_exit_clear

_lp_wr_br_kick_c11:
    ; --- Активация прерываний для Intel 82C11 ---
    MOV  A, C                       ; А = Порт управления чипа 82C11 (BASE+1)
    STA  _lp_wr_br_kick_out2 + 1
    MVI  A, 001H                    ; Константа C11_CTRL_IRQ_EN
_lp_wr_br_kick_out2:
    OUT  000H                       ; Прерывания 82C11 взведены! Патчится на BASE+1

_lp_wr_br_exit_clear:
    EI                               ; ВЫШЛИ ИЗ КРИТИЧЕСКОЙ СЕКЦИИ, ОТКРЫЛИ ПРЕРЫВАНИЯ!
    POP  H
    POP  D
    POP  B                           ; Идеальное каноническое восстановление РОН по LIFO
    ANA  A                           ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Успех!)
    RET

; =============================================================================
; КАНАЛЫ АВАРИЙНЫХ ВОЗВРАТОВ С POSIX-КОДАМИ ОШИБОК
; =============================================================================
_lp_wr_err_inval:
    POP  H
    POP  D
    POP  B                           ; Восстановили РОН
    MVI  A, EINVAL                   ; A = 22 (Invalid argument — Minor вне диапазона)
    STC                              ; CY = 1 (Провал)
    RET

_lp_wr_err_ebadf:
    POP  H
    POP  D
    POP  B                           ; Восстановили РОН
    MVI  A, EBADF                    ; A = 9 (Bad file number — порт не открыт)
    STC                              ; CY = 1 (Провал)
    RET

_lp_wr_err_io:
    POP  H
    POP  D
    POP  B                           ; Восстановили РОН
    MVI  A, EIO                      ; A = 5 (I/O error — аппаратная ошибка принтера)
    STC                              ; CY = 1 (Провал)
    RET

_lp_wr_err_eagain:
    POP  H
    POP  D
    POP  B                           ; Восстановили РОН
    MVI  A, EAGAIN                   ; A = 11 (Try again — таймаут ожидания FIFO)
    STC                              ; CY = 1 (Провал)
    RET

; =============================================================================
; НАЗВАНИЕ: lp_core.asm (POSIX-совместимый HAL-мост чтения LP_READ_BRIDGE) 
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль ПЕЧАТИ
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: lp_read_bridge
; Вход:  B  = Номер Minor (0..1), полученный от коммутатора символьных устройств.
; Задача: Имитировать каноничное поведение POSIX LPT-устройства на чтение.
;         Выполнить валидацию Minor и мгновенно вернуть признак EOF (00H).
; Выход: А  = 00H (Символ конца файла EOF).
;        CY = 0 — Системная операция завершена успешно.
;        Регистры BC, DE, HL полностью сохранены согласно контракту HAL.
; =============================================================================
lp_read_bridge:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    ; === ЭТАП 1: РАНТАЙМ-ВАЛИДАЦИЯ ГРАНИЦ MINOR ===
    MOV  A, B                       ; A = Minor (0..1)
    CPI  LP_MAX_DEVICES             ; Сравниваем с лимитом (2) из lp.inc
    JNC  _lp_rd_br_err_inval        ; Если Minor >= 2 — уходим на аварийный выход

    ; === ЭТАП 2: ФОРМИРОВАНИЕ ПОТОКА КОНЦА ФАЙЛА (EOF) ===
    ; Согласно UNIX-канону, чтение из write-only устройства Centronics 
    ; не вешает систему, а выдает 0 прочитанных байт (атомарный EOF = 00H).
    MVI  A, 00H                     ; Аккумулятор А = 00H (EOF)

    POP  H
    POP  D
    POP  B                          ; Идеальное каноническое восстановление РОН по LIFO
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Полный рантайм-успех)
    RET

; =============================================================================
; КАНАЛ АВАРИЙНОГО ВОЗВРАТА ОШИБКИ
; =============================================================================
_lp_rd_br_err_inval:
    POP  H
    POP  D
    POP  B                          ; Изолированно разгрузили рантайм-контекст по LIFO
    MVI  A, EINVAL                  ; А = Константа 22 (0x16) из lp.inc / vfs.inc
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Провал операции)
    RET

; =============================================================================
; ПРОЦЕДУРА: k_lp_carousel_auto_build
; Вход:  Cold Boot, Ring 0, прерывания гарантированно заперты (DI).
; Задача: Последовательно опросить физические адреса LPT0 (0x78) и LPT1 (0x28).
;         Аллоцировать свободные 80-байтовые слоты в LP_TABLE, назначить IRQ
;         и привязать специализированные ISR к вектору прерываний ВН59.
; Выход: Все РОН полностью сохранены. Прерывания заперты.
; =============================================================================
k_lp_carousel_auto_build:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора

    ; Инициализируем динамический указатель целевого логического LP-слота ОЗУ
    LXI  D, LP_TABLE                ; DE = База первого слота (обслуживает /dev/lp0)

    ; --- ТЕСТИРОВАНИЕ ФИЗИЧЕСКОГО АДРЕСА LPT0 ---
    MVI  A, LPT0_BASE_PORT          ; A = 0x78 (из lp.inc)
    MVI  B, 5                       ; B = Аппаратная линия IRQ5 для первого порта
    CALL _lp_probe_hardware_gate    ; Запуск шлюза автодетекта
    
    ; --- ТЕСТИРОВАНИЕ ФИЗИЧЕСКОГО АДРЕСА LPT1 ---
    MVI  A, LPT1_BASE_PORT          ; A = 0x28 (из lp.inc)
    MVI  B, 6                       ; B = Аппаратная линия IRQ6 для второго порта
    CALL _lp_probe_hardware_gate    ; Запуск шлюза автодетекта

    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление РОН по LIFO
    RET

; =============================================================================
; ВНУТРЕННИЙ ШЛЮЗ АВТОДЕТЕКТА: _lp_probe_hardware_gate (ИСПРАВЛЕННАЯ ВЕРСИЯ)
; =============================================================================
_lp_probe_hardware_gate:
    PUSH B                          ; Спрятали пару BC (B=IRQ, C=мусор)
    PUSH PSW                        ; Спрятали тестируемый порт на стек

    ; --- ПРИОРИТЕТНЫЙ ТЕСТ №1: Проверка наличия специализированной БИС 82C11 ---
    CALL hw_82C11_lp_init           ; Функция в файле hw_lp82c11.asm [1.3]
    JNC  _lp_gate_device_found      ; CY=0 -> Чип 82C11 успешно детектирован!

    ; --- РЕЗЕРВНЫЙ ТЕСТ №2: Проверка наличия универсального адаптера КР580ВВ55А ---
    POP  PSW
	PUSH PSW             ; Восстановили тестируемый порт в аккумулятор A
    CALL hw_i8255_lp_init           ; Функция в файле hw_lp8255.asm [1.3]
    JNC  _lp_gate_device_found      ; CY=0 -> Нашли КР580ВВ55А на этом адресе!

    ; --- АППАРАТНАЯ ПУСТОТА: Ни одного чипа на данном адресе шины нет ---
    POP  PSW                        ; Очистили стек от сохраненного порта
    POP  B                          ; Восстановили назначенное IRQ
    RET                             ; Слот в DE остается свободным

_lp_gate_device_found:
    ; === КРЕМНИЙ НАЙДЕН И ИНИЦИАЛИЗИРОВАН! ===
    POP  PSW                        ; Выбросили порт из стека (не нужен)
    POP  B                          ; Восстановили IRQ (B = 5 или 6)
    
    ; Записываем вычисленную линию IRQ в дескриптор текущего слота
    MOV  H, D
    MOV  L, E                       ; HL = Чистая база текущего слота ОЗУ
    PUSH H                          ; Запомнили базу слота на стеке
    
    ; ИСПРАВЛЕНО: Удалена мёртвая инструкция LXI D, O_LP_HW_LINE
    LXI  D, O_LP_HW_IRQ_LINE        ; Смещение +20 согласно lp.inc
    DAD  D                          ; HL -> Поле O_LP_HW_IRQ_LINE
    MOV  M, B                       ; Прошили номер IRQ в структуру дескриптора
    
    POP  H                          ; HL = Восстановили чистую базу слота
    
    ; Считываем тип чипа для выбора правильного ISR
    PUSH B                          ; Спасли IRQ
    LXI  B, O_LP_HW_TYPE            ; Смещение +19
    DAD  B                          ; HL -> Поле типа кремния
    MOV  A, M                       ; A = Считанный тип (01H или 02H)
    POP  B                          ; Восстановили IRQ (B = 5 или 6)
    
    CPI  LP_TYPE_82C11              ; На этом адресе ожил Intel 82C11?
    JZ   _lp_gate_register_c11      ; Да — прыгаем на регистрацию вектора 82C11

    ; --- Регистрация обработчика прерываний для КР580ВВ55А ---
    MOV  A, B                       ; А = Номер линии IRQ (5 или 6)
    LXI  H, hw_lp8255_isr           ; HL = Адрес ISR для ВВ55А
    CALL k_register_isr             ; Встроили вектор в таблицу КР580ВН59!
    JMP  _lp_gate_slot_allocated

_lp_gate_register_c11:
    ; --- Регистрация обработчика прерываний для Intel 82C11 ---
    MOV  A, B                       ; А = Номер линии IRQ (5 или 6)
    LXI  H, hw_lp82c11_isr          ; HL = Адрес ISR для 82C11
    CALL k_register_isr             ; Встроили вектор в таблицу КР580ВН59!

_lp_gate_slot_allocated:
    ; === СДВИГ УКАЗАТЕЛЯ: ПОРТ УСПЕШНО ЗАНЯЛ СЛОТ, ШАГАЕМ ВПЕРЕД ===
    MOV  H, D
    MOV  L, E                       ; HL = Текущая база слота
    LXI  D, LP_STRUCT_SIZE          ; DE = 80 байт — шаг структуры
    DAD  D                          ; HL = HL + 80
    XCHG                            ; DE = Указатель на следующий СВОБОДНЫЙ слот!
    RET

; =============================================================================
; НАЗВАНИЕ: lp_core.asm (Авторегистратор LPT-драйвера в коммутаторе VFS)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Модуль ПЕЧАТИ
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: k_lp_register_vfs
; Вход:  Cold Boot, Ring 0, прерывания заперты (DI).
; Задача: Зарегистрировать HAL-мосты чтения/записи подсистемы параллельной печати
;         в глобальной таблице SYS_CHRDEV_SWITCH под MAJOR-номером 7 (MAJOR_LP).
; Выход: CY = 0 — Успех. Драйвер LPT успешно интегрирован в коммутатор VFS.
;        CY = 1 — Критическая ошибка: Неверный Major-номер (Защита границ таблицы).
;        Все РОН (BC, DE, HL) полностью сохранены по контракту LIFO.
; =============================================================================
k_lp_register_vfs:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    ; --- ЭТАП 1: ПОДГОТОВКА ПАРАМЕТРОВ ДЛЯ СИСТЕМНОГО РЕГИСТРАТОРА VFS ---
    MVI  A, MAJOR_LP                ; A = MAJOR_LP (Константа 7 из lp.inc) [1.3]
    LXI  H, lp_write_bridge         ; HL = Физический адрес HAL-моста записи LPT [1.3]
    LXI  D, lp_read_bridge          ; DE = Физический адрес HAL-моста чтения LPT [1.3]

    ; --- ЭТАП 2: АТОМАРНАЯ СВЯЗКА В ОЗУ ТАБЛИЦЕ ДРАЙВЕРОВ ЯДРА ---
    CALL k_register_chrdev          ; Вызов Plug-and-Play регистратора VFS [1.3]
                                    ; (При успехе возвращает CY=0, при ошибке границ — CY=1)

    ; Перехват ошибки: если Major >= 32 — аварийный выход
    JC   _k_lp_reg_vfs_fault

    ; --- ЭТАП 3: КАНОНИЧЕСКОЕ ВОССТАНОВЛЕНИЕ КОНТЕКСТА (УСПЕХ) ---
    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление РОН по LIFO
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Полный успех операции)
    RET

; =============================================================================
; КАНАЛ АВАРИЙНОГО ВОЗВРАТА ОШИБКИ
; =============================================================================
_k_lp_reg_vfs_fault:
    ; ИСПРАВЛЕНО: Удалена дублирующая метка _k_lp_register_vfs_fault
    POP  H
    POP  D
    POP  B                          ; Зеркально разгрузили оригинальный РОН-кадр со стека
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Провал коммутации)
    RET

; =============================================================================
; ПРОЦЕДУРА: vfs_mount_lp_nodes
; Вход:  DE = Физический адрес первого СВОБОДНОГО слота в LP_TABLE после карусели.
; Задача: По разности адресов (16-битная DAD-арифметика с дополнительным кодом)
;         вычислить число реально найденных LPT-контроллеров, последовательно
;         зарегистрировать для них файлы /dev/lp0 и /dev/lp1 в VFS.
; =============================================================================
vfs_mount_lp_nodes:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли контекст супервизора Ring 0

    ; --- ВЫЧИСЛЕНИЕ СУММАРНОЙ ДЕЛЬТЫ АДРЕСOВ ОЗУ ТАБЛИЦЫ ---
    LXI  H, LP_TABLE
    MOV  A, E
    SUB  L
    MOV  E, A                       ; E = Младший байт 16-битной дельты
    MOV  A, D
    SBB  H
    MOV  D, A                       ; DE = Итоговая 16-битная дельта адресов (DE - LP_TABLE)

    ; --- ДЕЛЕНИЕ НА РАЗМЕР СТРУКТУРЫ (80 БАЙТ) ЧЕРЕЗ ДОПОЛНИТЕЛЬНЫЙ КОД ---
    MVI  B, 0                       ; B = Накопительный счетчик найденных LPT (0..2)

_vfs_lp_calc_active:
    MOV  A, E
    ORA  D
    JZ   _vfs_lp_mount_start        ; Если дельта сошлась в ноль — расчет окончен, на монтаж
    
    LXI  H, -80                     ; HL = 0xFFB0 (Дополнительный код числа 80)
    DAD  D                          ; HL = DE - 80
    JNC  _vfs_lp_mount_start        ; CY=0 -> Остаток дельты меньше 80 (Завершение расчета)
    
    MOV  D, H
    MOV  E, L                       ; DE = Декрементированная дельта (DE - 80)
    INR  B                          ; Счетчик активных Minor-номеров принтеров++
    JMP  _vfs_lp_calc_active

_vfs_lp_mount_start:
    MOV  A, B                       ; А = Общее число успешно оживленных LPT-портов
    ORA  A
    JZ   _vfs_lp_no_hardware        ; Если 0 — принтеров на шине нет, тихо выходим без создания файлов

    MOV  C, A                       ; C = Счетчик циклов монтирования файлов в директорию /dev
    MVI  B, 0                       ; B = Начальный Minor-номер устройства (0..1)

_vfs_lp_mount_loop:
    PUSH B                          ; Спасли пару BC (B = Minor, C = Ограничитель итераций)

    MOV  A, B                       ; A = Текущий Minor (0..1)
    CALL _vfs_lp_get_string_ptr     ; Выход: DE = Адрес изолированной ASCIIZ-строки пути
    
    MVI  A, I_TYPE_CHRDEV           ; A = 02H (Тип файла: Специальное символьное устройство) [1.3]
    MVI  C, MAJOR_LP                ; C = MAJOR_LP (7) из за заголовочного lp.inc
    ; Регистр B из сохраненной пары по-прежнему содержит текущий Minor
    
    CALL vfs_mknod                  ; Физическая интеграция Inode в RAM-диск VFS! [1.3]

    POP  B                          ; Восстановили пару BC со стека ядра
    INR  B                          ; Переходим к следующему Minor-номеру (Minor++)
    DCR  C                          ; Уменьшаем счетчик оставшихся проходов
    JNZ  _vfs_lp_mount_loop

_vfs_lp_no_hardware:
    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление РОН по LIFO
    RET

; =============================================================================
; ВНУТРЕННЯЯ ПОДПРОГРАММА: _vfs_lp_get_string_ptr (С ВАЛИДАЦИЕЙ ВЕРХНЕЙ ГРАНИЦЫ)
; =============================================================================
_vfs_lp_get_string_ptr:
    CPI  0
	JZ  _vfs_lp_ret_dev0
    CPI  1
	JZ  _vfs_lp_ret_dev1
    
    ; Индексный оверран: Minor > 1 — повреждение памяти Ring 0, вешаем систему
    LXI  H, _vfs_lp_panic_msg
    JMP  kernel_panic_lp_indx_err

_vfs_lp_ret_dev0:
    LXI  D, _vfs_lp_str_dev0
	RET
_vfs_lp_ret_dev1:
    LXI  D, _vfs_lp_str_dev1
	RET

kernel_panic_lp_indx_err:
	; Фатальная ошибка старта: Нарушение структуры LP.
    ; Выключаем прерывания и намертво вешаем процессор.
    DI
    HLT
	JMP  kernel_panic_lp_indx_err

; --- Изолированные системные ASCIIZ-строки и ловушки ошибок (Секция ROM) ---
_vfs_lp_str_dev0:    DB  "/dev/lp0", 0
_vfs_lp_str_dev1:    DB  "/dev/lp1", 0
_vfs_lp_panic_msg:   DB  "VFS FATAL: INVALID LPT MINOR NUMBER EXTRACTED DURING COLD BOOT!", 0
#include "./kernel/hw_lp8255.asm"
; =============================================================================
; НАЗВАНИЕ: hw_lp8255.asm (Конфигуратор и инициализатор БИС КР580ВВ55А)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Драйверы Печати
; =============================================================================
; =============================================================================
; hw_i8255_lp_init (ИСПРАВЛЕННАЯ ВЕРСИЯ)
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: hw_i8255_lp_init
; Вход:  A  = Тестируемый 8-битный базовый порт данных (0x78 или 0x28).
;        DE = Физический адрес целевого свободного слота в LP_TABLE.
; Задача: Проверить физическое НАЛИЧИЕ чипа ВВ55А на шине методом записи/чтения
;         регистра данных, настроить Режим 1 Centronics, взвести прерывание
;         INTE A, выполнить тест принтера и заполнить структуру слота.
; Выход: CY = 0 — Успех. Чип ВВ55А верифицирован и готов к асинхронной печати.
;        CY = 1 — Ошибка: Чип отсутствует на шине или принтер не готов.
;        Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
hw_i8255_lp_init:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    MOV  C, A                       ; C = Тестируемый BASE_PORT (LPT0/LPT1)

    ; --- ЭТАП 1: ДИНАМИЧЕСКИЙ SMC-РАСЧЕТ И ПАТЧИНГ ПОРТОВ ---
    ; DATA_PORT = BASE_PORT + 0
    STA  _lp_55_probe_out1 + 1
    STA  _lp_55_probe_in1 + 1
    STA  _lp_55_probe_out2 + 1
    STA  _lp_55_probe_in2 + 1
    
    ; STATUS_PORT = BASE_PORT + 1
    INR  A
    STA  _lp_55_init_status_in + 1
    
    ; РРУ (Регистр Управляющего Слова) = BASE_PORT + 3
    MOV  A, C
	ADI 3
    STA  _lp_55_probe_cmd_out + 1
    STA  _lp_55_init_cmd_out + 1
    STA  _lp_55_init_cmd_out2 + 1   ; Пропатчили все точки ввода-вывода

    ; --- ЭТАП 2: ЖЕСТКИЙ ТЕСТ ФИЗИЧЕСКОГO НАЛИЧИЯ ЧИПА (КРЕМНИЕВАЯ ПРОВЕРКА) ---
    ; Временно настраиваем ВВ55А в простой Режим 0: Порт А на вывод, Порты B/C на ввод.
    ; Управляющее слово для этого режима = 0x92
    MVI  A, 092H
_lp_55_probe_cmd_out:
    OUT  000H                       ; Сконфигурировали чип для теста. Патчится на BASE+3
    NOP
	NOP

    ; Тест 1: Запись и чтение шахматной маски 0x55
    MVI  A, 055H
_lp_55_probe_out1:
    OUT  000H                       ; Запись в Порт А. Патчится на BASE+0
    NOP
	NOP
_lp_55_probe_in1:
    IN   000H                       ; Чтение из Порта А. Патчится на BASE+0
    CPI  055H                       ; Проверяем фиксацию уровней защелки
    JNZ  _hw_lp_55_init_fail        ; Не совпало — кристалл отсутствует! [1.3]

    ; Тест 2: Запись и чтение инвертированной маски 0xAA
    MVI  A, 0AAH
_lp_55_probe_out2:
    OUT  000H                       ; Запись в Порт А. Патчится на BASE+0
    NOP
	NOP
_lp_55_probe_in2:
    IN   000H                       ; Чтение из Порта А. Патчится на BASE+0
    CPI  0AAH                       ; Проверяем инверсные уровни
    JNZ  _hw_lp_55_init_fail        ; Не совпало — кремний отсутствует! [1.3]

    ; --- ЭТАП 3: РАБОЧАЯ КОНФИГУРАЦИЯ И СБРОС КРИСТАЛЛА ---
    ; Чип живой. Переводим в боевой Режим 1 Handshake вывода. Упр.слово = 0xA8
    MVI  A, 0A8H
_lp_55_init_cmd_out:
    OUT  000H                       ; Конвейер прерываний активирован. Патчится на BASE+3

    ; Взвод триггера INTE A через РРУ по вашей проверенной маске BSR для бита PC3
    MVI  A, 007H                    ; Утвержденный фикс: PC3 Set = 0x07 [1.3]
_lp_55_init_cmd_out2:
    OUT  000H                       ; Линия прерываний INTE A открыта. Патчится на BASE+3
    NOP
	NOP

    ; --- ЭТАП 4: ТЕСТ ФУНКЦИОНИРОВАНИЯ ВНЕШНЕГO УСТРOЙСТВА (CENTRONICS) ---
_lp_55_init_status_in:
    IN   000H                       ; Считали статус Centronics. Патчится на BASE+1
    MOV  B, A                       ; B = Кэш статуса

    ; Валидация 1: Проверяем, выбран ли принтер (LP_SELECT / Бит 4 == 1)
    ANI  LP_SELECT                  ; Маска 0x10 из lp.inc
    JZ   _hw_lp_55_init_fail        ; Если 0 — принтер выключен или не подключен

    ; Валидация 2: Проверяем отсутствие конца бумаги (LP_PAPER_OUT / Бит 5 == 0)
    MOV  A, B
    ANI  LP_PAPER_OUT               ; Маска 0x20 из lp.inc
    JNZ  _hw_lp_55_init_fail        ; Если 1 — датчик бумаги активен, блокируем запуск

    ; --- ЭТАП 5: ПОСЛЕДОВАТЕЛЬНОЕ ЗАПОЛНЕНИЕ ДЕСКРИПТОРА СЛOТА ---
    MOV  H, D
    MOV  L, E                       ; HL = Истинный адрес слота LP_TABLE

    MVI  M, 00H                     ; O_LP_STATUS = 0
    
    INX  H                          ; HL -> O_LP_PORT_DATA (+1)
    MOV  M, C                       ; Физический порт DATA (BASE+0)
    
    MOV  A, C
	INR A
    INX  H                          ; HL -> O_LP_PORT_STATUS (+2)
    MOV  M, A                       ; Физический порт STATUS (BASE+1)
    
    INR  A
    INX  H                          ; HL -> O_LP_PORT_CTRL (+3)
    MOV  M, A                       ; Физический порт CTRL (BASE+2)
    
    INX  H                          ; HL -> O_LP_FLAGS (+4)
    MVI  M, LP_OPEN                 ; Выставили флаг "Порт успешно открыт" (0x01)
    
    ; Фиксация аппаратного типа чипа в дескрипторе
    MOV  H, D
    MOV  L, E                       ; HL = Восстановили чистую базу слота
    LXI  B, O_LP_HW_TYPE            ; Смещение +19 из lp.inc
    DAD  B                          ; HL -> O_LP_HW_TYPE
    MVI  M, LP_TYPE_8255            ; Зафиксировали тип кремния (01H) [1.3]

    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление РОН по LIFO
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Полный рантайм-успех!)
    RET

_hw_lp_55_init_fail:
    POP  H
    POP  D
    POP  B                          ; Восстановили оригинальный контекст супервизора
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Аппаратный отказ чипа / Centronics)
    RET

; =============================================================================
; АСИНХРОННЫЙ ОБРАБОТЧИК ПРЕРЫВАНИЙ ДЛЯ БИС КР580ВВ55А
; Вход:  Аппаратный CALL по вектору IRQ от КР580ВН59. Прерывания заперты (DI).
;        Состояние РОН и SP — случайное (из прерванного контекста Ring 3).
; Задача: Извлечь байт из TX-кольца ОЗУ, выдать в DATA_PORT, сформировать
;         импульс STROBE через BSR-команду РРУ, декрементировать BUFFER_COUNT.
; Выход: РОН полностью восстановлены.
; =============================================================================
; =============================================================================
; НАЗВАНИЕ: hw_lp8255.asm (Асинхронный монолитный ISR для КР580ВВ55А)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Драйверы Печати
; =============================================================================
hw_lp8255_isr:
_smc_lp55_isr_base:
    ; === ЭТАП 0: АППАРАТНЫЙ ПОРТ ПРИВЯЗКИ БАЗЫ (SMC-ИНСТАНС) ===
    LXI  D, 0000H                   ; Сюда карусель lp_core.asm при старте
                                    ; пропишет истинный адрес структуры ОЗУ.

    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст прерванного процесса

    ; === ЭТАП 1: ДИНАМИЧЕСКИЙ SMC-РАСЧЕТ ФИЗИЧЕСКИХ ПОРТОВ ВВОД-ВЫВОДА ===
    MOV  H, D
    MOV  L, E                       ; HL = Физическая база дескриптора принтера
    INX  H                          ; HL -> O_LP_PORT_DATA (+1)
    MOV  A, M                       ; A = Физический базовый порт DATA (0x78 или 0x28)
    MOV  C, A                       ; C = Кэш базового порта DATA
    
    ; Прошиваем операнд инструкции OUT для выдачи данных (BASE+0)
    STA  _lp_55_isr_data_out + 1
    
    ; === ЭТАП 1.1: ВЫЧИСЛЕНИЕ АДРЕСА РРУ (BASE+3) И ТОТАЛЬНЫЙ SMC ПАТЧ ===
    MOV  A, C
    ADI  3                          ; A = BASE_PORT + 3 (Регистр Управляющего Слова)
    STA  _lp_55_isr_bsr_out1 + 1    ; Прошили РРУ для BSR-сброса строба
    STA  _lp_55_isr_bsr_out2 + 1    ; Прошили РРУ для BSR-взвода строба
    STA  _lp_55_isr_empty_out + 1   ; Прошили РРУ для глушения INTE A прерываний [1.3]

    ; === ЭТАП 2: КОНТРОЛЬ НАЛИЧИЯ ДАННЫХ В TX КОЛЬЦЕ ОЗУ ===
    MOV  H, D
    MOV  L, E                       ; HL = База слота LPT
    LXI  B, O_LP_BUFFER_COUNT       ; Смещение +18 согласно lp.inc
    DAD  B                          ; HL -> O_LP_BUFFER_COUNT
    MOV  A, M
    ORA  A                          ; BUFFER_COUNT == 0 (Очередь отложенной записи пуста)?
    JZ   _lp_55_isr_empty_close     ; Да — данных для печати больше нет, глушим линию прерывания!

    ; === ЭТАП 3: ИЗВЛЕЧЕНИЕ БАЙТА ИЗ КОЛЬЦЕВОГО FIFO БУФЕРА ===
    DCR  M                          ; O_LP_BUFFER_COUNT--
    
    ; Извлекаем индекс чтения по указателю TAIL
    DCX  H                          ; HL -> O_LP_BUFFER_TAIL (Смещение +17)
    MOV  A, M                       ; A = TAIL_old
    MOV  B, A                       ; B = Кэш текущего индекса чтения
    
    ; Инкрементируем и зацикливаем TAIL в памяти ядра Ring 0
    INR  M                          ; TAIL++
    MOV  A, M
    CPI  48                         ; Буфер строго ограничивается 48 байтами [1.3]
    JC   _lp_55_isr_tail_no_wrap
    MVI  M, 00H                     ; Циклический заворот TAIL = 0

_lp_55_isr_tail_no_wrap:
    ; Двухступенчатый DAD-расчет физического адреса байта
    MOV  H, D
    MOV  L, E                       ; HL = Восстановили чистую базу слота LPT
    PUSH D                          ; Спрятали базу слота
    
    LXI  D, 21                      ; Смещение начала сектора данных буфера FIFO
    DAD  D                          ; HL = База + Начало буфера вывода
    
    MOV  E, B
    MVI  D, 00H                     ; DE = 0000H + TAIL_old
    DAD  D                          ; HL = Точный физический адрес байта в ОЗУ ядра Ring 0!
    MOV  A, M                       ; А = ASCII-символ, готовый к выгрузке в принтер
    MOV  B, A                       ; B = Спасли символ от разрушения при POP
    POP  D                          ; DE = Восстановили базу слота LPT

    ; === ЭТАП 3.1: ПОЛНЫЙ 32-БИТНЫЙ ИНКРЕМЕНТ СЧЕТЧИКА O_LP_BYTES_WRITTEN ===
    MOV  H, D
    MOV  L, E
    LXI  D, O_LP_BYTES_WRITTEN      ; Смещение +8 из lp.inc
    DAD  D                          ; HL -> Байт 0 (младший) счётчика
    
    INR  M                          ; Байт 0++
    JNZ  _lp_bytes_inc_done         ; Если не было переполнения — выходим из каскада
    
    INX  H                          ; Переход к Байту 1
    INR  M
    JNZ  _lp_bytes_inc_done
    
    INX  H                          ; Переход к Байту 2
    INR  M
    JNZ  _lp_bytes_inc_done
    
    INX  H                          ; Переход к Байту 3 (старший)
    INR  M

_lp_bytes_inc_done:
    ; === ЭТАП 4: ФИЗИЧЕСКИЙ ВЫСТРЕЛ В КРЕМНИЙ И BSR-СТРОБИРОВАНИЕ CENTRONICS ===
    MOV  A, B                       ; А = Извлеченный ASCII-символ
_lp_55_isr_data_out:
    OUT  000H                       ; Выставили символ на шину данных LPT. Патчится на BASE+0

    ; Формируем импульс фиксации STROBE для Centronics через BSR-команды в РРУ.
    ; BSR-команда: 0000 000 0 = 0x00 (Reset PC0 -> STROBE уходит в низкий активный уровень)
    MVI  A, 000H                    
_lp_55_isr_bsr_out1:
    OUT  000H                       ; STROBE = 0 (Начало фиксации данных принтером). Патчится на BASE+3 [1.3]
    
    ; Микровыдержка импульса согласно временным диаграммам Centronics
    NOP
	NOP
	NOP
	NOP

    ; Завершаем импульс, возвращая STROBE в единицу через BSR.
    ; BSR-команда: 0000 000 1 = 0x01 (Set PC0 -> STROBE возвращается в высокий пассивный уровень)
    MVI  A, 001H
_lp_55_isr_bsr_out2:
    OUT  000H                       ; STROBE = 1 (Данные запечатаны принтером). Патчится на BASE+3 [1.3]
    JMP  _lp_55_isr_close_8259      ; Символ улетел, шагаем на закрытие прерывания ВН59

_lp_55_isr_empty_close:
    ; Очередь ОЗУ пуста — принудительно гасим асинхронный триггер прерываний чипа ВВ55А.
    ; Сброс бита PC3 (INTE A) в РРУ ВВ55А (Команда BSR: Бит=3, Уровень=0) = 0x06
    MVI  A, 006H
_lp_55_isr_empty_out:
    OUT  000H                       ; Атомарно заперли INTE A прерываний ВВ55А! Патчится на BASE+3 [1.3]

    ; Переводим логический статус порта в состояние покоя (O_LP_STATUS = 0)
    MOV  H, D
    MOV  L, E
    MVI  M, 00H                     

_lp_55_isr_close_8259:
    ; === ЭТАП 5: СБРОС ТРИГГЕРА КОНТРОЛЛЕРА ПРЕРЫВАНИЙ КР580ВН59 ===
    MVI  A, 020H
    OUT  MASTER_8259_CMD            ; Неспецифический EOI в суверенный ВН59 (Порты 0xA0/0xA1) [1.3]
    
    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление контекста прерванной задачи
    EI                              ; Разрешили асинхронный конвейер шины eMMU
    RET

#include "./kernel/hw_lp82c11.asm"
; =============================================================================
; НАЗВАНИЕ: hw_lp82c11.asm (Инициализатор БИС Intel 82C11 с аппаратным детектом)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Драйверы Печати
; =============================================================================
; =============================================================================
; ПРОЦЕДУРА: hw_82c11_lp_init
; Вход:  A  = Тестируемый 8-битный базовый порт данных (0x78 или 0x28).
;        DE = Физический адрес целевого свободного слота в LP_TABLE.
; Задача: Проверить физическое НАЛИЧИЕ чипа 82C11 на шине ввода-вывода. В случае
;         успеха взвести маску IRQ, выполнить тест принтера и заполнить слот.
; Выход: CY = 0 — Успех. Чип 82C11 найден, исправен и готов к асинхронной печати.
;        CY = 1 — Ошибка: Чип отсутствует на шине или принтер не готов.
;        Все РОН полностью сохранены согласно контракту HAL Варианта B.
; =============================================================================
hw_82c11_lp_init:
    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст супервизора Ring 0

    MOV  C, A                       ; C = Тестируемый BASE_PORT (LPT0/LPT1)

    ; --- ЭТАП 1: ДИНАМИЧЕСКИЙ SMC-РАСЧЕТ И ПАТЧИНГ ПОРТОВ ---
    INR  A
    STA  _lp_c11_probe_out + 1
    STA  _lp_c11_probe_in + 1
    STA  _lp_c11_init_cmd_out + 1
    STA  _lp_c11_init_status_in + 1 ; Пропатчили все точки ввода-вывода на (BASE + 1)

    ; --- ЭТАП 2: ЖЕСТКИЙ ТЕСТ ФИЗИЧЕСКОГO НАЛИЧИЯ ЧИПА (КРЕМНИЕВАЯ ПРОВЕРКА) ---
    ; Формируем тестовую маску: совмещаем IRQ_EN и BIDIR фланги (0x01 | 0x02 = 0x03)
    MVI  A, C11_CTRL_IRQ_EN | C11_CTRL_BIDIR
_lp_c11_probe_out:
    OUT  000H                       ; Стреляем маску в регистр управления. Патчится на BASE+1
    
    NOP
	NOP                       ; Микропауза стабилизации шины КР580ВМ80А
    
_lp_c11_probe_in:
    IN   000H                       ; Читаем обратно этот же регистр. Патчится на BASE+1
    
    ; Выделяем проверяемые R/W биты управления
    ANI  C11_CTRL_IRQ_EN | C11_CTRL_BIDIR
    CPI  C11_CTRL_IRQ_EN | C11_CTRL_BIDIR ; Чип вернул записанные биты?
    JNZ  _hw_lp_c11_init_fail       ; Нет — кристалл физически отсутствует на шине! [1.3]

    ; --- ЭТАП 3: РАБОЧАЯ КОНФИГУРАЦИЯ И СБРОС КРИСТАЛЛА ---
    ; Активируем чистый вывод данных с разрешением асинхронных прерываний от ACK
    MVI  A, C11_CTRL_IRQ_EN                    
_lp_c11_init_cmd_out:
    OUT  000H                       ; Рабочая прошивка БИС 82C11. Патчится на BASE+1
    NOP
	NOP                       ; Стабилизация внутренних триггеров чипа

    ; --- ЭТАП 4: ТЕСТ ФУНКЦИОНИРОВАНИЯ ВНЕШНЕГO УСТРOЙСТВА (CENTRONICS) ---
_lp_c11_init_status_in:
    IN   000H                       ; Считали внешние флаги статуса. Патчится на BASE+1
    MOV  B, A                       ; B = Кэш регистра статуса

    ; Валидация 1: Проверяем сигнал выбора принтера (LP_SELECT / Бит 4 == 1)
    ANI  LP_SELECT                  ; Маска 0x10 из lp.inc
    JZ   _hw_lp_c11_init_fail       ; Если 0 — принтер выключен или не подключен

    ; Валидация 2: Проверяем датчик окончания бумаги (LP_PAPER_OUT / Бит 5 == 0)
    MOV  A, B
    ANI  LP_PAPER_OUT               ; Маска 0x20 из lp.inc
    JNZ  _hw_lp_c11_init_fail       ; Если 1 — лоток пуст, блокируем запуск

    ; --- ЭТАП 5: ПОСЛЕДОВАТЕЛЬНОЕ ЗАПОЛНЕНИЕ ДЕСКРИПТОРА СЛOТА ---
    MOV  H, D
    MOV  L, E                       ; HL = Истинный адрес слота LP_TABLE

    MVI  M, 00H                     ; O_LP_STATUS = 0
    
    INX  H                          ; HL -> O_LP_PORT_DATA (+1)
    MOV  M, C                       ; Физический порт DATA (BASE+0)
    
    MOV  A, C
	INR A
    INX  H                          ; HL -> O_LP_PORT_STATUS (+2)
    MOV  M, A                       ; Физический порт STATUS (BASE+1)
    
    INX  H                          ; HL -> O_LP_PORT_CTRL (+3)
    MOV  M, A                       ; Физический порт CTRL (Для 82C11 совмещен с STATUS!)
    
    INX  H                          ; HL -> O_LP_FLAGS (+4)
    MVI  M, LP_OPEN                 ; Выставили флаг "Порт успешно открыт" (0x01)
    
    ; Фиксация типа чипа в дескрипторе
    MOV  H, D
    MOV  L, E                       ; HL = Восстановили чистую базу слота
    LXI  B, O_LP_HW_TYPE            ; Смещение +19 из lp.inc
    DAD  B                          ; HL -> O_LP_HW_TYPE
    MVI  M, LP_TYPE_82C11           ; Зафиксировали тип кремния (02H) [1.3]

    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление РОН по LIFO
    ANA  A                          ; СБРОС ФЛАГА ОШИБКИ: CY = 0 (Полный успех!)
    RET

_hw_lp_c11_init_fail:
    POP  H
    POP  D
    POP  B                          ; Восстановили оригинальный контекст супервизора
    STC                             ; ВЗВОД ФЛАГА ОШИБКИ: CY = 1 (Аппаратный отказ чипа / Centronics)
    RET

; =============================================================================
; НАЗВАНИЕ: hw_lp82c11.asm (Асинхронный монолитный ISR для Intel 82C11)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Драйверы Печати
; =============================================================================
; =============================================================================
; АСИНХРОННЫЙ ОБРАБОТЧИК ПРЕРЫВАНИЙ ДЛЯ БИС Intel 82C11
; Вход:  Аппаратный CALL по вектору IRQ от КР580ВН59. Прерывания заперты (DI).
;        Состояние РОН и SP — случайное (из прерванного контекста Ring 3).
; =============================================================================
hw_lp82c11_isr:
_smc_c11_isr_base:
    ; === ЭТАП 0: АППАРАТНЫЙ ПОРТ ПРИВЯЗКИ БАЗЫ (SMC-ИНСТАНС) ===
    LXI  D, 0000H                   ; Сюда карусель lp_core.asm при старте
                                    ; пропишет истинный адрес ОЗУ-структуры слота.

    PUSH B
    PUSH D
    PUSH H                          ; Спасли рантайм-контекст прерванного процесса

    ; === ЭТАП 1: ДИНАМИЧЕСКИЙ SMC-РАСЧЕТ АППАРАТНЫХ ПОРТОВ ---
    MOV  H, D
    MOV  L, E                       ; HL = Физическая база дескриптора принтера
    INX  H                          ; HL -> O_LP_PORT_DATA (+1)
    MOV  A, M                       ; A = Физический базовый порт DATA (0x78 или 0x28)
    MOV  C, A                       ; C = Кэш базового порта DATA
    
    ; Прошиваем операнд инструкции OUT для выдачи данных (BASE+0)
    STA  _lp_c11_isr_data_out + 1
    
    ; Вычисляем и прошиваем управляющий порт (BASE+1)
    MOV  A, C \ INR  A
    STA  _lp_c11_isr_ctrl_out + 1   ; SMC-патч операндов ввода-вывода завершен!

    ; === ЭТАП 2: КОНТРОЛЬ НАЛИЧИЯ ДАННЫХ В TX КОЛЬЦЕ ОЗУ ===
    MOV  H, D
    MOV  L, E                       ; HL = База слота LPT
    LXI  B, O_LP_BUFFER_COUNT       ; Смещение +18 из lp.inc
    DAD  B                          ; HL -> O_LP_BUFFER_COUNT
    MOV  A, M
    ORA  A                          ; BUFFER_COUNT == 0 (Очередь вывода пуста)?
    JZ   _lp_c11_isr_empty_close    ; Да — уходим на глушение линии прерываний чипа

    ; === ЭТАП 3: ИЗВЛЕЧЕНИЕ БАЙТА ИЗ КОЛЬЦЕВОГО FIFO БУФЕРА ===
    DCR  M                          ; O_LP_BUFFER_COUNT-- (Фиксация в памяти ядра)
    
    ; Извлекаем индекс чтения по указателю TAIL
    DCX  H                          ; HL -> O_LP_BUFFER_TAIL (Смещение +17)
    MOV  A, M                       ; A = TAIL_old
    MOV  B, A                       ; B = Кэш текущего индекса чтения
    
    ; Инкрементируем и зацикливаем TAIL в памяти ядра Ring 0
    INR  M                          ; TAIL++
    MOV  A, M
    CPI  48                         ; Граница буфера строго 48 байт (21+48=69 < 80) [1.3]
    JC   _lp_c11_isr_tail_no_wrap
    MVI  M, 00H                     ; Циклический заворот TAIL = 0

_lp_c11_isr_tail_no_wrap:
    ; Двухступенчатый DAD-расчет физического адреса байта в ОЗУ
    MOV  H, D
    MOV  L, E                       ; HL = Восстановили чистую базу слота LPT
    PUSH D                          ; Спрятали базу слота
    
    LXI  D, 21                      ; Смещение начала сектора данных буфера FIFO
    DAD  D                          ; HL = База + Начало буфера вывода
    
    MOV  E, B
    MVI  D, 00H                     ; DE = 0000H + TAIL_old
    DAD  D                          ; HL = Точный физический адрес байта в ОЗУ ядра Ring 0!
    MOV  A, M                       ; А = ASCII-символ, готовый к печати
    MOV  B, A                       ; B = Спасли символ от затирания при POP
    POP  D                          ; DE = Восстановили базу слота LPT

    ; === ЭТАП 3.1: ПОЛНЫЙ 32-БИТНЫЙ ИНКРЕМЕНТ СЧЕТЧИКА O_LP_BYTES_WRITTEN ===
    ; Наш утвержденный каноничный каскад обработки переносов Little-Endian
    MOV  H, D
    MOV  L, E
    LXI  D, O_LP_BYTES_WRITTEN      ; Смещение +8 из lp.inc
    DAD  D                          ; HL -> Байт 0 (младший) счётчика
    
    INR  M                          ; Байт 0++
    JNZ  _lp_c11_bytes_inc_done     ; Если не было переполнения — выходим из каскада
    
    INX  H                          ; Переход к Байту 1
    INR  M
    JNZ  _lp_c11_bytes_inc_done
    
    INX  H                          ; Переход к Байту 2
    INR  M
    JNZ  _lp_c11_bytes_inc_done
    
    INX  H                          ; Переход к Байту 3 (старший)
    INR  M

_lp_c11_bytes_inc_done:
    ; === ЭТАП 4: ФИЗИЧЕСКИЙ ВЫСТРЕЛ В КРЕМНИЙ Intel 82C11 ===
    MOV  A, B                       ; А = Извлеченный ASCII-символ
_lp_c11_isr_data_out:
    OUT  000H                       ; Выставили символ в регистр данных. Патчится на BASE+0
                                    ; ВНИМАНИЕ: Чип 82C11 сам аппаратно сформирует строб! [1.3]
    JMP  _lp_c11_isr_close_8259

_lp_c11_isr_empty_close:
    ; Очередь ОЗУ пуста — принудительно гасим асинхронные прерывания чипа 82C11.
    MVI  A, C11_CTRL_RESET
_lp_c11_isr_ctrl_out:
    OUT  000H                       ; Прерывания чипа 82C11 заблокированы. Патчится на BASE+1 [1.3]

    ; Переводим логический статус порта в состояние покоя (O_LP_STATUS = 0)
    MOV  H, D
    MOV  L, E
    MVI  M, 00H                     

_lp_c11_isr_close_8259:
    ; === ЭТАП 5: СБРОС ТРИГГЕРА КОНТРОЛЛЕРА ПРЕРЫВАНИЙ КР580ВН59 ===
    ; ИСПРАВЛЕНО: отправляем EOI в реальный порт ВН59 согласно вашему стандарту
    MVI  A, 020H
    OUT  MASTER_8259_CMD            ; Неспецифический EOI в главный контроллер прерываний ВН59
    
    POP  H
    POP  D
    POP  B                          ; Полное каноническое восстановление контекста прерванной задачи
    EI                              ; Разрешили асинхронный конвейер шины eMMU
    RET


#include "kernel.mem"
#code RAM, EMMU_PAGE_1, EMMU_PAGE_SIZE

#include "./include/kernel_time.mem"
; =============================================================================
; MEGA-580_OS v1.5.76_TIME - SYSTEM CLOCK & TICK COUNTER
; BUILD DATE: 20260708 | AUTHOR: OS ARCHITECT & KERNEL TIME MANAGER
; =============================================================================

; --- Системный счетчик тиков текущей секунды (0..49) ---
SYS_TICK_COUNTER:   DS  1           ; 1 байт

; --- Глобальное 32-битное время UNIX Time (Little-Endian) ---
SYS_UNIX_TIME:      DS  4           ; 4 байта (Младший байт по адресу 0B121H)
#include "./include/vfs.mem"
; =============================================================================
; /include/vfs.mem - РЕЗЕРВИРОВАНИЕ СТАТИЧЕСКОЙ ОЗУ ПОДСИС ТЕМЫ ВИРТУАЛЬНОЙ ФС
; =============================================================================

VFS_SWITCH_TABLE:    ds  VFS_MAX_TYPES * VFS_ROW_SIZE       ; Выделено 320 байт ОЗУ
SYS_FILE_TABLE:      ds  MAX_SYS_FILES * SYS_FILE_SLOT_SIZE ; Выделено 1280 байт ОЗУ

; =============================================================================
; ЛОКАЛЬНЫЙ СУПЕРВИЗОРСКИЙ СЕКТОР ХРАНЕНИЯ ПАРАМЕТРОВ (RAM ЯДРА)
; =============================================================================
_vfs_mknod_tmp_type:    DB  000H
_vfs_mknod_tmp_major:   DB  000H
_vfs_mknod_tmp_minor:   DB  000H

; Глобальная область памяти RAM-диска VFS (Выделено ровно 1024 байта ОЗУ)
VFS_INODE_TABLE:        DS  VFS_MAX_INODES * INODE_STRUCT_SIZE

; Служебные ячейки атомарной табличной диспетчеризации
VFS_DISPATCH_MAJOR:  ds  1
VFS_DISPATCH_MINOR:  ds  1
VFS_DRV_ROW_PTR:     ds  2
VFS_CLOSE_TEMP_IDX:  ds  1
VFS_CLOSE_STRUCT_PTR:ds  2
VFS_CLOSE_MAJOR_TMP: ds  1
VFS_CLOSE_MINOR_TMP: ds  1

; --- ГЛОБАЛЬНАЯ ТАБЛИЦА АППАРАТНЫХ ISR (8 ВЕКТОРОВ * 2 БАЙТА = 16 БАЙТ) ---
SYS_ISR_TABLE:       ds  8 * 2                              ; Хранилище прерываний

; --- ТАБЛИЦА СТАТИЧЕСКОГО МОНТИРОВАНИЯ УЗЛОВ ОБОРУДОВАНИЯ /dev/ ---
DEV_MOUNT_TABLE:     ds  MAX_MOUNT_DEVS * MNT_ENTRY_SZ      ; Выделено ровно 96 байт ОЗУ

; Внутренний скалярный кэш модулей VFS
K_TMP_SLOTS_CNT:     ds  1                                  ; Счетчик слотов
K_TMP_CURR_LO:       ds  1
K_TMP_CURR_HI:       ds  1

; Временный scratchpad для атомарной маршрутизации k_vfs_dispatch
K_TMP_PC:            ds  2                                  ; ЖЕСТКИЙ ФИКС: Выделено 2 байта!
#include "./include/chrdev.mem"
; =============================================================================
; ДИНАМИЧЕСКИ РЕЛОЦИРУЕМЫЙ СЕГМЕНТ СИСТЕМНОЙ ПАМЯТИ ЯДРА (BSS)
; =============================================================================
O_CHR_WRITE         EQU 0           ; Смещение метода write драйвера
O_CHR_READ          EQU 2           ; Смещение метода read драйвера
CHRDEV_OPS_SIZE     EQU 4           ; Размер структуры одного Major-слота

; Глобальная таблица драйверов (Выделяет ровно 128 байт ОЗУ в текущей куче ядра)
SYS_CHRDEV_SWITCH:  DS  VFS_MAX_TYPES * CHRDEV_OPS_SIZE
#include "./include/pcb.mem"
; =============================================================================
; /include/pcb.mem - РЕЛОЦИРУЕМАЯ ПАМЯТЬ ПОДСИС ТЕМЫ ПЛАНИРОВАНИЯ И ЗАДАЧ
; =============================================================================
CURRENT_PID:		ds  1            ; Идентификатор активной задачи (1..32)
NEXT_PID:			ds  1            ; Идентификатор следующей задачи на активацию
CURRENT_PCB_PTR:	ds  2            ; 16-битный физический кэш-адрес активного PCB

; Внутренние scratchpad-ячейки приоритетного шедуллера
SCHED_BEST_PRIO:	ds  1            ; Минимальное значение динамического приоритета
SCHED_BEST_PID:		ds  1            ; PID кандидата на переключение

; МОНОЛИТНАЯ ТАБЛИЦА СТРУКТУР ВСЕХ ПРОЦЕССОВ ЯДРА (ЗАНИМАЕТ СТРОГО 2 КИЛОБАЙТА)
PCB_TABLE:			ds  MAX_PROCS * PCB_SIZE

; Метрика производительности системы
CPU_USAGE:			ds  1            ; Текущая загрузка CPU (Метрика: 0..4)
#include "./include/syscall.mem"
SYSCALL_TABLE:
	DW		syscall_bad_number
    ; DW	sys_fork				; Index 0: SYS_FORK
    ; DW	sys_exit				; Index 1: SYS_EXIT
    ; DW	sys_waitpid				; Index 2: SYS_WAITPID
    ; DW	sys_request_io			; Index 3: SYS_REQUEST_IO
    ; DW	sys_release_io			; Index 4: SYS_RELEASE_IO
    ; DW	sys_open				; Index 5: SYS_OPEN
    ; DW	sys_close				; Index 6: SYS_CLOSE
    ; DW	sys_read				; Index 7: SYS_READ
    ; DW	sys_write				; Index 8: SYS_WRITE
    ; DW	sys_chdir				; Index 9: SYS_CHDIR
    ; DW	sys_alarm				; Index 10: SYS_ALARM
    ; DW	sys_sigaction			; Index 11: SYS_SIGACTION
    ; DW	sys_execve				; Index 12: SYS_EXECVE
	; DW  sys_overlay_map			; Index 13: SYS_OVERLAY_MAP
	; DW	sys_kill				; Index 14: SYS_KILL
	; DW	sys_lseek				; Index 15: SYS_LSEEK
	; DW	sys_pipe				; Index 16: SYS_PIPE
	; DW	sys_mutex				; Index 17: SYS_MUTEX
	; DW	sys_cond				; Index 18: SYS_COND
	; DW	sys_sem_wait			; Index 19: SYS_SEM_WAIT
	; DW	sys_sem_post			; Index 20: SYS_SEM_POST
	; DW	sys_socket				; Index 21: SYS_SOCKET
	; DW	sys_send				; Index 22: SYS_SEND
	; DW	sys_recv				; Index 23: SYS_RECV
	; DW	sys_socketpair			; Index 24: SYS_SOCKETPAIR
	; DW	sys_netstat				; Index 25: SYS_NETSTAT
	; DW	sys_shutdown			; Index 26: SYS_SHUTDOWN
	; DW	sys_openpty				; Index 27: SYS_OPENPTY
	; DW	sys_ptsname				; Index 28: SYS_PTSNAME
	; DW	sys_ttyname				; Index 29: SYS_TTYNAME
	; DW	sys_ioctl				; Index 30: SYS_IOCTL
	; DW	sys_setsid				; Index 31: SYS_SETSID
	; DW	sys_getpid				; Index 32: SYS_GETPID
	; DW	sys_getppid				; Index 33: SYS_GETPPID
	; DW	sys_getuid				; Index 34: SYS_GETUID
#include "./include/tty.mem"
; =============================================================================
; /include/tty.mem - ВЫДЕЛЕНИЕ ПАМЯТИ ТЕРМИНАЛЬНОГО ДВИЖКА (МАССИВ 4 TTY × 160 B)
; =============================================================================

; МОНОЛИТНАЯ ТАБЛИЦА АТРИБУТОВ И БУФЕРОВ КОНСОЛЕЙ ЯДРА (ВЫРАВНИВАНИЕ 160 БАЙТ)
; Расчёт габаритов: 4 * 160 байт = 640 байт ОЗУ в системном пространстве Ring 0
TTY_TABLE:         DS  MAX_TTY_DEVS * TTY_STRUCT_SIZE
#include "./include/hw_i8251.mem"
; =============================================================================
; MEGA-580_OS v1.5.54_HAL - i8251 DRIVER RAM RESERVATION
; BUILD DATE: 20260707 | AUTHOR: OS ARCHITECT & DEVICE DRIVER MANAGER
; =============================================================================

; --- Таблица статического маппинга физических портов для 4-х консолей ---
; Каждый байт хранит базовый адрес портов для TTY 0..3 (для ВВ51 это константа 0A0H)
HW_8251_PORT_MAP:	DS	MAX_TTY_DEVS

; Временная ячейка памяти для сохранения символа (должна быть в секции RAM)
_temp_get_char:		DB 0
#include "./include/hw_ns16550.mem"
; --- Изолированная локальная ячейка памяти драйвера NS16550 (Секция RAM ядра) ---
_temp_ns_get_char:  DB  000H
#include "./include/lp.mem"
; =============================================================================
; НАЗВАНИЕ: lp.mem (Выделение неинициализированной памяти подсистемы LPT)
; СРЕДА:    Ring 0 супервизора | Архитектура КР580ВМ80А | Секция BSS Ядра
; =============================================================================

; Глобальная таблица дескрипторов параллельных принтеров.
; Выделяет ровно 160 байт последовательного ОЗУ (2 слота по 80 байт) [1.3].
; Слот 0 (Смещение +0)  -> Обслуживает /dev/lp0 (Инстанс LPT0)
; Слот 1 (Смещение +80) -> Обслуживает /dev/lp1 (Инстанс LPT1)
LP_TABLE:           DS  LP_MAX_DEVICES * LP_STRUCT_SIZE

; --- Локальный супервизорский сектор хранения (BSS RAM ядра) ---
_lp_wr_br_tmp_head:     DB  000H

; =============================================================================
; Системные структуры данных распределения памяти Ring 0
; =============================================================================
RAM_BITMAP:        DS  RAM_BITMAP_SIZE ; Битовая карта занятых/свободных страниц ОЗУ

; Глобальная таблица занятости портов/устройств (256 байт)
; Индекс — номер порта (00H-0FFH). Значение — PID владельца или 0FFH
GLOBAL_RESOURCE_TABLE:  DS 256

;=========================================================================================================================
#code _BLANK_RAM, RAM_end+1, EMMU_PAGE_SIZE-RAM_size

;=========================================================================================================================
#code _BLANK_OVERRUN, EMMU_PAGE_2, EMMU_PAGE_SIZE

;=========================================================================================================================
#code _BLANK_STACK, EMMU_PAGE_3, EMMU_PAGE_SIZE-KERNEL_STACK_SIZE
;				DB	0xAA
;				DB	0x55
;				DW	KERNEL_STACK_TOP
;				DW	KERNEL_STACK_SIZE
;				DW	KERNEL_STACK

;=========================================================================================================================
#code _STACK, _BLANK_STACK_end, KERNEL_STACK_SIZE
; Системный стек Ядра (Изолирован от пользовательских стеков Ring 3)
KERNEL_STACK_SIZE		EQU 512          ; Выделяем 512 байт под вложенные прерывания
KERNEL_STACK_TOP		EQU _STACK_end-1	 ; _STACK + KERNEL_STACK_SIZE	; <-- ВЕРШИНА СТЕКА ЯДРА (Сюда указывает SP супервизора при старте)

; --- ИЗОЛИРОВАННАЯ И ЗАЩИЩЕННАЯ ОБЛАСТЬ СТЕКА ЯДРА (GROW DOWNWARD) ---
KERNEL_STACK:	DS  KERNEL_STACK_SIZE ; Выделяем место под стек в ОЗУ Ring 0



