; =============================================================================
; MEGA-580_OS // FILE: panic.inc // SUBSYSTEM K_PANIC REGESTRY (SEALED)
; =============================================================================

; --- УЗЕЛ 1: АППАРАТНАЯ ПЛАТФОРМА СУПЕРВИЗОРА (0x10) ---
PANIC_HW_PIC_FAILURE  EQU 015H    ; БИС КР580ВН59 не отвечает (прерывания парализованы)
PANIC_HW_PIT_FAILURE  EQU 011H    ; БИС КР580ВИ53 заклинило (нет системного кванта 20 мс)

; --- УЗЕЛ 2: ФИЗИЧЕСКИЕ СИСТЕМНЫЕ КОНСОЛИ ВВОДА-ВЫВОДА (0x20) ---
PANIC_TTY_NONE_FOUND  EQU 023H    ; Автодетектер не обнаружил ни одного терминала КР580ВВ51А

; --- УЗЕЛ 4: СТРУКТУРЫ И ИНДЕКСЫ ВИРТУАЛЬНОЙ ФС (0x40) ---
PANIC_VFS_INDEX_CORRUPT EQU 046H  ; Извлечен нулевой вектор метода для критического узла VFS
PANIC_VFS_SYS_FT_CRASH  EQU 043H  ; Физическое разрушение таблицы дескрипторов SYS_FILE_TABLE

; --- УЗЕЛ 5: ЧАСЫ РЕАЛЬНОГО ВРЕМЕНИ И КАЛЕНДАРЬ (0x50) ---
PANIC_RTC_CHIP_CRASH   EQU 053H   ; Аппаратный отказ или исчезновение чипа КР512ВИ1 при сисколле
