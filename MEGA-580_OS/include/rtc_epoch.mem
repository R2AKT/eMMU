; =============================================================================
; MEGA-580_OS // FILE: rtc_epoch.mem // SUBSYSTEM RTC/NVRAM STEP_2
; =============================================================================

; --- 32-битный временный аккумулятор для расчета секунд (Little-Endian) ---
k_rtc_sec_acc_b0:   DS 1
k_rtc_sec_acc_b1:   DS 1
k_rtc_sec_acc_b2:   DS 1
k_rtc_sec_acc_b3:   DS 1

; Временная ячейка для хранения промежуточных дней
k_rtc_tmp_days:     DS 2

; --- Константная таблица дней, прошедших с начала года (невисокосный год) ---
; ВАЖНО: Используем DW (16 бит), так как значения для октября (273), 
; ноября (304) и декабря (334) превышают максимальное значение 8-битного регистра (255)!
; Индекс 0 = Январь (0 дней), Индекс 1 = Февраль (31 день) и т.д.
k_rtc_days_before_month:
    .dw 0    ; 0: Январь (0 дней прошло)
    .dw 31   ; 1: Февраль (31 день)
    .dw 59   ; 2: Март (31+28)
    .dw 90   ; 3: Апрель (31+28+31)
    .dw 120  ; 4: Май
    .dw 151  ; 5: Июнь
    .dw 181  ; 6: Июль
    .dw 212  ; 7: Август
    .dw 243  ; 8: Сентябрь
    .dw 273  ; 9: Октябрь
    .dw 304  ; 10: Ноябрь
    .dw 334  ; 11: Декабрь